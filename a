local function showNotif(title, message, notifType)
	if not notifEnabled then return end
	notifCount += 1

	local typeColor = ACCENT
	if notifType == "success" then typeColor = Color3.fromRGB(60, 200, 120)
	elseif notifType == "error" then typeColor = Color3.fromRGB(220, 70, 70)
	elseif notifType == "warning" then typeColor = Color3.fromRGB(220, 160, 40) end

	local card = Instance.new("Frame")
	card.Name = "Notif_" .. notifCount
	card.Size = UDim2.new(1, 0, 0, 52)
	card.BackgroundColor3 = Color3.fromRGB(18, 17, 27)
	card.BorderSizePixel = 0
	card.LayoutOrder = -notifCount
	card.ZIndex = 200
	card.ClipsDescendants = true
	card.Parent = notifHolder
	corner(card, 7)

	local stroke = Instance.new("UIStroke")
	stroke.Color = Color3.fromRGB(32, 30, 48)
	stroke.Thickness = 1
	stroke.Parent = card

	-- Title
	local titleLbl = Instance.new("TextLabel")
	titleLbl.Size = UDim2.new(1, -36, 0, 16)
	titleLbl.Position = UDim2.new(0, 12, 0, 9)
	titleLbl.BackgroundTransparency = 1
	titleLbl.Text = title
	titleLbl.TextColor3 = TEXT_MAIN
	titleLbl.TextSize = 12
	titleLbl.Font = Enum.Font.GothamBold
	titleLbl.TextXAlignment = Enum.TextXAlignment.Left
	titleLbl.ZIndex = 201
	titleLbl.Parent = card

	-- Message
	local msgLbl = Instance.new("TextLabel")
	msgLbl.Size = UDim2.new(1, -36, 0, 13)
	msgLbl.Position = UDim2.new(0, 12, 0, 27)
	msgLbl.BackgroundTransparency = 1
	msgLbl.Text = message
	msgLbl.TextColor3 = TEXT_MUTED
	msgLbl.TextSize = 10
	msgLbl.Font = Enum.Font.Gotham
	msgLbl.TextXAlignment = Enum.TextXAlignment.Left
	msgLbl.ZIndex = 201
	msgLbl.Parent = card

	-- Close button
	local closeBtn = Instance.new("TextButton")
	closeBtn.Size = UDim2.new(0, 18, 0, 18)
	closeBtn.Position = UDim2.new(1, -24, 0, 5)
	closeBtn.BackgroundTransparency = 1
	closeBtn.Text = "×"
	closeBtn.TextColor3 = TEXT_MUTED
	closeBtn.TextSize = 15
	closeBtn.Font = Enum.Font.GothamBold
	closeBtn.ZIndex = 202
	closeBtn.Parent = card

	-- Progress bar — sits at bottom edge, fully inside the card
	local progress = Instance.new("Frame")
	progress.Size = UDim2.new(1, -24, 0, 2)
	progress.Position = UDim2.new(0, 12, 1, -4)
	progress.BackgroundColor3 = typeColor
	progress.BackgroundTransparency = 0.3
	progress.BorderSizePixel = 0
	progress.ZIndex = 201
	progress.Parent = card
	corner(progress, 1)

	tween(progress, { Size = UDim2.new(0, 0, 0, 2) }, TweenInfo.new(4, Enum.EasingStyle.Linear))

	local function dismiss()
		tween(card, { BackgroundTransparency = 1 }, TweenInfo.new(0.2, Enum.EasingStyle.Quad))
		tween(titleLbl, { TextTransparency = 1 }, TweenInfo.new(0.2, Enum.EasingStyle.Quad))
		tween(msgLbl,   { TextTransparency = 1 }, TweenInfo.new(0.2, Enum.EasingStyle.Quad))
		tween(stroke,   { Transparency = 1 },     TweenInfo.new(0.2, Enum.EasingStyle.Quad))
		task.delay(0.22, function()
			tween(card, { Size = UDim2.new(1, 0, 0, 0) }, tweenInfoFast)
			task.delay(0.14, function() card:Destroy() end)
		end)
	end

	closeBtn.MouseButton1Click:Connect(dismiss)
	task.delay(4.1, function() if card and card.Parent then dismiss() end end)
end

