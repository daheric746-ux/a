function SpareStackLib:LoadConfigsFromFile()
	if not isfolder("spare_stack_configs") then
		makefolder("spare_stack_configs")
	end

	self.SavedConfigs = {}
	local success, files = pcall(function()
		return listfiles("spare_stack_configs")
	end)

	if success and files then
		for _, filepath in pairs(files) do
			if filepath:match("%.json$") then
				local configSuccess, configData = pcall(function()
					return readfile(filepath)
				end)

				if configSuccess and configData then
					local decoded = HttpService:JSONDecode(configData)
					if decoded and decoded.Name then
						self.SavedConfigs[decoded.Name] = decoded
					end
				end
			end
		end
	end

	if self.ConfigListHolder then
		self:RefreshConfigList()
	end
end

function SpareStackLib:SaveConfigToFile(configName)
	if not isfolder("spare_stack_configs") then
		makefolder("spare_stack_configs")
	end

	local config = self.SavedConfigs[configName]
	if not config then return end

	local success, err = pcall(function()
		local encoded = HttpService:JSONEncode(config)
		writefile("spare_stack_configs/" .. configName .. ".json", encoded)
	end)

	if not success then
		warn("Failed to save config:", err)
	end
end

function SpareStackLib:DeleteConfigFile(configName)
	local filepath = "spare_stack_configs/" .. configName .. ".json"
	local success, err = pcall(function()
		if isfile(filepath) then
			delfile(filepath)
		end
	end)

	if not success then
		warn("Failed to delete config file:", err)
	end
end

function SpareStackLib:LoadConfig(configName)
	local config = self.SavedConfigs[configName]
	if not config then
		self:Notify("Error", "Config not found", 2)
		return
	end

	for elementName, data in pairs(config.Data) do
		if self.ConfigData[elementName] then
			pcall(function()
				self.ConfigData[elementName].SetValue(data.Value)
			end)
		end
	end

	self:Notify("Success", "Config loaded: " .. configName, 2)
end

function SpareStackLib:DeleteConfig(configName)
	self.SavedConfigs[configName] = nil
	self:DeleteConfigFile(configName)
	self:Notify("Deleted", "Config deleted: " .. configName, 2)
	self:RefreshConfigList()
end

function SpareStackLib:Notify(title, text, duration, notifType, position)
	duration = duration or 3
	notifType = notifType or "info"
	position = position or "topright"

	local NOTIF_H = 95
	local NOTIF_GAP = 8
	local NOTIF_STEP = NOTIF_H + NOTIF_GAP  -- 103px per slot

	local iconId, fillerColor
	if notifType == "success" then
		iconId = "rbxassetid://96462596892775"
		fillerColor = Color3.fromRGB(34, 197, 94)
	elseif notifType == "error" then
		iconId = "rbxassetid://84674618415860"
		fillerColor = Color3.fromRGB(239, 68, 68)
	elseif notifType == "warning" then
		iconId = "rbxassetid://115818015422286"
		fillerColor = Color3.fromRGB(250, 204, 21)
	else
		iconId = "rbxassetid://99108275822290"
		fillerColor = Color3.fromRGB(51, 105, 255)
	end

	-- Base anchors per position (off-screen start, on-screen base Y)
	local isRight = (position == "topright" or position == "bottomright")
	local isBottom = (position == "bottomright" or position == "bottomleft")

	local function getEndPos(slotIndex)
		local yBase = isBottom and -115 or 20
		local yOffset = isBottom
			and (yBase - (slotIndex - 1) * NOTIF_STEP)
			or  (yBase + (slotIndex - 1) * NOTIF_STEP)
		local xScale = isRight and 1 or 0
		local xOffset = isRight and -360 or 14
		local yScale = isBottom and 1 or 0
		return UDim2.new(xScale, xOffset, yScale, yOffset)
	end

	local function getStartPos()
		local xScale = isRight and 1 or 0
		local xOffset = isRight and 100 or -400
		local yScale = isBottom and 1 or 0
		local yOffset = isBottom and -115 or 20
		return UDim2.new(xScale, xOffset, yScale, yOffset)
	end

	-- Assign a slot: first gap in the stack, or append
	local slotIndex = #self._activeNotifs + 1
	for i, entry in ipairs(self._activeNotifs) do
		if entry == false then
			slotIndex = i
			break
		end
	end

	local Holder = createInstance("Frame", {
		Name = "NotificationHolder",
		Position = getStartPos(),
		Size = UDim2.new(0, 346, 0, NOTIF_H),
		Parent = self.Gui,
		BackgroundColor3 = Color3.fromRGB(16, 16, 21),
		BorderSizePixel = 0,
		ZIndex = 100,
	})

	self._activeNotifs[slotIndex] = Holder

	createInstance("UICorner", { Parent = Holder, CornerRadius = UDim.new(0, 5) })

	createInstance("TextLabel", {
		Name = "Label",
		Position = UDim2.new(0.12, 0, 0.05, 0),
		Size = UDim2.new(0, 150, 0, 40),
		Parent = Holder,
		BackgroundTransparency = 1,
		Font = Enum.Font.GothamBold,
		Text = title,
		TextScaled = true,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextYAlignment = Enum.TextYAlignment.Center,
		TextWrapped = true,
		TextColor3 = Color3.fromRGB(255, 255, 255),
		BackgroundColor3 = Color3.fromRGB(255, 255, 255),
		TextSize = 14,
		BorderSizePixel = 0,
		ZIndex = 101,
	})

	createInstance("UITextSizeConstraint", {
		Parent = Holder:FindFirstChild("Label"),
		MaxTextSize = 15,
		MinTextSize = 1,
	})

	createInstance("ImageLabel", {
		Name = "Image",
		Position = UDim2.new(0.035, 0, 0.158, 0),
		Size = UDim2.new(0, 20, 0, 20),
		Parent = Holder,
		BackgroundTransparency = 1,
		BackgroundColor3 = Color3.fromRGB(255, 255, 255),
		ImageColor3 = Color3.fromRGB(255, 255, 255),
		Image = iconId,
		BorderSizePixel = 0,
		ZIndex = 101,
	})

	local BarHolder = createInstance("Frame", {
		Name = "BarHolder",
		Position = UDim2.new(0.038, 0, 0.705, 0),
		Size = UDim2.new(0, 320, 0, 13),
		Parent = Holder,
		BackgroundColor3 = Color3.fromRGB(30, 30, 36),
		BorderSizePixel = 0,
		ZIndex = 101,
	})
	createInstance("UICorner", { Parent = BarHolder })

	local Filler = createInstance("Frame", {
		Name = "Filler",
		Position = UDim2.new(0.035, 0, 0.705, 0),
		Size = UDim2.new(0, 320, 0, 13),
		Parent = Holder,
		BackgroundColor3 = fillerColor,
		BorderSizePixel = 0,
		ZIndex = 102,
	})
	createInstance("UICorner", { Parent = Filler })

	local Desc = createInstance("TextLabel", {
		Name = "Description",
		Position = UDim2.new(0.035, 0, 0.358, 0),
		Size = UDim2.new(0, 300, 0, 32),
		Parent = Holder,
		BackgroundTransparency = 1,
		Font = Enum.Font.Gotham,
		Text = text,
		TextScaled = true,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextYAlignment = Enum.TextYAlignment.Center,
		TextWrapped = true,
		TextColor3 = Color3.fromRGB(200, 200, 200),
		BackgroundColor3 = Color3.fromRGB(255, 255, 255),
		TextSize = 14,
		BorderSizePixel = 0,
		ZIndex = 101,
	})
	createInstance("UITextSizeConstraint", { Parent = Desc, MaxTextSize = 11, MinTextSize = 1 })

	local Close = createInstance("ImageButton", {
		Name = "Close",
		Position = UDim2.new(0.905, 0, 0.147, 0),
		Size = UDim2.new(0, 20, 0, 20),
		Parent = Holder,
		BackgroundTransparency = 1,
		BackgroundColor3 = Color3.fromRGB(255, 255, 255),
		ImageColor3 = Color3.fromRGB(255, 255, 255),
		Image = "rbxassetid://93374486940401",
		BorderSizePixel = 0,
		ZIndex = 101,
	})

	local function repositionAll()
		for i, entry in ipairs(self._activeNotifs) do
			if entry and entry ~= false and entry.Parent then
				TweenService:Create(entry, TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
					Position = getEndPos(i),
				}):Play()
			end
		end
	end

	local function dismiss()
		self._activeNotifs[slotIndex] = false
		-- Trim trailing false entries
		while #self._activeNotifs > 0 and self._activeNotifs[#self._activeNotifs] == false do
			table.remove(self._activeNotifs)
		end
		repositionAll()
	end

	local slideIn = TweenService:Create(Holder,
		TweenInfo.new(0.5, Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
		{ Position = getEndPos(slotIndex) })

	local slideOut = TweenService:Create(Holder,
		TweenInfo.new(0.4, Enum.EasingStyle.Quint, Enum.EasingDirection.In),
		{ Position = getStartPos() })

	local barTween = TweenService:Create(Filler,
		TweenInfo.new(duration, Enum.EasingStyle.Linear),
		{ Size = UDim2.new(0, 0, 0, 13) })

	local closed = false
	local function close()
		if closed then return end
		closed = true
		barTween:Cancel()
		dismiss()
		slideOut:Play()
		task.wait(0.4)
		if Holder and Holder.Parent then Holder:Destroy() end
	end

	Close.MouseButton1Click:Connect(close)

	slideIn:Play()
	task.wait(0.5)
	barTween:Play()
	task.wait(duration)
	close()
end

