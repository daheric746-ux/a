local function buildColorPicker(parent, defaultColor)
	local currentColor = defaultColor or Color3.fromRGB(135,96,220)
	local open = false
	local PRESETS = {
		Color3.fromRGB(135,96,220), Color3.fromRGB(80,140,255),
		Color3.fromRGB(60,200,120), Color3.fromRGB(220,70,70),
		Color3.fromRGB(220,120,40), Color3.fromRGB(220,60,160),
		Color3.fromRGB(255,220,50), Color3.fromRGB(40,200,220),
	}
	local swatch = Instance.new("Frame")
	swatch.Size = UDim2.new(0,34,0,34)
	swatch.Position = UDim2.new(1,-34,0.5,-17)
	swatch.BackgroundColor3 = currentColor
	swatch.BorderSizePixel = 0
	swatch.ZIndex = 2
	swatch.Parent = parent
	corner(swatch,6)
	local swatchBorder = Instance.new("UIStroke")
	swatchBorder.Color = Color3.fromRGB(255,255,255)
	swatchBorder.Transparency = 0.82
	swatchBorder.Thickness = 1.5
	swatchBorder.Parent = swatch
	local swatchBtn = Instance.new("TextButton")
	swatchBtn.Size = UDim2.new(1,0,1,0)
	swatchBtn.BackgroundTransparency = 1
	swatchBtn.Text = ""
	swatchBtn.ZIndex = 3
	swatchBtn.Parent = swatch

	local POPUP_W=200; local POPUP_H=140
	local popup = Instance.new("Frame")
	popup.Size = UDim2.new(0,POPUP_W,0,POPUP_H)
	popup.BackgroundColor3 = Color3.fromRGB(17,16,26)
	popup.BorderSizePixel = 0
	popup.ZIndex = 50
	popup.Visible = false
	popup.ClipsDescendants = true
	popup.Parent = MainFrame
	corner(popup,10)
	local popupStroke = Instance.new("UIStroke")
	popupStroke.Color = Color3.fromRGB(42,40,62)
	popupStroke.Transparency = 0
	popupStroke.Thickness = 1
	popupStroke.Parent = popup
	local inner = Instance.new("Frame")
	inner.Size = UDim2.new(1,-20,1,-16)
	inner.Position = UDim2.new(0,10,0,8)
	inner.BackgroundTransparency = 1
	inner.ZIndex = 51
	inner.Parent = popup

	local SS=38; local SG=5; local COLS=4; local activeIndicator=nil
	local function applyColor(c,ind)
		currentColor=c; swatch.BackgroundColor3=c
		if activeIndicator then activeIndicator.Visible=false end
		if ind then ind.Visible=true; activeIndicator=ind end
	end
	for i,presetColor in ipairs(PRESETS) do
		local col=(i-1)%COLS; local row2=math.floor((i-1)/COLS)
		local ps=Instance.new("Frame")
		ps.Size=UDim2.new(0,SS,0,SS); ps.Position=UDim2.new(0,col*(SS+SG),0,row2*(SS+SG))
		ps.BackgroundColor3=presetColor; ps.BorderSizePixel=0; ps.ZIndex=52; ps.Parent=inner
		corner(ps,5)
		local psBorder=Instance.new("UIStroke"); psBorder.Color=Color3.fromRGB(255,255,255); psBorder.Transparency=0.85; psBorder.Thickness=1; psBorder.Parent=ps
		local checkInd=Instance.new("Frame"); checkInd.Size=UDim2.new(1,0,1,0); checkInd.BackgroundColor3=Color3.fromRGB(0,0,0)
		checkInd.BackgroundTransparency=0.45; checkInd.BorderSizePixel=0; checkInd.ZIndex=53; checkInd.Visible=(presetColor==currentColor); checkInd.Parent=ps
		corner(checkInd,5)
		local chkIco=Instance.new("ImageLabel"); chkIco.Size=UDim2.new(0,14,0,14); chkIco.Position=UDim2.new(0.5,-7,0.5,-7)
		chkIco.BackgroundTransparency=1; chkIco.Image=getIcon("check","Material"); chkIco.ImageColor3=Color3.fromRGB(255,255,255); chkIco.ZIndex=54; chkIco.Parent=checkInd
		if presetColor==currentColor then activeIndicator=checkInd end
		local psBtn=Instance.new("TextButton"); psBtn.Size=UDim2.new(1,0,1,0); psBtn.BackgroundTransparency=1; psBtn.Text=""; psBtn.ZIndex=55; psBtn.Parent=ps
		psBtn.MouseEnter:Connect(function() tween(ps,{BackgroundColor3=presetColor:Lerp(Color3.fromRGB(255,255,255),0.15)},tweenInfoFast) end)
		psBtn.MouseLeave:Connect(function() tween(ps,{BackgroundColor3=presetColor},tweenInfoFast) end)
		local cc=presetColor; local ci=checkInd
		psBtn.MouseButton1Click:Connect(function()
			applyColor(cc,ci)
			tween(parent,{BackgroundColor3=Color3.fromRGB(20,19,30)},tweenInfoFast)
			task.delay(0.12,function() tween(parent,{BackgroundColor3=BG_ROW},tweenInfo) end)
		end)
	end
	local GRID_H=2*(SS+SG)-SG; local INPUT_Y=GRID_H+7
	local div=Instance.new("Frame"); div.Size=UDim2.new(1,0,0,1); div.Position=UDim2.new(0,0,0,INPUT_Y-4)
	div.BackgroundColor3=DIVIDER; div.BorderSizePixel=0; div.ZIndex=51; div.Parent=inner
	local inputBox=Instance.new("TextBox"); inputBox.Size=UDim2.new(1,0,0,28); inputBox.Position=UDim2.new(0,0,0,INPUT_Y+2)
	inputBox.BackgroundColor3=Color3.fromRGB(23,22,34); inputBox.BorderSizePixel=0; inputBox.Text=""
	inputBox.PlaceholderText="#8760DC or 135, 96, 220"; inputBox.PlaceholderColor3=TEXT_MUTED
	inputBox.TextColor3=TEXT_MAIN; inputBox.TextSize=11; inputBox.Font=Enum.Font.Gotham
	inputBox.TextXAlignment=Enum.TextXAlignment.Center; inputBox.ClearTextOnFocus=false; inputBox.ZIndex=52; inputBox.Parent=inner
	corner(inputBox,6)
	local inputStroke=Instance.new("UIStroke"); inputStroke.Color=Color3.fromRGB(42,40,62); inputStroke.Transparency=0; inputStroke.Thickness=1; inputStroke.Parent=inputBox
	inputBox.FocusLost:Connect(function()
		local raw=inputBox.Text:gsub("%s",""); local parsed=nil
		local hex=raw:gsub("#","")
		if #hex==6 then
			local r=tonumber(hex:sub(1,2),16); local g=tonumber(hex:sub(3,4),16); local b=tonumber(hex:sub(5,6),16)
			if r and g and b then parsed=Color3.fromRGB(r,g,b) end
		end
		if not parsed then
			local r,g,b=raw:match("^(%d+),(%d+),(%d+)$")
			if r and g and b then r,g,b=tonumber(r),tonumber(g),tonumber(b); if r<=255 and g<=255 and b<=255 then parsed=Color3.fromRGB(r,g,b) end end
		end
		if parsed then applyColor(parsed,nil); inputBox.Text=""; tween(inputStroke,{Color=Color3.fromRGB(42,40,62)},tweenInfoFast)
		else
			tween(inputStroke,{Color=Color3.fromRGB(180,60,60)},tweenInfoFast)
			task.delay(0.8,function() tween(inputStroke,{Color=Color3.fromRGB(42,40,62)},tweenInfo); inputBox.Text="" end)
		end
	end)
	inputBox:GetPropertyChangedSignal("Text"):Connect(function() tween(inputStroke,{Color=Color3.fromRGB(42,40,62)},tweenInfoFast) end)
	local function positionPopup()
		local ap=swatch.AbsolutePosition; local fp=MainFrame.AbsolutePosition
		popup.Position=UDim2.new(0,ap.X-fp.X-POPUP_W+34,0,ap.Y-fp.Y+42)
	end
	swatchBtn.MouseButton1Click:Connect(function()
		open=not open; positionPopup(); popup.Visible=open
		tween(parent,{BackgroundColor3=open and Color3.fromRGB(18,17,26) or BG_ROW},tweenInfoFast)
	end)
	UserInputService.InputBegan:Connect(function(input)
		if not open then return end
		if input.UserInputType==Enum.UserInputType.MouseButton1 then
			task.defer(function()
				if not popup.Visible then return end
				if inputBox:IsFocused() then return end
				local mp=UserInputService:GetMouseLocation()
				local ap,as=popup.AbsolutePosition,popup.AbsoluteSize
				local inside=mp.X>=ap.X and mp.X<=ap.X+as.X and mp.Y>=ap.Y and mp.Y<=ap.Y+as.Y
				local onS=mp.X>=swatch.AbsolutePosition.X and mp.X<=swatch.AbsolutePosition.X+swatch.AbsoluteSize.X
					and mp.Y>=swatch.AbsolutePosition.Y and mp.Y<=swatch.AbsolutePosition.Y+swatch.AbsoluteSize.Y
				if not inside and not onS then open=false; popup.Visible=false; tween(parent,{BackgroundColor3=BG_ROW},tweenInfoFast) end
			end)
		end
	end)
	return function() return currentColor end
end

local function buildMultiSelect(parent, options, defaults)
	local selected={}
	if defaults then for _,v in ipairs(defaults) do selected[v]=true end end
	local open=false; local ITEM_H=30; local closedH=0; local openH=#options*ITEM_H+8
	local function getLabel()
		local parts={}
		for _,opt in ipairs(options) do if selected[opt] then table.insert(parts,opt) end end
		if #parts==0 then return "None" end
		if #parts>2 then return parts[1]..", +"..(#parts-1) end
		return table.concat(parts,", ")
	end
	local frame=Instance.new("Frame"); frame.Size=UDim2.new(0,165,0,34); frame.Position=UDim2.new(1,-165,0.5,-17)
	frame.BackgroundColor3=BG_INPUT; frame.BorderSizePixel=0; frame.ZIndex=2; frame.Parent=parent; corner(frame,5)
	local label=Instance.new("TextLabel"); label.Size=UDim2.new(1,-30,1,0); label.Position=UDim2.new(0,12,0,0)
	label.BackgroundTransparency=1; label.Text=getLabel(); label.TextColor3=TEXT_MAIN; label.TextSize=12
	label.Font=Enum.Font.Gotham; label.TextXAlignment=Enum.TextXAlignment.Left; label.TextTruncate=Enum.TextTruncate.AtEnd
	label.ZIndex=3; label.Parent=frame
	local chevron=Instance.new("ImageLabel"); chevron.Size=UDim2.new(0,16,0,16); chevron.Position=UDim2.new(1,-24,0.5,-8)
	chevron.BackgroundTransparency=1; chevron.Image=getIcon("expand_more","Material"); chevron.ImageColor3=TEXT_MUTED; chevron.ZIndex=3; chevron.Parent=frame
	local clickBtn=Instance.new("TextButton"); clickBtn.Size=UDim2.new(1,0,1,0); clickBtn.BackgroundTransparency=1
	clickBtn.Text=""; clickBtn.ZIndex=4; clickBtn.Parent=frame
	local listClip=Instance.new("Frame"); listClip.Size=UDim2.new(0,165,0,closedH); listClip.BackgroundTransparency=1
	listClip.BorderSizePixel=0; listClip.ClipsDescendants=true; listClip.ZIndex=20; listClip.Parent=MainFrame
	local listBg=Instance.new("Frame"); listBg.Size=UDim2.new(1,0,0,openH); listBg.BackgroundColor3=Color3.fromRGB(22,21,32)
	listBg.BorderSizePixel=0; listBg.ZIndex=21; listBg.Parent=listClip; corner(listBg,6)
	local ll=Instance.new("UIListLayout"); ll.SortOrder=Enum.SortOrder.LayoutOrder; ll.Padding=UDim.new(0,0); ll.Parent=listBg
	pad(listBg,4,4,0,0)
	local itemBtns={}
	local function refreshItems()
		label.Text=getLabel()
		for _,e in ipairs(itemBtns) do
			local isOn=selected[e.opt]
			tween(e.check,{BackgroundColor3=isOn and ACCENT or BG_INPUT},tweenInfoFast)
			e.lbl.TextColor3=isOn and TEXT_MAIN or TEXT_MUTED
			e.checkMark.Visible=isOn or false
		end
	end
	local function positionList()
		local ap=frame.AbsolutePosition; local fp=MainFrame.AbsolutePosition
		listClip.Position=UDim2.new(0,ap.X-fp.X,0,ap.Y-fp.Y+38)
	end
	local trackConn
	for i,opt in ipairs(options) do
		local item=Instance.new("TextButton"); item.Size=UDim2.new(1,0,0,ITEM_H); item.BackgroundColor3=Color3.fromRGB(22,21,32)
		item.BackgroundTransparency=0; item.Text=""; item.LayoutOrder=i; item.ZIndex=22; item.Parent=listBg; corner(item,4)
		local cf=Instance.new("Frame"); cf.Size=UDim2.new(0,14,0,14); cf.Position=UDim2.new(0,10,0.5,-7)
		cf.BackgroundColor3=selected[opt] and ACCENT or BG_INPUT; cf.BorderSizePixel=0; cf.ZIndex=23; cf.Parent=item; corner(cf,3)
		local cm=Instance.new("ImageLabel"); cm.Size=UDim2.new(0,10,0,10); cm.Position=UDim2.new(0.5,-5,0.5,-5)
		cm.BackgroundTransparency=1; cm.Image=getIcon("check","Material"); cm.ImageColor3=Color3.fromRGB(255,255,255)
		cm.ZIndex=24; cm.Visible=selected[opt] or false; cm.Parent=cf
		local il=Instance.new("TextLabel"); il.Size=UDim2.new(1,-40,1,0); il.Position=UDim2.new(0,32,0,0)
		il.BackgroundTransparency=1; il.Text=opt; il.TextColor3=selected[opt] and TEXT_MAIN or TEXT_MUTED
		il.TextSize=13; il.Font=Enum.Font.Gotham; il.TextXAlignment=Enum.TextXAlignment.Left; il.ZIndex=23; il.Parent=item
		table.insert(itemBtns,{btn=item,lbl=il,check=cf,checkMark=cm,opt=opt})
		item.MouseEnter:Connect(function() tween(item,{BackgroundColor3=Color3.fromRGB(26,25,38)},tweenInfoFast) end)
		item.MouseLeave:Connect(function() tween(item,{BackgroundColor3=Color3.fromRGB(22,21,32)},tweenInfoFast) end)
		item.MouseButton1Click:Connect(function() selected[opt]=not selected[opt]; refreshItems() end)
	end
	clickBtn.MouseButton1Click:Connect(function()
		open=not open
		if open then positionList(); tween(listClip,{Size=UDim2.new(0,165,0,openH)}); tween(chevron,{Rotation=180},tweenInfo)
			tween(frame,{BackgroundColor3=Color3.fromRGB(24,23,34)},tweenInfoFast); trackConn=RunService.RenderStepped:Connect(positionList)
		else tween(listClip,{Size=UDim2.new(0,165,0,closedH)}); tween(chevron,{Rotation=0},tweenInfo)
			tween(frame,{BackgroundColor3=BG_INPUT},tweenInfoFast); if trackConn then trackConn:Disconnect(); trackConn=nil end
		end
	end)
	return function()
		local out={}; for _,opt in ipairs(options) do if selected[opt] then table.insert(out,opt) end end; return out
	end
end

-- ── Row builder ───────────────────────────────────────────────────────────────
-- widgetDef = { type = "toggle"|"slider"|"dropdown"|"keybind"|"input"|"button"|"colorpicker"|"multiselect", ... }

local function buildRow(parent, titleText, descText, order, widgetDef, pageEntry, navEntry, tabName)
	local row = Instance.new("Frame")
	row.Size = UDim2.new(1, 0, 0, 64)
	row.BackgroundColor3 = BG_ROW
	row.BorderSizePixel = 0
	row.LayoutOrder = order
	row.ClipsDescendants = false
	row.Parent = parent
	corner(row, 6)
	pad(row, 0, 0, 18, 18)

	-- Title & desc (pushed right to give room for star on left)
	local title = Instance.new("TextLabel")
	title.Size = UDim2.new(0.5, -10, 0, 20)
	title.Position = UDim2.new(0, 26, 0, 12)
	title.BackgroundTransparency = 1
	title.Text = titleText
	title.TextColor3 = TEXT_MAIN
	title.TextSize = 15
	title.Font = Enum.Font.GothamBold
	title.TextXAlignment = Enum.TextXAlignment.Left
	title.Parent = row

	local desc = Instance.new("TextLabel")
	desc.Size = UDim2.new(0.5, -10, 0, 14)
	desc.Position = UDim2.new(0, 26, 0, 34)
	desc.BackgroundTransparency = 1
	desc.Text = descText
	desc.TextColor3 = TEXT_MUTED
	desc.TextSize = 12
	desc.Font = Enum.Font.Gotham
	desc.TextXAlignment = Enum.TextXAlignment.Left
	desc.Parent = row

	-- ── Star (top-left corner, partially outside row, rotated 45°) ──────────
	local starBtn = Instance.new("ImageButton")
	starBtn.Name = "StarBtn"
	starBtn.Size = UDim2.new(0, 24, 0, 24)
	-- Sit in the top-left corner, slightly overlapping
	starBtn.Position = UDim2.new(0, -10, 0, -10)
	starBtn.BackgroundTransparency = 1
	starBtn.Image = getIcon("star", "Lucide")
	starBtn.ImageColor3 = TEXT_MUTED
	starBtn.Rotation = 45
	starBtn.ZIndex = row.ZIndex + 4
	starBtn.Visible = false
	starBtn.Parent = row

	-- Invisible hover overlay (behind widgets)
	local hoverZone = Instance.new("TextButton")
	hoverZone.Size = UDim2.new(1, 0, 1, 0)
	hoverZone.BackgroundTransparency = 1
	hoverZone.Text = ""
	hoverZone.ZIndex = row.ZIndex + 1
	hoverZone.Parent = row

	hoverZone.MouseEnter:Connect(function()
		starBtn.Visible = true
	end)
	hoverZone.MouseLeave:Connect(function()
		if not favoritedSet[titleText] then
			starBtn.Visible = false
		end
	end)

	-- Build the actual widget on this row
	local getter
	local wt = widgetDef and widgetDef.type or nil
	if wt == "toggle"      then getter = buildToggle(row, widgetDef.default)
	elseif wt == "slider"  then getter = buildSlider(row, widgetDef.min, widgetDef.max, widgetDef.default)
	elseif wt == "dropdown" then getter = buildDropdown(row, widgetDef.options, widgetDef.default)
	elseif wt == "keybind" then getter = buildKeybind(row, widgetDef.default)
	elseif wt == "input"   then getter = buildInput(row, widgetDef.default)
	elseif wt == "button"  then getter = buildButton(row, widgetDef.icon, widgetDef.iconLibrary, widgetDef.callback)
	elseif wt == "colorpicker" then getter = buildColorPicker(row, widgetDef.default)
	elseif wt == "multiselect" then getter = buildMultiSelect(row, widgetDef.options, widgetDef.defaults)
	end

	-- Register for search
	local feat = {
		title    = titleText,
		desc     = descText,
		row      = row,
		widgetDef = widgetDef,
		page     = pageEntry,
		navEntry = navEntry,
		tabName  = tabName,
	}
	table.insert(featureRegistry, feat)

	-- Star click: add/remove from favorites
	starBtn.MouseButton1Click:Connect(function()
		favoritedSet[titleText] = not favoritedSet[titleText]
		local isFav = favoritedSet[titleText]

		if isFav then
			starBtn.ImageColor3 = Color3.fromRGB(255, 210, 60)
			starBtn.Visible = true

			-- Build a live functional row in favScroll
			if favScrollRef then
				local favRow = buildRow(favScrollRef, titleText, descText, #featureRegistry + 1000, widgetDef, nil, nil, nil)
				favRow.Name = "FavRow_" .. titleText
				-- Small "source" badge bottom right
				local badge = Instance.new("TextLabel")
				badge.Size = UDim2.new(0, 0, 0, 14)
				badge.AutomaticSize = Enum.AutomaticSize.X
				badge.Position = UDim2.new(1, -4, 1, -16)
				badge.AnchorPoint = Vector2.new(1, 0)
				badge.BackgroundTransparency = 1
				badge.Text = navEntry and navEntry.name or ""
				badge.TextColor3 = TEXT_MUTED
				badge.TextSize = 9
				badge.Font = Enum.Font.Gotham
				badge.TextXAlignment = Enum.TextXAlignment.Right
				badge.ZIndex = favRow.ZIndex + 3
				badge.Parent = favRow
			end

			if favEmptyLabel then favEmptyLabel.Visible = false end
			showNotif("Favorited", titleText .. " added to Favorites.", "success")
		else
			starBtn.ImageColor3 = TEXT_MUTED
			starBtn.Visible = false

			if favScrollRef then
				local existing = favScrollRef:FindFirstChild("FavRow_" .. titleText)
				if existing then existing:Destroy() end
			end

			-- Show empty label if nothing left
			if favEmptyLabel then
				local hasFav = false
				for _, v in pairs(favoritedSet) do if v then hasFav = true; break end end
				favEmptyLabel.Visible = not hasFav
			end
			showNotif("Removed", titleText .. " removed from Favorites.", "warning")
		end
	end)

	return row, getter
end

