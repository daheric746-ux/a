local function setActiveNav(entry)
	if activeNavBtn then
		tween(activeNavBtn.btn, { BackgroundColor3 = BG_SIDEBAR })
		activeNavBtn.btn.BackgroundTransparency = 1
		tween(activeNavBtn.ico, { ImageColor3 = TEXT_MUTED })
		tween(activeNavBtn.lbl, { TextColor3 = TEXT_MUTED })
	end
	activeNavBtn = entry
	activeNavBtn.btn.BackgroundTransparency = 0
	tween(activeNavBtn.btn, { BackgroundColor3 = Color3.fromRGB(16, 15, 24) })
	tween(activeNavBtn.ico, { ImageColor3 = ACCENT })
	tween(activeNavBtn.lbl, { TextColor3 = TEXT_MAIN })

	searchResultsClip.Visible = false
	for _, p in ipairs(pages) do p.clip.Visible = false end

	HeaderTitle.Text    = entry.title
	HeaderSubtitle.Text = entry.subtitle

	local hasTabs = entry.tabs ~= nil
	TabBar.Visible      = hasTabs
	TabsDivider.Visible = hasTabs

	if entry.page then entry.page.clip.Visible = true end
end

local function setTab(name)
	activeTabName = name
	for _, def in ipairs(activeTabDefs) do
		local isActive = def.name == name
		tween(def.btn, { TextColor3 = isActive and TEXT_MAIN or TEXT_MUTED })
		if isActive then
			tween(TabIndicator, {
				Position = UDim2.new(0, def.x, 1, -2),
				Size     = UDim2.new(0, def.w, 0, 2),
			}, TweenInfo.new(0.22, Enum.EasingStyle.Quint, Enum.EasingDirection.Out))
			if def.clip then def.clip.Visible = true end
		else
			if def.clip then def.clip.Visible = false end
		end
	end
end

local function buildToggle(parent, defaultOn)
	local state = defaultOn or false
	local track = Instance.new("Frame")
	track.Size = UDim2.new(0, 44, 0, 24)
	track.Position = UDim2.new(1, -44, 0.5, -12)
	track.BackgroundColor3 = state and ACCENT or BG_INPUT
	track.BorderSizePixel = 0
	track.ZIndex = 3
	track.Parent = parent
	corner(track, 12)

	local ball = Instance.new("Frame")
	ball.Size = UDim2.new(0, 16, 0, 16)
	ball.Position = state and UDim2.new(1, -20, 0.5, -8) or UDim2.new(0, 4, 0.5, -8)
	ball.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	ball.BorderSizePixel = 0
	ball.ZIndex = 4
	ball.Parent = track
	corner(ball, 8)

	local hitBtn = Instance.new("TextButton")
	hitBtn.Size = UDim2.new(1, 0, 1, 0)
	hitBtn.BackgroundTransparency = 1
	hitBtn.Text = ""
	hitBtn.ZIndex = 5
	hitBtn.Parent = track

	local function doToggle()
		state = not state
		tween(track, { BackgroundColor3 = state and ACCENT or BG_INPUT })
		tween(ball, { Position = state and UDim2.new(1, -20, 0.5, -8) or UDim2.new(0, 4, 0.5, -8) }, tweenInfoSpring)
		tween(parent, { BackgroundColor3 = Color3.fromRGB(20, 19, 30) }, tweenInfoFast)
		task.delay(0.12, function() tween(parent, { BackgroundColor3 = BG_ROW }, tweenInfo) end)
	end
	hitBtn.MouseButton1Click:Connect(doToggle)
	hitBtn.MouseEnter:Connect(function() tween(parent, { BackgroundColor3 = Color3.fromRGB(18, 17, 26) }, tweenInfoFast) end)
	hitBtn.MouseLeave:Connect(function() tween(parent, { BackgroundColor3 = BG_ROW }, tweenInfoFast) end)
	return (function() return state end), doToggle
end

-- ────────────────────────────────────────────────────────────────────────────
-- SLIDER — draggable + click the number to type an exact value
-- ────────────────────────────────────────────────────────────────────────────
local function buildSlider(parent, minVal, maxVal, defaultVal)
	local allowDecimals = (math.floor(minVal) ~= minVal) or (math.floor(maxVal) ~= maxVal)
		or (defaultVal and math.floor(defaultVal) ~= defaultVal)

	local function roundValue(v)
		if allowDecimals then
			return math.clamp(math.floor(v * 10 + 0.5) / 10, minVal, maxVal)
		else
			return math.clamp(math.round(v), minVal, maxVal)
		end
	end

	local value = roundValue(defaultVal or minVal)

	-- Container so we can position things cleanly without fighting UIPadding
	local container = Instance.new("Frame")
	container.Size = UDim2.new(0, 210, 0, 40)
	container.Position = UDim2.new(1, -210, 0.5, -20)
	container.BackgroundTransparency = 1
	container.BorderSizePixel = 0
	container.ZIndex = 3
	container.Parent = parent

local valBox = Instance.new("TextBox")
	valBox.Size = UDim2.new(0, 46, 0, 16)
	valBox.ClearTextOnFocus = false
	valBox.Position = UDim2.new(0, 0, 0.5, -8)
	valBox.BackgroundTransparency = 1
	valBox.BorderSizePixel = 0
	valBox.Text = tostring(value)
	valBox.TextColor3 = ACCENT
	valBox.TextSize = 13
	valBox.Font = Enum.Font.GothamBold
	valBox.TextXAlignment = Enum.TextXAlignment.Right
	valBox.ZIndex = 4
	valBox.Parent = container

	-- Track (right side of container)
	local track = Instance.new("Frame")
	track.Size = UDim2.new(0, 150, 0, 4)
	track.Position = UDim2.new(0, 56, 0.5, -2)
	track.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
	track.BorderSizePixel = 0
	track.ZIndex = 3
	track.Parent = container
	corner(track, 2)

	local fill = Instance.new("Frame")
	fill.Size = UDim2.new((value - minVal) / (maxVal - minVal), 0, 1, 0)
	fill.BackgroundColor3 = ACCENT
	fill.BorderSizePixel = 0
	fill.ZIndex = 4
	fill.Parent = track
	corner(fill, 2)

	local thumb = Instance.new("Frame")
	thumb.Size = UDim2.new(0, 12, 0, 12)
	thumb.Position = UDim2.new((value - minVal) / (maxVal - minVal), -6, 0.5, -6)
	thumb.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	thumb.BorderSizePixel = 0
	thumb.ZIndex = 5
	thumb.Parent = track
	corner(thumb, 6)

	local function applyValue(v)
		value = v
		local pct = (value - minVal) / (maxVal - minVal)
		fill.Size = UDim2.new(pct, 0, 1, 0)
		thumb.Position = UDim2.new(pct, -6, 0.5, -6)
		valBox.Text = tostring(value)
	end

	-- Drag hitbox over the track
	local dragging = false
	local hitbox = Instance.new("TextButton")
	hitbox.Size = UDim2.new(1, 12, 1, 14)
	hitbox.Position = UDim2.new(0, -6, 0.5, -7)
	hitbox.BackgroundTransparency = 1
	hitbox.Text = ""
	hitbox.ZIndex = 6
	hitbox.Parent = track

	local function updateFromX(inputX)
		local rel = math.clamp((inputX - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
		applyValue(roundValue(minVal + rel * (maxVal - minVal)))
	end

	hitbox.MouseButton1Down:Connect(function()
		dragging = true
		updateFromX(UserInputService:GetMouseLocation().X)
	end)
	UserInputService.InputChanged:Connect(function(input)
		if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
			updateFromX(input.Position.X)
		end
	end)
	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = false
		end
	end)
valBox.FocusLost:Connect(function()
		local parsed = tonumber(valBox.Text)
		if parsed then
			applyValue(roundValue(parsed))
		else
			valBox.Text = tostring(value)
		end
	end)

	return function() return value end
end

