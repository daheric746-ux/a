function SpareStackLib:ShowSettings()
	self.SettingsMode = true

	for _, card in pairs(self.AllCards) do
		card.Visible = false
	end

	for _, card in pairs(self.SettingsCards) do
		card.Visible = true
	end

	for _, tab in pairs(self.Tabs) do
		tab.Frame.BackgroundTransparency = 1
	end
end

