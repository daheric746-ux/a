local function beautifyKey(raw)
	if not raw then return "[ -- ]" end
	if KEY_NAMES[raw] then return "[" .. KEY_NAMES[raw] .. "]" end
	local fnum = raw:match("^F(%d+)$")
	if fnum then return "[F" .. fnum .. "]" end
	return "[" .. raw .. "]"
end

