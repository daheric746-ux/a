local CONFIG_KEY = "sparestack_config"

local function saveConfig(registry)
	local data = {}
	for key, entry in pairs(registry) do
		if entry.getter then
			local ok, val = pcall(entry.getter)
			if not ok then continue end
			local t = type(val)
			if t == "boolean" or t == "number" or t == "string" then
				data[key] = { type = t, value = val }
			elseif t == "userdata" then
				local tv = typeof(val)
				if tv == "EnumItem" then
					data[key] = { type = "keycode", name = val.Name }
				elseif tv == "Color3" then
					data[key] = { type = "color", r = val.R, g = val.G, b = val.B }
				end
			elseif t == "table" then
				data[key] = { type = "table", value = val }
			end
		end
	end
	pcall(writefile, CONFIG_KEY .. ".json", HttpService:JSONEncode(data))
end

local function loadConfig()
	local ok, raw = pcall(readfile, CONFIG_KEY .. ".json")
	if not ok or not raw then return {} end
	local ok2, data = pcall(HttpService.JSONDecode, HttpService, raw)
	return (ok2 and data) or {}
end

