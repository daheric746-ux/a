-- Attaches a hover tooltip to any GuiObject. tip = string text.
function SpareStackLib:_attachTooltip(element, tip)
	if not tip or tip == "" then return end

	element.MouseEnter:Connect(function()
		-- Create tooltip frame on first use
		if not self._tooltip or not self._tooltip.Parent then
			local t = Instance.new("Frame")
			t.Name = "_Tooltip"
			t.Parent = self.Gui
			t.BackgroundColor3 = Color3.fromRGB(18, 18, 26)
			t.BorderSizePixel = 0
			t.ZIndex = 600
			t.AutomaticSize = Enum.AutomaticSize.XY
			t.Size = UDim2.new(0, 0, 0, 0)

			local tc = Instance.new("UICorner")
			tc.CornerRadius = UDim.new(0, 5)
			tc.Parent = t

			local ts = Instance.new("UIStroke")
			ts.Color = Color3.fromRGB(40, 40, 58)
			ts.Thickness = 1
			ts.Parent = t

			local tp = Instance.new("UIPadding")
			tp.PaddingLeft  = UDim.new(0, 8)
			tp.PaddingRight = UDim.new(0, 8)
			tp.PaddingTop   = UDim.new(0, 5)
			tp.PaddingBottom = UDim.new(0, 5)
			tp.Parent = t

			local tl = Instance.new("TextLabel")
			tl.Name = "Text"
			tl.Parent = t
			tl.BackgroundTransparency = 1
			tl.Font = Enum.Font.Gotham
			tl.TextSize = 12
			tl.TextColor3 = Color3.fromRGB(200, 200, 215)
			tl.TextXAlignment = Enum.TextXAlignment.Left
			tl.AutomaticSize = Enum.AutomaticSize.XY
			tl.ZIndex = 601

			self._tooltip = t
		end

		self._tooltip:FindFirstChild("Text").Text = tip
		self._tooltip.Visible = true

		-- Follow mouse
		if self._tooltipMoveConn then self._tooltipMoveConn:Disconnect() end
		self._tooltipMoveConn = UIS.InputChanged:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseMovement then
				local mx = input.Position.X + 14
				local my = input.Position.Y + 14
				self._tooltip.Position = UDim2.new(0, mx, 0, my)
			end
		end)

		-- Initial position
		local mp = UIS:GetMouseLocation()
		self._tooltip.Position = UDim2.new(0, mp.X + 14, 0, mp.Y + 14)
	end)

	element.MouseLeave:Connect(function()
		if self._tooltip then
			self._tooltip.Visible = false
		end
		if self._tooltipMoveConn then
			self._tooltipMoveConn:Disconnect()
			self._tooltipMoveConn = nil
		end
	end)
end

