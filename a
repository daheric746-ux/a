	label.Font = Enum.Font.Gotham
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.TextTruncate = Enum.TextTruncate.AtEnd
	label.ZIndex = 4
	label.Parent = frame

	local chevron = Instance.new("ImageLabel")
	chevron.Size = UDim2.new(0, 16, 0, 16)
	chevron.Position = UDim2.new(1, -24, 0.5, -8)
	chevron.BackgroundTransparency = 1
	chevron.Image = getIcon("expand_more", "Material")
	chevron.ImageColor3 = TEXT_MUTED
	chevron.ZIndex = 4
	chevron.Parent = frame

	local clickBtn = Instance.new("TextButton")
	clickBtn.Size = UDim2.new(1, 0, 1, 0)
	clickBtn.BackgroundTransparency = 1
	clickBtn.Text = ""
	clickBtn.ZIndex = 5
	clickBtn.Parent = frame

	local listClip = Instance.new("Frame")
	listClip.Size = UDim2.new(0, 165, 0, closedH)
	listClip.BackgroundTransparency = 1
	listClip.BorderSizePixel = 0
	listClip.ClipsDescendants = true
	listClip.ZIndex = 20
	listClip.Parent = MainFrame

	local listBg = Instance.new("Frame")
	listBg.Size = UDim2.new(1, 0, 0, openH)
	listBg.BackgroundColor3 = Color3.fromRGB(22, 21, 32)
	listBg.BorderSizePixel = 0
	listBg.ZIndex = 21
	listBg.Parent = listClip
	corner(listBg, 6)

	local ll = Instance.new("UIListLayout")
	ll.SortOrder = Enum.SortOrder.LayoutOrder
	ll.Padding = UDim.new(0, 0)
	ll.Parent = listBg
	pad(listBg, 4, 4, 0, 0)

	local itemBtns = {}
	local function refreshItems()
		label.Text = getLabel()
		for _, e in ipairs(itemBtns) do
			local isOn = selected[e.opt]
			tween(e.check, { BackgroundColor3 = isOn and ACCENT or BG_INPUT }, tweenInfoFast)
			e.lbl.TextColor3 = isOn and TEXT_MAIN or TEXT_MUTED
			e.checkMark.Visible = isOn or false
		end
	end

	local function positionList()
		local ap = frame.AbsolutePosition
		local fp = MainFrame.AbsolutePosition
		listClip.Position = UDim2.new(0, ap.X - fp.X, 0, ap.Y - fp.Y + 38)
	end

	local trackConn
	for i, opt in ipairs(options) do
		local item = Instance.new("TextButton")
		item.Size = UDim2.new(1, 0, 0, ITEM_H)
		item.BackgroundColor3 = Color3.fromRGB(22, 21, 32)
		item.BackgroundTransparency = 0
		item.Text = ""
		item.LayoutOrder = i
		item.ZIndex = 22
		item.Parent = listBg
		corner(item, 4)

		local cf = Instance.new("Frame")
		cf.Size = UDim2.new(0, 14, 0, 14)
		cf.Position = UDim2.new(0, 10, 0.5, -7)
		cf.BackgroundColor3 = selected[opt] and ACCENT or BG_INPUT
		cf.BorderSizePixel = 0
		cf.ZIndex = 23
		cf.Parent = item
		corner(cf, 3)

		local cm = Instance.new("ImageLabel")
		cm.Size = UDim2.new(0, 10, 0, 10)
		cm.Position = UDim2.new(0.5, -5, 0.5, -5)
		cm.BackgroundTransparency = 1
		cm.Image = getIcon("check", "Material")
		cm.ImageColor3 = Color3.fromRGB(255, 255, 255)
		cm.ZIndex = 24
		cm.Visible = selected[opt] or false
		cm.Parent = cf

		local il = Instance.new("TextLabel")
		il.Size = UDim2.new(1, -40, 1, 0)
		il.Position = UDim2.new(0, 32, 0, 0)
		il.BackgroundTransparency = 1
		il.Text = opt
		il.TextColor3 = selected[opt] and TEXT_MAIN or TEXT_MUTED
		il.TextSize = 13
		il.Font = Enum.Font.Gotham
		il.TextXAlignment = Enum.TextXAlignment.Left
		il.ZIndex = 23
		il.Parent = item

		table.insert(itemBtns, { btn = item, lbl = il, check = cf, checkMark = cm, opt = opt })
		item.MouseEnter:Connect(function() tween(item, { BackgroundColor3 = Color3.fromRGB(26, 25, 38) }, tweenInfoFast) end)
		item.MouseLeave:Connect(function() tween(item, { BackgroundColor3 = Color3.fromRGB(22, 21, 32) }, tweenInfoFast) end)
		item.MouseButton1Click:Connect(function() selected[opt] = not selected[opt]; refreshItems() end)
	end

	clickBtn.MouseButton1Click:Connect(function()
		open = not open
		if open then
			positionList()
			tween(listClip, { Size = UDim2.new(0, 165, 0, openH) })
			tween(chevron, { Rotation = 180 }, tweenInfo)
			tween(frame, { BackgroundColor3 = Color3.fromRGB(24, 23, 34) }, tweenInfoFast)
			trackConn = RunService.RenderStepped:Connect(positionList)
		else
			tween(listClip, { Size = UDim2.new(0, 165, 0, closedH) })
			tween(chevron, { Rotation = 0 }, tweenInfo)
			tween(frame, { BackgroundColor3 = BG_INPUT }, tweenInfoFast)
			if trackConn then trackConn:Disconnect(); trackConn = nil end
		end
	end)

	return function()
		local out = {}
		for _, opt in ipairs(options) do if selected[opt] then table.insert(out, opt) end end
		return out
	end
end

local function buildRow(parent, titleText, descText, order, widgetDef, pageEntry, navEntry, tabName)
	local row = Instance.new("Frame")
	row.Size = UDim2.new(1, 0, 0, 64)
	row.BackgroundColor3 = BG_ROW
	row.BorderSizePixel = 0
	row.LayoutOrder = order
	row.ClipsDescendants = false
	row.Parent = parent
	corner(row, 6)
	pad(row, 0, 0, 18, 18)

	local title = Instance.new("TextLabel")
	title.Size = UDim2.new(0.5, -10, 0, 20)
	title.Position = UDim2.new(0, 0, 0, 12)
	title.BackgroundTransparency = 1
	title.Text = tostring(titleText)
	title.TextColor3 = TEXT_MAIN
	title.TextSize = 15
	title.Font = Enum.Font.GothamBold
	title.TextXAlignment = Enum.TextXAlignment.Left
	title.ZIndex = 2
	title.Parent = row

	local desc = Instance.new("TextLabel")
	desc.Size = UDim2.new(0.5, -10, 0, 14)
	desc.Position = UDim2.new(0, 0, 0, 34)
	desc.BackgroundTransparency = 1
	desc.Text = tostring(descText)
	desc.TextColor3 = TEXT_MUTED
	desc.TextSize = 12
	desc.Font = Enum.Font.Gotham
	desc.TextXAlignment = Enum.TextXAlignment.Left
	desc.ZIndex = 2
	desc.Parent = row

	-- hoverZone only covers the LEFT half (text area) so widgets on the right remain clickable
	local hoverZone = Instance.new("TextButton")
	hoverZone.Size = UDim2.new(0.5, 0, 1, 0)
	hoverZone.BackgroundTransparency = 1
	hoverZone.Text = ""
	hoverZone.ZIndex = 2
	hoverZone.Parent = row

	hoverZone.MouseEnter:Connect(function() tween(row, { BackgroundColor3 = Color3.fromRGB(18, 17, 26) }, tweenInfoFast) end)
	hoverZone.MouseLeave:Connect(function() tween(row, { BackgroundColor3 = BG_ROW }, tweenInfoFast) end)

	local getter
	local toggleFn
	local wt = widgetDef and widgetDef.type or nil
	if wt == "toggle"        then getter, toggleFn = buildToggle(row, widgetDef.default)
	elseif wt == "slider"    then getter = buildSlider(row, widgetDef.min, widgetDef.max, widgetDef.default)
	elseif wt == "dropdown"  then getter = buildDropdown(row, widgetDef.options, widgetDef.default)
	elseif wt == "keybind"   then getter = buildKeybind(row, widgetDef.default)
	elseif wt == "input"     then getter = buildInput(row, widgetDef.default)
	elseif wt == "button"    then getter = buildButton(row, widgetDef.icon, widgetDef.iconLibrary, widgetDef.callback)
	elseif wt == "colorpicker"  then getter = buildColorPicker(row, widgetDef.default)
	elseif wt == "multiselect"  then getter = buildMultiSelect(row, widgetDef.options, widgetDef.defaults)
	end

	-- For toggle rows, clicking anywhere on the card flips the toggle (the
	-- toggle button itself still works since it sits at a higher ZIndex).
	if wt == "toggle" and toggleFn then
		hoverZone.Size = UDim2.new(1, 0, 1, 0)
		hoverZone.MouseButton1Click:Connect(toggleFn)
	end

	local feat = {
		title    = tostring(titleText),
		desc     = tostring(descText),
		row      = row,
		widgetDef = widgetDef,
		page     = pageEntry,
		navEntry = navEntry,
		tabName  = tabName,
	}
	table.insert(featureRegistry, feat)

	return row, getter
end

local searchActive = false
local searchResultFrames = {}

local function clearSearchResults()
	for _, f in ipairs(searchResultFrames) do f:Destroy() end
	searchResultFrames = {}
end

local function showSearchResults(query)
	clearSearchResults()
	local q = query:lower()
	local count = 0
	for _, feat in ipairs(featureRegistry) do
		if feat.title:lower():find(q, 1, true) or feat.desc:lower():find(q, 1, true) then
			count += 1
			local shell = Instance.new("Frame")
			shell.Size = UDim2.new(1, 0, 0, 64)
			shell.BackgroundColor3 = BG_ROW
			shell.BorderSizePixel = 0
			shell.LayoutOrder = count
			shell.Parent = searchResultsScroll
			corner(shell, 6)
			pad(shell, 0, 0, 18, 18)
			table.insert(searchResultFrames, shell)

			local tl = Instance.new("TextLabel")
			tl.Size = UDim2.new(0.55, 0, 0, 20)
			tl.Position = UDim2.new(0, 0, 0, 12)
			tl.BackgroundTransparency = 1
			tl.Text = feat.title
			tl.TextColor3 = TEXT_MAIN
			tl.TextSize = 15
			tl.Font = Enum.Font.GothamBold
			tl.TextXAlignment = Enum.TextXAlignment.Left
			tl.Parent = shell

			local dl = Instance.new("TextLabel")
			dl.Size = UDim2.new(0.55, 0, 0, 14)
			dl.Position = UDim2.new(0, 0, 0, 34)
			dl.BackgroundTransparency = 1
			dl.Text = feat.desc
			dl.TextColor3 = TEXT_MUTED
			dl.TextSize = 12
			dl.Font = Enum.Font.Gotham
			dl.TextXAlignment = Enum.TextXAlignment.Left
			dl.Parent = shell

			if feat.navEntry then
				local badge = Instance.new("TextLabel")
				badge.Size = UDim2.new(0, 0, 0, 18)
				badge.AutomaticSize = Enum.AutomaticSize.X
				badge.Position = UDim2.new(1, -68, 0.5, -9)
				badge.BackgroundColor3 = Color3.fromRGB(22, 20, 36)
				badge.BorderSizePixel = 0
				badge.Text = feat.navEntry.name
				badge.TextColor3 = TEXT_MUTED
				badge.TextSize = 10
				badge.Font = Enum.Font.GothamBold
				badge.ZIndex = 2
				badge.Parent = shell
				corner(badge, 3)
				pad(badge, 0, 0, 6, 6)
			end

			local goBtn = Instance.new("TextButton")
			goBtn.Size = UDim2.new(0, 52, 0, 22)
			goBtn.Position = UDim2.new(1, -8, 0.5, -11)
			goBtn.AnchorPoint = Vector2.new(1, 0.5)
			goBtn.BackgroundColor3 = Color3.fromRGB(22, 20, 36)
			goBtn.BorderSizePixel = 0
			goBtn.Text = "Go to"
			goBtn.TextColor3 = ACCENT
			goBtn.TextSize = 11
			goBtn.Font = Enum.Font.GothamBold
			goBtn.ZIndex = 2
			goBtn.Parent = shell
			corner(goBtn, 4)

			goBtn.MouseEnter:Connect(function() tween(goBtn, { BackgroundColor3 = Color3.fromRGB(30, 26, 50) }, tweenInfoFast) end)
			goBtn.MouseLeave:Connect(function() tween(goBtn, { BackgroundColor3 = Color3.fromRGB(22, 20, 36) }, tweenInfoFast) end)

			local capturedFeat = feat
			goBtn.MouseButton1Click:Connect(function()
				SearchInput.Text = ""
				setActiveNav(capturedFeat.navEntry)
				if capturedFeat.tabName then setTab(capturedFeat.tabName) end
			end)
		end
	end

	if count == 0 then
		local noResult = Instance.new("TextLabel")
		noResult.Size = UDim2.new(1, 0, 0, 40)
		noResult.BackgroundTransparency = 1
		noResult.Text = 'No features match "' .. query .. '"'
		noResult.TextColor3 = TEXT_MUTED
		noResult.TextSize = 12
		noResult.Font = Enum.Font.Gotham
		noResult.TextXAlignment = Enum.TextXAlignment.Center
		noResult.LayoutOrder = 1
		noResult.Parent = searchResultsScroll
		table.insert(searchResultFrames, noResult)
	end
end

SearchInput:GetPropertyChangedSignal("Text"):Connect(function()
	local q = SearchInput.Text
	if q == "" then
		if searchActive then
			searchActive = false
			searchResultsClip.Visible = false
			clearSearchResults()
			if activeNavBtn and activeNavBtn.page then activeNavBtn.page.clip.Visible = true end
			HeaderTitle.Text    = activeNavBtn and activeNavBtn.title    or ""
			HeaderSubtitle.Text = activeNavBtn and activeNavBtn.subtitle or ""
			TabBar.Visible      = activeNavBtn and (activeNavBtn.tabs ~= nil) or false
			TabsDivider.Visible = TabBar.Visible
		end
		for _, entry in ipairs(navButtons) do entry.btn.Visible = true end
		return
	end
	if not searchActive then
		searchActive = true
		for _, p in ipairs(pages) do p.clip.Visible = false end
		TabBar.Visible = false
		TabsDivider.Visible = false
	end
	HeaderTitle.Text    = "Search Results"
	HeaderSubtitle.Text = 'Showing results for "' .. q .. '"'
	searchResultsClip.Visible = true
	showSearchResults(q)
	local ql = q:lower()
	for _, entry in ipairs(navButtons) do
		entry.btn.Visible = entry.name:lower():find(ql, 1, true) ~= nil
	end
end)

