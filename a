		config = config or {}
		local cur = config.default or 45
		local card, valLabel = createCard({label = config.label or "Angle", value = tostring(cur), width=100, height=100, order=config.order})

		local w = Instance.new("Frame")
		w.Size = UDim2.new(0,34,0,73)
		w.Position = UDim2.new(0,-42,0.5,0)
		w.AnchorPoint = Vector2.new(0,0.5)
		w.BackgroundTransparency = 1
		w.Parent = card

		local plus = Instance.new("TextButton")
		plus.Size = UDim2.new(0,34,0,34)
		plus.Text = "+"
		plus.BackgroundColor3 = C.ElemBg
		plus.TextColor3 = C.White
		plus.Font = Enum.Font.GothamBold
		plus.Parent = w
		Instance.new("UICorner", plus)
		Instance.new("UIStroke", plus).Color = C.Accent

		local minus = plus:Clone()
		minus.Text = "−"
		minus.Position = UDim2.new(0,0,0,39)
		minus.Parent = w

		plus.MouseButton1Click:Connect(function()
			cur = math.clamp(cur + (config.step or 1), config.min or 0, config.max or 360)
			valLabel.Text = tostring(cur)
			if config.onChange then config.onChange(cur) end
		end)
		minus.MouseButton1Click:Connect(function()
			cur = math.clamp(cur - (config.step or 1), config.min or 0, config.max or 360)
			valLabel.Text = tostring(cur)
			if config.onChange then config.onChange(cur) end
		end)

		table.insert(allAdjWrappers, {wrapper=w, plus=plus, minus=minus})
		return card
	end

	local function moveHolder(dir)
		currentDirection = dir
		local vert = (dir == "left" or dir == "right")
		Layout.FillDirection = vert and Enum.FillDirection.Vertical or Enum.FillDirection.Horizontal

		local pos = {
			top    = UDim2.new(0.5,0,0,20),
			bottom = UDim2.new(0.5,0,1,-130),
			left   = UDim2.new(0,20,0.5,0),
			right  = UDim2.new(1,-20,0.5,0),
		}
		Holder:TweenPosition(pos[dir], "Out", "Quint", 0.45, true)
		Holder.AnchorPoint = vert and Vector2.new(0.5,0.5) or Vector2.new(0.5,0)

		for _, e in ipairs(allAdjWrappers) do
			local ww = e.wrapper
			if vert then
				ww.Position = UDim2.new(0.5,0,0,-42)
				ww.AnchorPoint = Vector2.new(0.5,1)
				e.plus.Position = UDim2.new(0,0,0,0)
				e.minus.Position = UDim2.new(0,39,0,0)
			else
				ww.Position = UDim2.new(0,-42,0.5,0)
				ww.AnchorPoint = Vector2.new(0,0.5)
				e.plus.Position = UDim2.new(0,0,0,0)
				e.minus.Position = UDim2.new(0,0,0,39)
			end
		end
	end

	local api = {}
	function api.AddAngle(label, default, minv, maxv, step, callback)
		return createAdjustableCard({label=label, default=default, min=minv, max=maxv, step=step, onChange=callback})
	end
	function api.AddMode(modes, defaultIdx, callback)
		local idx = defaultIdx or 1
		local card, vlabel = createCard({label="Mode", value=modes[idx]})
		local b = Instance.new("TextButton")
		b.Size = UDim2.new(1,0,1,0)
		b.BackgroundTransparency = 1
		b.Text = ""
		b.Parent = card
		b.MouseButton1Click:Connect(function()
			idx = (idx % #modes) + 1
			vlabel.Text = modes[idx]
			if callback then callback(modes[idx]) end
		end)
		return card
	end
	function api.AddStatic(label, value)
		return createCard({label=label, value=value})
	end
	function api.MoveTo(pos)
		moveHolder(pos)
	end

	local cp = Instance.new("Frame")
	cp.Size = UDim2.new(0,150,0,150)
	cp.Position = UDim2.new(0.5,0,0.5,0)
	cp.AnchorPoint = Vector2.new(0.5,0.5)
	cp.BackgroundTransparency = 1
	cp.Parent = ScreenGui

	local btns = {{"↑","top",53,0},{"←","left",0,53},{"+",nil,53,53},{"→","right",106,53},{"↓","bottom",53,106}}
	for _,v in ipairs(btns) do
		local b = Instance.new("TextButton")
		b.Size = UDim2.new(0,44,0,44)
		b.Position = UDim2.new(0,v[3],0,v[4])
		b.BackgroundColor3 = C.ElemBg
		b.Text = v[1]
		b.TextColor3 = C.TextMain
		b.Font = Enum.Font.GothamBold
		b.TextScaled = true
		b.Parent = cp
		Instance.new("UICorner", b)
		Instance.new("UIStroke", b).Color = C.Accent
		if v[2] then
			b.MouseButton1Click:Connect(function() moveHolder(v[2]) end)
		end
	end

	return api
end

return Nova
