-- AddRadioGroup  – segmented control, pick one
-- ─────────────────────────────────────────────
function SpareStackLib:AddRadioGroup(parent, name, options, default, callback, tooltip)
	callback = callback or function() end
	options = options or {}
	default = default or options[1]

	local RGFrame = Instance.new("Frame")
	RGFrame.Name = "RadioGroup_" .. name
	RGFrame.Parent = parent
	RGFrame.BackgroundTransparency = 1
	RGFrame.Size = UDim2.new(1, 0, 0, 58)

	local TitleLabel = Instance.new("TextLabel")
	TitleLabel.Parent = RGFrame
	TitleLabel.BackgroundTransparency = 1
	TitleLabel.Size = UDim2.new(1, 0, 0, 18)
	TitleLabel.Font = Enum.Font.GothamBold
	TitleLabel.Text = name
	TitleLabel.TextColor3 = Color3.fromRGB(200, 200, 220)
	TitleLabel.TextSize = 12
	TitleLabel.TextXAlignment = Enum.TextXAlignment.Left

	local ButtonsRow = Instance.new("Frame")
	ButtonsRow.Parent = RGFrame
	ButtonsRow.BackgroundTransparency = 1
	ButtonsRow.Position = UDim2.new(0, 0, 0, 22)
	ButtonsRow.Size = UDim2.new(1, 0, 0, 32)

	local ButtonsLayout = Instance.new("UIListLayout")
	ButtonsLayout.Parent = ButtonsRow
	ButtonsLayout.FillDirection = Enum.FillDirection.Horizontal
	ButtonsLayout.SortOrder = Enum.SortOrder.LayoutOrder
	ButtonsLayout.Padding = UDim.new(0, 4)

	local selectedValue = default
	local btnWidth = math.max(60, math.floor((320 - (#options - 1) * 4) / #options))
	local tweenInfo = TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
	local buttons = {}

	for i, optText in ipairs(options) do
		local Btn = Instance.new("TextButton")
		Btn.Parent = ButtonsRow
		Btn.BackgroundColor3 = (optText == default) and Color3.fromRGB(51,105,255) or Color3.fromRGB(22,22,30)
		Btn.BorderSizePixel = 0
		Btn.Size = UDim2.new(0, btnWidth, 1, 0)
		Btn.Font = Enum.Font.GothamBold
		Btn.Text = optText
		Btn.TextColor3 = Color3.fromRGB(255,255,255)
		Btn.TextSize = 12
		Btn.LayoutOrder = i
		local BC = Instance.new("UICorner"); BC.CornerRadius = UDim.new(0,5); BC.Parent = Btn

		Btn.MouseButton1Click:Connect(function()
			selectedValue = optText
			for opt, btn in pairs(buttons) do
				TweenService:Create(btn, tweenInfo, {
					BackgroundColor3 = (opt == optText) and Color3.fromRGB(51,105,255) or Color3.fromRGB(22,22,30),
				}):Play()
			end
			pcall(function() callback(selectedValue) end)
		end)

		buttons[optText] = Btn
	end

	local rgData = {
		Type = "RadioGroup", Name = name, Element = RGFrame,
		GetValue = function() return selectedValue end,
		SetValue = function(val)
			selectedValue = val
			for opt, btn in pairs(buttons) do
				btn.BackgroundColor3 = (opt == val) and Color3.fromRGB(51,105,255) or Color3.fromRGB(22,22,30)
			end
		end,
		SetLabel = function(newName) TitleLabel.Text = newName end,
	}
	local configKey = name; local suffix = 2
	while self.ConfigData[configKey] do configKey = name .. "_" .. suffix; suffix = suffix + 1 end
	self.ConfigData[configKey] = rgData
	self:_attachTooltip(RGFrame, tooltip)
	return rgData
end

return SpareStackLib
