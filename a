			Popup.Position = UDim2.new(0, math.clamp(mousePos.X - 110, 8, 1000), 0, math.clamp(mousePos.Y, 8, 700))
			Popup.Size = UDim2.new(0, 220, 0, 80)
			Popup.ZIndex = 500
			Popup.Active = true
			Popup.Draggable = false

			local PopupCorner = Instance.new("UICorner")
			PopupCorner.CornerRadius = UDim.new(0, 8)
			PopupCorner.Parent = Popup

