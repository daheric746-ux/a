		local vp = cam and cam.ViewportSize or Vector2.new(1280, 720)
		local size = CollapsedTab.AbsoluteSize
		CollapsedTab.Position = UDim2.fromOffset(
			math.clamp(startAbs.X + delta.X, 8, math.max(8, vp.X - size.X - 8)),
			math.clamp(startAbs.Y + delta.Y, 8, math.max(8, vp.Y - size.Y - 8))
		)
	end)
	onPointerEnd(function(input)
		if not dragging then return end
		if activePointer.UserInputType == Enum.UserInputType.Touch and input ~= activePointer then return end
		dragging = false
		activePointer = nil
		if not moved then setWindowExpanded(true) end
	end)
end

