--[[
	Nova UI Library v2.0
	A clean, composable UI library for Roblox.

	QUICK START:
		local Nova = loadstring(...)()  -- or require(...)
		local window = Nova.new({title="My Menu", pages=...})
		window:Show()

	FULL USAGE:
		local Nova = require(path.to.NovaLib)

		local window = Nova.new({
			title   = "My Menu",    -- optional display title
			size    = {720, 480},   -- optional {width, height}
			pages   = {
				{
					label = "Aimbot",
					icon  = "rbxasset://...",
					tabs  = {
						{
							label    = "Main",
							elements = {
								{ type="toggle",      label="Enable",        on=false,      onChange=function(v) end },
								{ type="slider",      label="FOV",           min=10, max=300, val=80, onChange=function(v) end },
								{ type="dropdown",    label="Target part",   options={"Head","Torso"}, val="Head", onChange=function(v) end },
								{ type="dropdown",    label="Multi select",  options={"A","B","C"},    val={}, multi=true, onChange=function(t) end },
								{ type="textinput",   label="Custom tag",    placeholder="...", default="", onChange=function(s) end },
								{ type="colorpicker", label="ESP color",     color=Color3.fromRGB(255,110,150), onChange=function(c) end },
								{ type="button",      label="Apply",         style="primary",    callback=function() end },
								{ type="button",      label="Reset",         style="secondary",  callback=function() end, disabled=false },
							},
						},
					},
				},
			},
		})

	RUNTIME API:
		window:Show()                         -- make visible
		window:Hide()                         -- make invisible
		window:Destroy()                      -- remove completely
		window:Toast(msg, style)              -- "info"|"warning"|"error"|"success"
		window:SetAccentColor(Color3)         -- change accent globally
		window:GetValue(page, tab, label)     -- read element value
		window:SetValue(page, tab, label, v)  -- write element value
		window:SetPage(pageLabel)             -- navigate to page by name
		window:OnClose(fn)                    -- fires when Destroy() called
]]

