local function buildToggle(parent, defaultOn)
	local state = defaultOn or false
	local track = Instance.new("Frame")
	track.Size = UDim2.new(0, 44, 0, 24)
	track.Position = UDim2.new(1, -44, 0.5, -12)
	track.BackgroundColor3 = state and ACCENT or BG_INPUT
	track.BorderSizePixel = 0
	track.Parent = parent
	corner(track, 12)

	local ball = Instance.new("Frame")
	ball.Size = UDim2.new(0, 16, 0, 16)
	ball.Position = state and UDim2.new(1, -20, 0.5, -8) or UDim2.new(0, 4, 0.5, -8)
	ball.BackgroundColor3 = Color3.fromRGB(255,255,255)
	ball.BorderSizePixel = 0
	ball.Parent = track
	corner(ball, 8)

	local hitBtn = Instance.new("TextButton")
	hitBtn.Size = UDim2.new(1, 0, 1, 0)
	hitBtn.BackgroundTransparency = 1
	hitBtn.Text = ""
	hitBtn.ZIndex = parent.ZIndex + 2
	hitBtn.Parent = parent

	local function doToggle()
		state = not state
		tween(track, { BackgroundColor3 = state and ACCENT or BG_INPUT })
		tween(ball,  { Position = state and UDim2.new(1,-20,0.5,-8) or UDim2.new(0,4,0.5,-8) }, tweenInfoSpring)
		tween(parent,{ BackgroundColor3 = Color3.fromRGB(20,19,30) }, tweenInfoFast)
		task.delay(0.12, function() tween(parent,{ BackgroundColor3 = BG_ROW }, tweenInfo) end)
	end
	hitBtn.MouseButton1Click:Connect(doToggle)
	hitBtn.MouseEnter:Connect(function() tween(parent,{BackgroundColor3=Color3.fromRGB(18,17,26)},tweenInfoFast) end)
	hitBtn.MouseLeave:Connect(function() tween(parent,{BackgroundColor3=BG_ROW},tweenInfoFast) end)
	return function() return state end
end

local function buildSlider(parent, minVal, maxVal, defaultVal)
	local value = defaultVal or minVal

	local track = Instance.new("Frame")
	track.Size = UDim2.new(0, 155, 0, 4)
	track.Position = UDim2.new(1, -155, 1, -22)
	track.BackgroundColor3 = BG_INPUT
	track.BorderSizePixel = 0
	track.Parent = parent
	corner(track, 2)

	local fill = Instance.new("Frame")
	fill.Size = UDim2.new((value-minVal)/(maxVal-minVal), 0, 1, 0)
	fill.BackgroundColor3 = ACCENT
	fill.BorderSizePixel = 0
	fill.Parent = track
	corner(fill, 2)

	local thumb = Instance.new("Frame")
	thumb.Size = UDim2.new(0, 12, 0, 12)
	thumb.Position = UDim2.new((value-minVal)/(maxVal-minVal), -6, 0.5, -6)
	thumb.BackgroundColor3 = Color3.fromRGB(255,255,255)
	thumb.BorderSizePixel = 0
	thumb.Parent = track
	corner(thumb, 6)

	local valLabel = Instance.new("TextLabel")
	valLabel.Size = UDim2.new(0, 36, 0, 16)
	valLabel.Position = UDim2.new(1, -36, 0, 10)
	valLabel.BackgroundTransparency = 1
	valLabel.Text = tostring(value)
	valLabel.TextColor3 = ACCENT
	valLabel.TextSize = 13
	valLabel.Font = Enum.Font.GothamBold
	valLabel.TextXAlignment = Enum.TextXAlignment.Right
	valLabel.Parent = parent

	local dragging = false
	local function update(inputX)
		local rel = math.clamp((inputX - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
		value = math.round(minVal + rel*(maxVal-minVal))
		local pct = (value-minVal)/(maxVal-minVal)
		fill.Size = UDim2.new(pct,0,1,0)
		thumb.Position = UDim2.new(pct,-6,0.5,-6)
		valLabel.Text = tostring(value)
	end

	local hitbox = Instance.new("TextButton")
	hitbox.Size = UDim2.new(1,0,1,8)
	hitbox.Position = UDim2.new(0,0,0.5,-4)
	hitbox.BackgroundTransparency = 1
	hitbox.Text = ""
	hitbox.ZIndex = track.ZIndex+1
	hitbox.Parent = track

	hitbox.MouseButton1Down:Connect(function()
		dragging = true
		update(UserInputService:GetMouseLocation().X)
	end)
	UserInputService.InputChanged:Connect(function(input)
		if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
			update(input.Position.X)
		end
	end)
	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
	end)
	return function() return value end
end

