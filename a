function Lib:AddPage(navText, iconName, order, titleText, subtitleText, iconLibrary, hasTabs)
	iconLibrary = iconLibrary or "Material"

	local pageClip, pageScroll = makeScrollPage(hasTabs and 110 or 66)
	local pageEntry = { clip = pageClip }
	table.insert(pages, pageEntry)

	local b = Instance.new("TextButton")
	b.Size = UDim2.new(1, 0, 0, 34)
	b.BackgroundColor3 = BG_SIDEBAR
	b.BackgroundTransparency = 1
	b.Text = ""
	b.LayoutOrder = order
	b.Parent = NavScroll
	corner(b, 5)

	local ico = Instance.new("ImageLabel")
	ico.Size = UDim2.new(0, 20, 0, 20)
	ico.Position = UDim2.new(0, 10, 0.5, -10)
	ico.BackgroundTransparency = 1
	ico.Image = getIcon(iconName, iconLibrary)
	ico.ImageColor3 = TEXT_MUTED
	ico.Parent = b

	local lbl = Instance.new("TextLabel")
	lbl.Size = UDim2.new(1, -38, 1, 0)
	lbl.Position = UDim2.new(0, 38, 0, 0)
	lbl.BackgroundTransparency = 1
	lbl.Text = tostring(navText)
	lbl.TextColor3 = TEXT_MUTED
	lbl.TextSize = 13
	lbl.Font = Enum.Font.Gotham
	lbl.TextXAlignment = Enum.TextXAlignment.Left
	lbl.Parent = b

	local navEntry = {
		btn      = b,
		lbl      = lbl,
		ico      = ico,
		name     = tostring(navText),
		title    = tostring(titleText),
		subtitle = tostring(subtitleText),
		page     = pageEntry,
		tabs     = hasTabs or nil,
	}
	table.insert(navButtons, navEntry)
	b.MouseButton1Click:Connect(function() setActiveNav(navEntry) end)

	local tabClips = {}
	local tabX = 0

	local Section = {}
	Section._navEntry  = navEntry
	Section._pageEntry = pageEntry
	Section._scroll    = pageScroll
	Section._rowOrder  = 0

	function Section:AddTabBar(tabNames)
		activeTabDefs = {}
		for i, tName in ipairs(tabNames) do
			local tabClip2, tabScroll2 = makeScrollPage(110)
			table.insert(pages, { clip = tabClip2 })
			tabClips[tName] = { clip = tabClip2, scroll = tabScroll2 }

			local tabBtn = Instance.new("TextButton")
			tabBtn.Size = UDim2.new(0, #tName * 8 + 10, 1, 0)
			tabBtn.Position = UDim2.new(0, tabX, 0, 0)
			tabBtn.BackgroundTransparency = 1
			tabBtn.Text = tName
			tabBtn.TextColor3 = i == 1 and TEXT_MAIN or TEXT_MUTED
			tabBtn.TextSize = 14
			tabBtn.Font = Enum.Font.GothamBold
			tabBtn.Parent = TabBar

			local def = { name = tName, btn = tabBtn, x = tabX, w = #tName * 8 + 10, clip = tabClip2 }
			table.insert(activeTabDefs, def)
			tabX = tabX + def.w + 18

			tabBtn.MouseButton1Click:Connect(function() setTab(tName) end)
		end
		if #activeTabDefs > 0 then
			TabIndicator.Size = UDim2.new(0, activeTabDefs[1].w, 0, 2)
			TabIndicator.Position = UDim2.new(0, activeTabDefs[1].x, 1, -2)
		end
		return tabClips
	end

	function Section:AddRow(titleText2, descText2, widgetDef2, tabName2)
		Section._rowOrder += 1
		local scroll = pageScroll
		if tabName2 and tabClips[tabName2] then
			scroll = tabClips[tabName2].scroll
		end
		local row, getter = buildRow(scroll, titleText2, descText2, Section._rowOrder, widgetDef2, pageEntry, navEntry, tabName2)
		return row, getter
	end

	return Section
end

function Lib:Init(defaultNavEntry, defaultTabName, keybindCode)
	currentKeybind = keybindCode or Enum.KeyCode.RightShift

	setActiveNav(defaultNavEntry or navButtons[1])
	if defaultTabName then setTab(defaultTabName) end

	-- Use ContextActionService at high priority so shiftlock doesn't swallow the key
	ContextActionService:BindActionAtPriority(
		"SyftUIToggle",
		function(_, inputState)
			if inputState == Enum.UserInputState.Begin then
				MainFrame.Visible = not MainFrame.Visible
			end
			return Enum.ContextActionResult.Pass  -- don't block the input from other things
		end,
		false,  -- no on-screen button
		2001,   -- above default game priority (2000) so shiftlock doesn't eat it first
		currentKeybind
	)

	task.delay(0.5, function()
		showNotif("Welcome back", "syft.wtf loaded successfully.", "success")
	end)
end

Lib.setActiveNav = setActiveNav
Lib.setTab       = setTab

return Lib
