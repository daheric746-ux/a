		item.MouseLeave:Connect(function() if opt ~= selected then tween(item, { BackgroundColor3 = Color3.fromRGB(22, 21, 32) }, tweenInfoFast) end end)
		item.MouseButton1Click:Connect(function()
			selected = opt
			label.Text = opt
			open = false
			tween(listClip, { Size = UDim2.new(0, 165, 0, closedH) })
			tween(chevron, { Rotation = 0 }, tweenInfo)
			tween(frame, { BackgroundColor3 = BG_INPUT }, tweenInfoFast)
			refreshColors()
			if trackConn then trackConn:Disconnect(); trackConn = nil end
		end)
	end

	clickBtn.MouseButton1Click:Connect(function()
		open = not open
		if open then
			positionList()
			tween(listClip, { Size = UDim2.new(0, 165, 0, openH) })
			tween(chevron, { Rotation = 180 }, tweenInfo)
			tween(frame, { BackgroundColor3 = Color3.fromRGB(24, 23, 34) }, tweenInfoFast)
			trackConn = RunService.RenderStepped:Connect(positionList)
		else
			tween(listClip, { Size = UDim2.new(0, 165, 0, closedH) })
			tween(chevron, { Rotation = 0 }, tweenInfo)
			tween(frame, { BackgroundColor3 = BG_INPUT }, tweenInfoFast)
			if trackConn then trackConn:Disconnect(); trackConn = nil end
		end
	end)

	return function() return selected end
end

