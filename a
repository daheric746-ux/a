function SpareStackLib:CreateMobileToggle()
	if not UIS.TouchEnabled or UIS.KeyboardEnabled then
		return
	end

	local Open = Instance.new("ImageButton")
	Open.Name = "MobileToggle"
	Open.Parent = self.Gui
	Open.AnchorPoint = Vector2.new(0.5, 0.5)
	Open.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	Open.BorderSizePixel = 0
	Open.Position = UDim2.new(0.85, 0, 0.5, 0)
	Open.Size = UDim2.new(0, 50, 0, 50)
	Open.Image = "rbxassetid://134799410833460"
	Open.ZIndex = 200

	local UICorner = Instance.new("UICorner")
	UICorner.CornerRadius = UDim.new(1, 0)
	UICorner.Parent = Open

	local UIStroke = Instance.new("UIStroke")
	UIStroke.Parent = Open
	UIStroke.Color = Color3.fromRGB(51, 105, 255)
	UIStroke.Thickness = 1.5
	UIStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border

	local HintLabel = Instance.new("TextLabel")
	HintLabel.Parent = Open
	HintLabel.BackgroundTransparency = 1
	HintLabel.Position = UDim2.new(-1.24, 0, 1.2, 0)
	HintLabel.Size = UDim2.new(0, 174, 0, 25)
	HintLabel.Font = Enum.Font.GothamBold
	HintLabel.Text = "Hold to lock"
	HintLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
	HintLabel.TextSize = 14
	HintLabel.ZIndex = 200

	local ALPHA, DEADZONE = 0.6, 6
	local dragging, inputObject, startPointer = false, nil, nil
	local targetPos
	local locked = false
	local LONG_PRESS_TIME = 1.0
	local longPressConn = nil
	local longPressStart = 0
	local longPressActive = false

	local function clamp(v, a, b)
		return math.max(a, math.min(b, v))
	end

	local function clampToParent(p)
		local par, s, b = self.Gui, self.Gui.AbsoluteSize, Open.AbsoluteSize
		local pa = par.AbsolutePosition
		return Vector2.new(clamp(p.X, pa.X, pa.X + s.X - b.X), clamp(p.Y, pa.Y, pa.Y + s.Y - b.Y))
	end

	local function toUDim2(p)
		local pa = self.Gui.AbsolutePosition
		return UDim2.new(0, p.X - pa.X, 0, p.Y - pa.Y)
	end

	local function cancelLongPress()
		if longPressConn then
			longPressConn:Disconnect()
			longPressConn = nil
			longPressActive = false
		end
	end

	local function startLongPressWatch(input)
		cancelLongPress()
		longPressActive = true
		longPressStart = tick()
		longPressConn = game:GetService("RunService").Heartbeat:Connect(function()
			if not inputObject or inputObject ~= input then
				cancelLongPress()
				return
			end

			if input.Position and startPointer and (input.Position - startPointer).Magnitude > DEADZONE then
				cancelLongPress()
				return
			end

			if tick() - longPressStart >= LONG_PRESS_TIME then
				locked = not locked
				HintLabel.Text = locked and "Locked" or "Hold to lock"
				Open.ImageTransparency = locked and 0.3 or 0
				cancelLongPress()
			end
		end)
	end

	Open.Active = true

	Open.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
			inputObject = input
			startPointer = input.Position
			dragging = false
			startLongPressWatch(input)
		end
	end)

	UIS.InputChanged:Connect(function(input)
		if not inputObject then return end

		if
			(input.UserInputType == Enum.UserInputType.Touch and input == inputObject)
			or (
				input.UserInputType == Enum.UserInputType.MouseMovement
				and inputObject
				and inputObject.UserInputType == Enum.UserInputType.MouseButton1
			)
		then
			local currentPos = input.Position
			local delta = currentPos - startPointer

			if not dragging and delta.Magnitude >= DEADZONE then
				cancelLongPress()

				if not locked then
					dragging = true
				end
			end

			if dragging then
				targetPos = clampToParent(currentPos)
			end
		end
	end)

	UIS.InputEnded:Connect(function(input)
		if longPressActive and input == inputObject then
			cancelLongPress()
		end

		if
			input == inputObject
			or (
				inputObject
				and inputObject.UserInputType == Enum.UserInputType.MouseButton1
				and input.UserInputType == Enum.UserInputType.MouseButton1
			)
		then
			if not dragging and not longPressActive then
				self.Background.Visible = not self.Background.Visible
			end
			dragging = false
			inputObject = nil
		end
	end)

	game:GetService("RunService").RenderStepped:Connect(function()
		if dragging and targetPos then
			local newPos = Open.AbsolutePosition:Lerp(targetPos, ALPHA)
			Open.Position = toUDim2(newPos)
		end
	end)

	self.MobileToggle = Open
end

