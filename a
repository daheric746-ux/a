-- ─────────────────────────────────────────────
-- AddTextInput  – labeled textbox, saves to config
-- ─────────────────────────────────────────────
function SpareStackLib:AddTextInput(parent, name, placeholder, default, callback, tooltip)
	callback = callback or function() end
	placeholder = placeholder or "Enter text..."
	default = default or ""

	local InputFrame = Instance.new("Frame")
	InputFrame.Name = "TextInput_" .. name
	InputFrame.Parent = parent
	InputFrame.BackgroundTransparency = 1
	InputFrame.Size = UDim2.new(1, 0, 0, 60)

	local TitleLabel = Instance.new("TextLabel")
	TitleLabel.Parent = InputFrame
	TitleLabel.BackgroundTransparency = 1
	TitleLabel.Size = UDim2.new(1, 0, 0, 22)
	TitleLabel.Font = Enum.Font.GothamBold
	TitleLabel.Text = name
	TitleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
	TitleLabel.TextSize = 13
	TitleLabel.TextXAlignment = Enum.TextXAlignment.Left

	local Box = Instance.new("TextBox")
	Box.Name = "Box"
	Box.Parent = InputFrame
	Box.BackgroundColor3 = Color3.fromRGB(20, 20, 27)
	Box.BorderSizePixel = 0
	Box.Position = UDim2.new(0, 0, 0, 26)
	Box.Size = UDim2.new(1, 0, 0, 32)
	Box.Font = Enum.Font.Gotham
	Box.PlaceholderText = placeholder
	Box.Text = default
	Box.TextColor3 = Color3.fromRGB(255, 255, 255)
	Box.PlaceholderColor3 = Color3.fromRGB(80, 80, 100)
	Box.TextSize = 13
	Box.TextXAlignment = Enum.TextXAlignment.Left
	Box.ClearTextOnFocus = false

	local BoxCorner = Instance.new("UICorner")
	BoxCorner.CornerRadius = UDim.new(0, 5)
	BoxCorner.Parent = Box

	local BoxPad = Instance.new("UIPadding")
	BoxPad.PaddingLeft = UDim.new(0, 10)
	BoxPad.Parent = Box

	Box.FocusLost:Connect(function()
		pcall(function() callback(Box.Text) end)
	end)

	local inputData = {
		Type = "TextInput",
		Name = name,
		Element = InputFrame,
		GetValue = function() return Box.Text end,
		SetValue = function(v) Box.Text = tostring(v) end,
		SetLabel = function(newName) TitleLabel.Text = newName end,
	}

	local configKey = name
	local suffix = 2
	while self.ConfigData[configKey] do
		configKey = name .. "_" .. suffix
		suffix = suffix + 1
	end
	self.ConfigData[configKey] = inputData

	self:_attachTooltip(InputFrame, tooltip)
	return inputData
end

-- ─────────────────────────────────────────────
-- AddKeybind  – standalone keybind element
-- ─────────────────────────────────────────────
function SpareStackLib:AddKeybind(parent, name, default, callback, tooltip)
	callback = callback or function() end
	default = default or "None"

	local KeyFrame = Instance.new("Frame")
	KeyFrame.Name = "Keybind_" .. name
	KeyFrame.Parent = parent
	KeyFrame.BackgroundTransparency = 1
	KeyFrame.Size = UDim2.new(1, 0, 0, 50)

	local TitleLabel = Instance.new("TextLabel")
	TitleLabel.Parent = KeyFrame
	TitleLabel.BackgroundTransparency = 1
	TitleLabel.Size = UDim2.new(0.55, 0, 1, 0)
	TitleLabel.Font = Enum.Font.GothamBold
	TitleLabel.Text = name
	TitleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
	TitleLabel.TextSize = 14
	TitleLabel.TextXAlignment = Enum.TextXAlignment.Left

	local KeyBtn = Instance.new("TextButton")
	KeyBtn.Parent = KeyFrame
	KeyBtn.BackgroundColor3 = Color3.fromRGB(20, 20, 27)
	KeyBtn.BorderSizePixel = 0
	KeyBtn.AnchorPoint = Vector2.new(1, 0.5)
	KeyBtn.Position = UDim2.new(1, 0, 0.5, 0)
	KeyBtn.Size = UDim2.new(0, 90, 0, 28)
	KeyBtn.Font = Enum.Font.GothamBold
	KeyBtn.Text = default
	KeyBtn.TextColor3 = Color3.fromRGB(200, 200, 220)
	KeyBtn.TextSize = 13

	local KeyCorner = Instance.new("UICorner")
	KeyCorner.CornerRadius = UDim.new(0, 5)
	KeyCorner.Parent = KeyBtn

	local KeyStroke = Instance.new("UIStroke")
	KeyStroke.Color = Color3.fromRGB(40, 40, 58)
	KeyStroke.Thickness = 1
	KeyStroke.Parent = KeyBtn

	local currentKey = default
	local listening = false
	local keyConn

	KeyBtn.MouseButton1Click:Connect(function()
		if listening then return end
		listening = true
		KeyBtn.Text = "..."
		KeyBtn.TextColor3 = Color3.fromRGB(51, 105, 255)
		TweenService:Create(KeyStroke, TweenInfo.new(0.15), { Color = Color3.fromRGB(51, 105, 255) }):Play()

		keyConn = UIS.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.Keyboard then
				listening = false
				keyConn:Disconnect()
				currentKey = input.KeyCode.Name
				KeyBtn.Text = currentKey
				KeyBtn.TextColor3 = Color3.fromRGB(200, 200, 220)
				TweenService:Create(KeyStroke, TweenInfo.new(0.15), { Color = Color3.fromRGB(40, 40, 58) }):Play()
				pcall(function() callback(currentKey) end)
			end
		end)
	end)

	-- Right-click to clear
	KeyBtn.MouseButton2Click:Connect(function()
		if listening then return end
		currentKey = "None"
		KeyBtn.Text = "None"
		pcall(function() callback(currentKey) end)
	end)

	local keybindData = {
		Type = "Keybind",
		Name = name,
		Element = KeyFrame,
		GetValue = function() return currentKey end,
		SetValue = function(v)
			currentKey = v or "None"
			KeyBtn.Text = currentKey
		end,
		SetLabel = function(newName) TitleLabel.Text = newName end,
	}

	local configKey = name
	local suffix = 2
	while self.ConfigData[configKey] do
		configKey = name .. "_" .. suffix
		suffix = suffix + 1
	end
	self.ConfigData[configKey] = keybindData

	self:_attachTooltip(KeyFrame, tooltip)
	return keybindData
end

-- ─────────────────────────────────────────────
-- AddColorPicker  – swatch button → HSV popup (UIGradient-based, no asset IDs)
-- ─────────────────────────────────────────────
function SpareStackLib:AddColorPicker(parent, name, default, callback, tooltip)
	callback = callback or function() end
	default = default or Color3.fromRGB(255, 255, 255)

	local h, s, v = Color3.toHSV(default)
	local currentColor = default

	local PickerFrame = Instance.new("Frame")
	PickerFrame.Name = "ColorPicker_" .. name
	PickerFrame.Parent = parent
	PickerFrame.BackgroundTransparency = 1
	PickerFrame.Size = UDim2.new(1, 0, 0, 50)

	local TitleLabel = Instance.new("TextLabel")
	TitleLabel.Parent = PickerFrame
	TitleLabel.BackgroundTransparency = 1
	TitleLabel.Size = UDim2.new(0.7, 0, 1, 0)
	TitleLabel.Font = Enum.Font.GothamBold
	TitleLabel.Text = name
	TitleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
	TitleLabel.TextSize = 14
	TitleLabel.TextXAlignment = Enum.TextXAlignment.Left

	-- Swatch preview button
	local Swatch = Instance.new("TextButton")
	Swatch.Parent = PickerFrame
	Swatch.BackgroundColor3 = currentColor
	Swatch.BorderSizePixel = 0
	Swatch.AnchorPoint = Vector2.new(1, 0.5)
	Swatch.Position = UDim2.new(1, 0, 0.5, 0)
	Swatch.Size = UDim2.new(0, 40, 0, 28)
	Swatch.Text = ""

	local SwatchCorner = Instance.new("UICorner")
	SwatchCorner.CornerRadius = UDim.new(0, 5)
	SwatchCorner.Parent = Swatch

	local SwatchStroke = Instance.new("UIStroke")
	SwatchStroke.Color = Color3.fromRGB(50, 50, 70)
	SwatchStroke.Thickness = 1
	SwatchStroke.Parent = Swatch

	-- Hex label next to swatch
	local HexLabel = Instance.new("TextLabel")
	HexLabel.Parent = PickerFrame
	HexLabel.BackgroundTransparency = 1
	HexLabel.AnchorPoint = Vector2.new(1, 0.5)
	HexLabel.Position = UDim2.new(1, -48, 0.5, 0)
	HexLabel.Size = UDim2.new(0, 70, 0, 20)
	HexLabel.Font = Enum.Font.Gotham
	HexLabel.TextColor3 = Color3.fromRGB(120, 120, 140)
	HexLabel.TextSize = 11
	HexLabel.TextXAlignment = Enum.TextXAlignment.Right

	local function colorToHex(c)
		return string.format("#%02X%02X%02X", math.floor(c.R*255), math.floor(c.G*255), math.floor(c.B*255))
	end
	HexLabel.Text = colorToHex(currentColor)

	local popupOpen = false

	Swatch.MouseButton1Click:Connect(function()
		local existing = self.Gui:FindFirstChild("_ColorPopup_" .. name)
		if existing then existing:Destroy(); popupOpen = false; return end
		popupOpen = true

		local mp = UIS:GetMouseLocation()
		local px = math.clamp(mp.X - 10, 8, 880)
		local py = math.clamp(mp.Y + 8, 8, 560)

		-- ── Popup container ───────────────────────────────────────
		local Popup = Instance.new("Frame")
		Popup.Name = "_ColorPopup_" .. name
		Popup.Parent = self.Gui
		Popup.BackgroundColor3 = Color3.fromRGB(16, 16, 22)
		Popup.BorderSizePixel = 0
		Popup.Position = UDim2.new(0, px, 0, py)
		Popup.Size = UDim2.new(0, 230, 0, 218)
		Popup.ZIndex = 550
		Popup.Active = true
		Popup.ClipsDescendants = false

		local PopCorner = Instance.new("UICorner")
		PopCorner.CornerRadius = UDim.new(0, 8)
		PopCorner.Parent = Popup

		local PopStroke = Instance.new("UIStroke")
		PopStroke.Color = Color3.fromRGB(45, 45, 65)
		PopStroke.Thickness = 1
		PopStroke.Parent = Popup

		-- Drag handle bar at top
		local DragBar = Instance.new("TextButton")
		DragBar.Parent = Popup
		DragBar.BackgroundColor3 = Color3.fromRGB(22, 22, 30)
		DragBar.BorderSizePixel = 0
		DragBar.Size = UDim2.new(1, 0, 0, 22)
		DragBar.Text = name
		DragBar.Font = Enum.Font.GothamBold
		DragBar.TextSize = 11
		DragBar.TextColor3 = Color3.fromRGB(130, 130, 150)
		DragBar.ZIndex = 560

		local DBC = Instance.new("UICorner"); DBC.CornerRadius = UDim.new(0,8); DBC.Parent = DragBar

		-- ── SV square (built with UIGradient — no assets needed) ──
		-- Base: solid hue color
		local SVBox = Instance.new("Frame")
		SVBox.Name = "SVBox"
		SVBox.Parent = Popup
		SVBox.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
		SVBox.BorderSizePixel = 0
		SVBox.Position = UDim2.new(0, 10, 0, 30)
		SVBox.Size = UDim2.new(0, 148, 0, 148)
		SVBox.ZIndex = 551
		SVBox.Active = true
		SVBox.ClipsDescendants = true

		local SVCorner = Instance.new("UICorner")
		SVCorner.CornerRadius = UDim.new(0, 4)
		SVCorner.Parent = SVBox

		-- White saturation overlay (left=white, right=transparent)
		local SatOverlay = Instance.new("Frame")
		SatOverlay.Parent = SVBox
		SatOverlay.BackgroundColor3 = Color3.fromRGB(255,255,255)
		SatOverlay.BorderSizePixel = 0
		SatOverlay.Size = UDim2.new(1,0,1,0)
		SatOverlay.ZIndex = 552
		SatOverlay.Active = false

		local SatGrad = Instance.new("UIGradient")
		SatGrad.Color = ColorSequence.new({
			ColorSequenceKeypoint.new(0, Color3.fromRGB(255,255,255)),
			ColorSequenceKeypoint.new(1, Color3.fromRGB(255,255,255)),
		})
		SatGrad.Transparency = NumberSequence.new({
			NumberSequenceKeypoint.new(0, 0),
			NumberSequenceKeypoint.new(1, 1),
		})
		SatGrad.Rotation = 0
		SatGrad.Parent = SatOverlay

		-- Black value overlay (top=transparent, bottom=black)
		local ValOverlay = Instance.new("Frame")
		ValOverlay.Parent = SVBox
		ValOverlay.BackgroundColor3 = Color3.fromRGB(0,0,0)
		ValOverlay.BorderSizePixel = 0
		ValOverlay.Size = UDim2.new(1,0,1,0)
		ValOverlay.ZIndex = 553
		ValOverlay.Active = false

		local ValGrad = Instance.new("UIGradient")
		ValGrad.Color = ColorSequence.new({
			ColorSequenceKeypoint.new(0, Color3.fromRGB(0,0,0)),
			ColorSequenceKeypoint.new(1, Color3.fromRGB(0,0,0)),
		})
		ValGrad.Transparency = NumberSequence.new({
			NumberSequenceKeypoint.new(0, 1),
			NumberSequenceKeypoint.new(1, 0),
		})
		ValGrad.Rotation = 90
		ValGrad.Parent = ValOverlay

		-- SV cursor dot
		local SVCursor = Instance.new("Frame")
		SVCursor.Parent = SVBox
		SVCursor.BackgroundColor3 = Color3.fromRGB(255,255,255)
		SVCursor.BorderSizePixel = 0
		SVCursor.AnchorPoint = Vector2.new(0.5, 0.5)
		SVCursor.Size = UDim2.new(0, 12, 0, 12)
		SVCursor.ZIndex = 560
		SVCursor.Position = UDim2.new(s, 0, 1-v, 0)

		local SVC2 = Instance.new("UICorner"); SVC2.CornerRadius = UDim.new(1,0); SVC2.Parent = SVCursor
		local SVS = Instance.new("UIStroke"); SVS.Color = Color3.fromRGB(0,0,0); SVS.Thickness = 1; SVS.Parent = SVCursor

		-- ── Hue bar (UIGradient rainbow) ─────────────────────────
		local HueBar = Instance.new("Frame")
		HueBar.Name = "HueBar"
		HueBar.Parent = Popup
		HueBar.BackgroundColor3 = Color3.fromRGB(255,255,255)
		HueBar.BorderSizePixel = 0
		HueBar.Position = UDim2.new(0, 166, 0, 30)
		HueBar.Size = UDim2.new(0, 18, 0, 148)
		HueBar.ZIndex = 551
		HueBar.Active = true

		local HueCorner = Instance.new("UICorner")
		HueCorner.CornerRadius = UDim.new(0, 4)
		HueCorner.Parent = HueBar

		-- Build a 7-stop rainbow ColorSequence
		local hueGrad = Instance.new("UIGradient")
		hueGrad.Color = ColorSequence.new({
			ColorSequenceKeypoint.new(0/6,  Color3.fromHSV(0,   1, 1)),
			ColorSequenceKeypoint.new(1/6,  Color3.fromHSV(1/6, 1, 1)),
			ColorSequenceKeypoint.new(2/6,  Color3.fromHSV(2/6, 1, 1)),
			ColorSequenceKeypoint.new(3/6,  Color3.fromHSV(3/6, 1, 1)),
			ColorSequenceKeypoint.new(4/6,  Color3.fromHSV(4/6, 1, 1)),
			ColorSequenceKeypoint.new(5/6,  Color3.fromHSV(5/6, 1, 1)),
			ColorSequenceKeypoint.new(1,    Color3.fromHSV(1,   1, 1)),
		})
		hueGrad.Rotation = 90  -- top = 0 hue, bottom = 1 hue (red→violet)
		hueGrad.Parent = HueBar

		local HueCursor = Instance.new("Frame")
		HueCursor.Parent = HueBar
		HueCursor.BackgroundColor3 = Color3.fromRGB(255,255,255)
		HueCursor.BorderSizePixel = 0
		HueCursor.AnchorPoint = Vector2.new(0.5, 0.5)
		HueCursor.Size = UDim2.new(1.5, 0, 0, 4)
		HueCursor.ZIndex = 560
		HueCursor.Position = UDim2.new(0.5, 0, 1 - h, 0)

		local HC2 = Instance.new("UICorner"); HC2.CornerRadius = UDim.new(1,0); HC2.Parent = HueCursor
		local HCS = Instance.new("UIStroke"); HCS.Color = Color3.fromRGB(0,0,0); HCS.Thickness = 1; HCS.Parent = HueCursor

		-- ── Bottom row: result swatch + hex input ─────────────────
		local ResultSwatch = Instance.new("Frame")
		ResultSwatch.Parent = Popup
		ResultSwatch.BackgroundColor3 = currentColor
		ResultSwatch.BorderSizePixel = 0
		ResultSwatch.Position = UDim2.new(0, 10, 0, 186)
		ResultSwatch.Size = UDim2.new(0, 44, 0, 24)
		ResultSwatch.ZIndex = 551
		local RSC = Instance.new("UICorner"); RSC.CornerRadius = UDim.new(0,4); RSC.Parent = ResultSwatch

		local HexBox = Instance.new("TextBox")
		HexBox.Parent = Popup
		HexBox.BackgroundColor3 = Color3.fromRGB(22,22,30)
		HexBox.BorderSizePixel = 0
		HexBox.Position = UDim2.new(0, 60, 0, 186)
		HexBox.Size = UDim2.new(0, 162, 0, 24)
		HexBox.Font = Enum.Font.Gotham
		HexBox.Text = colorToHex(currentColor)
		HexBox.TextColor3 = Color3.fromRGB(200,200,220)
		HexBox.TextSize = 12
		HexBox.ClearTextOnFocus = false
		HexBox.ZIndex = 551
		local HBC = Instance.new("UICorner"); HBC.CornerRadius = UDim.new(0,4); HBC.Parent = HexBox
		local HBP = Instance.new("UIPadding"); HBP.PaddingLeft = UDim.new(0,8); HBP.Parent = HexBox

		-- ── applyColor ────────────────────────────────────────────
		local function applyColor()
			currentColor = Color3.fromHSV(h, s, v)
			Swatch.BackgroundColor3 = currentColor
			HexLabel.Text = colorToHex(currentColor)
			SVBox.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
			ResultSwatch.BackgroundColor3 = currentColor
			HexBox.Text = colorToHex(currentColor)
			SVCursor.Position = UDim2.new(s, 0, 1 - v, 0)
			HueCursor.Position = UDim2.new(0.5, 0, 1 - h, 0)
			pcall(function() callback(currentColor) end)
		end

		local function getSVFromMouse()
			local mouse = UIS:GetMouseLocation()
			local ap = SVBox.AbsolutePosition
			local as = SVBox.AbsoluteSize
			s = math.clamp((mouse.X - ap.X) / as.X, 0, 1)
			v = 1 - math.clamp((mouse.Y - ap.Y) / as.Y, 0, 1)
		end

		local function getHueFromMouse()
			local mouse = UIS:GetMouseLocation()
			local ap = HueBar.AbsolutePosition
			local as = HueBar.AbsoluteSize
			h = 1 - math.clamp((mouse.Y - ap.Y) / as.Y, 0, 1)
		end

		-- ── SV drag ───────────────────────────────────────────────
		local svDragging = false

		local svConn = game:GetService("RunService").RenderStepped:Connect(function()
			if svDragging then
				getSVFromMouse()
				applyColor()
			end
		end)

		local svEnd = UIS.InputEnded:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 then
				svDragging = false
			end
		end)

		SVBox.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 then
				svDragging = true
				getSVFromMouse()
				applyColor()
			end
		end)

		-- ── Hue drag ──────────────────────────────────────────────
		local hueDragging = false

		local hueConn = game:GetService("RunService").RenderStepped:Connect(function()
			if hueDragging then
				getHueFromMouse()
				applyColor()
			end
		end)

		local hueEnd = UIS.InputEnded:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 then
				hueDragging = false
			end
		end)

		HueBar.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 then
				hueDragging = true
				getHueFromMouse()
				applyColor()
			end
		end)

		-- ── Hex input ─────────────────────────────────────────────
		HexBox.FocusLost:Connect(function()
			local hex = HexBox.Text:gsub("#","")
			if #hex == 6 then
				local r = tonumber(hex:sub(1,2), 16)
				local g = tonumber(hex:sub(3,4), 16)
				local b = tonumber(hex:sub(5,6), 16)
				if r and g and b then
					local nc = Color3.fromRGB(r, g, b)
					h, s, v = Color3.toHSV(nc)
					applyColor()
				end
			end
		end)

		-- ── Popup drag (drag bar) ─────────────────────────────────
		local popDrag, popDragStart, popStartPos2 = false, nil, nil

		DragBar.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 then
				popDrag = true
				popDragStart = input.Position
				popStartPos2 = Popup.Position
			end
		end)

		local pdConn = UIS.InputChanged:Connect(function(input)
			if popDrag and input.UserInputType == Enum.UserInputType.MouseMovement then
				local d = input.Position - popDragStart
				Popup.Position = UDim2.new(
					popStartPos2.X.Scale, popStartPos2.X.Offset + d.X,
					popStartPos2.Y.Scale, popStartPos2.Y.Offset + d.Y
				)
			end
		end)

		local pdEnd = UIS.InputEnded:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 then
				popDrag = false
			end
		end)

		Popup.AncestryChanged:Connect(function()
			svConn:Disconnect(); svEnd:Disconnect()
			hueConn:Disconnect(); hueEnd:Disconnect()
			pdConn:Disconnect(); pdEnd:Disconnect()
			popupOpen = false
		end)
	end)

	local pickerData = {
		Type = "ColorPicker",
		Name = name,
		Element = PickerFrame,
		GetValue = function() return currentColor end,
		SetValue = function(c)
			currentColor = c
			h, s, v = Color3.toHSV(c)
			Swatch.BackgroundColor3 = c
			HexLabel.Text = colorToHex(c)
			pcall(function() callback(c) end)
		end,
		SetLabel = function(newName) TitleLabel.Text = newName end,
	}

	local configKey = name
	local suffix = 2
	while self.ConfigData[configKey] do
		configKey = name .. "_" .. suffix
		suffix = suffix + 1
	end
	self.ConfigData[configKey] = pickerData

	self:_attachTooltip(PickerFrame, tooltip)
	return pickerData
end

-- ─────────────────────────────────────────────
-- AddMultiDropdown  – multiple selectable options with checkboxes
-- ─────────────────────────────────────────────
function SpareStackLib:AddMultiDropdown(parent, name, options, defaults, callback, tooltip)
	callback = callback or function() end
	options = options or {}
	local selected = {}
	if defaults then
		for _, v in ipairs(defaults) do selected[v] = true end
	end

	-- MDFrame grows to include the open list — no clipping issues with ElementsHolder
	local CLOSED_H = 62
	local ROW_H    = 32
	local LIST_PAD = 10  -- top+bottom padding inside list
	local dropH    = math.min(#options * ROW_H + LIST_PAD, 180)
	local OPEN_H   = CLOSED_H + dropH + 4

	local MDFrame = Instance.new("Frame")
	MDFrame.Name = "MultiDropdown_" .. name
	MDFrame.Parent = parent
	MDFrame.BackgroundTransparency = 1
	MDFrame.Size = UDim2.new(1, 0, 0, CLOSED_H)
	MDFrame.ClipsDescendants = false

	-- Label above button
	local BtnLabel = Instance.new("TextLabel")
	BtnLabel.Parent = MDFrame
	BtnLabel.BackgroundTransparency = 1
	BtnLabel.Position = UDim2.new(0, 0, 0, 0)
	BtnLabel.Size = UDim2.new(1, 0, 0, 18)
	BtnLabel.Font = Enum.Font.GothamBold
	BtnLabel.Text = name
	BtnLabel.TextColor3 = Color3.fromRGB(200, 200, 220)
	BtnLabel.TextSize = 11
	BtnLabel.TextXAlignment = Enum.TextXAlignment.Left

	local function getSelectedText()
		local parts = {}
		for _, opt in ipairs(options) do
			if selected[opt] then table.insert(parts, opt) end
		end
		if #parts == 0 then return "None" end
		if #parts == #options then return "All" end
		return table.concat(parts, ", ")
	end

	-- Main dropdown button
	local Button = Instance.new("TextButton")
	Button.Parent = MDFrame
	Button.BackgroundColor3 = Color3.fromRGB(20, 20, 27)
	Button.BorderSizePixel = 0
	Button.Position = UDim2.new(0, 0, 0, 22)
	Button.Size = UDim2.new(1, 0, 0, 36)
	Button.Font = Enum.Font.Gotham
	Button.Text = ""
	Button.TextColor3 = Color3.fromRGB(255, 255, 255)
	Button.TextSize = 13
	Button.ZIndex = 2
	local BC = Instance.new("UICorner"); BC.CornerRadius = UDim.new(0, 6); BC.Parent = Button

	-- Value text inside button (left side, leaves room for arrow)
	local ValLabel = Instance.new("TextLabel")
	ValLabel.Parent = Button
	ValLabel.BackgroundTransparency = 1
	ValLabel.Position = UDim2.new(0, 10, 0, 0)
	ValLabel.Size = UDim2.new(1, -36, 1, 0)
	ValLabel.Font = Enum.Font.Gotham
	ValLabel.Text = getSelectedText()
	ValLabel.TextColor3 = Color3.fromRGB(180, 180, 200)
	ValLabel.TextSize = 13
	ValLabel.TextXAlignment = Enum.TextXAlignment.Left
	ValLabel.TextTruncate = Enum.TextTruncate.AtEnd
	ValLabel.ZIndex = 3

	-- Arrow chevron (right side of button)
	local Arrow = Instance.new("TextLabel")
	Arrow.Parent = Button
	Arrow.BackgroundTransparency = 1
	Arrow.AnchorPoint = Vector2.new(1, 0.5)
	Arrow.Position = UDim2.new(1, -10, 0.5, 0)
	Arrow.Size = UDim2.new(0, 18, 0, 18)
	Arrow.Font = Enum.Font.GothamBold
	Arrow.Text = "▾"
	Arrow.TextColor3 = Color3.fromRGB(100, 100, 130)
	Arrow.TextSize = 14
	Arrow.ZIndex = 3

	-- Options list (parented inside MDFrame, revealed by growing MDFrame)
	local OptionsHolder = Instance.new("ScrollingFrame")
	OptionsHolder.Parent = MDFrame
	OptionsHolder.BackgroundColor3 = Color3.fromRGB(22, 22, 30)
	OptionsHolder.BorderSizePixel = 0
	OptionsHolder.Position = UDim2.new(0, 0, 0, CLOSED_H + 2)
	OptionsHolder.Size = UDim2.new(1, 0, 0, dropH)
	OptionsHolder.Visible = false
	OptionsHolder.ScrollBarThickness = 2
	OptionsHolder.ScrollBarImageColor3 = Color3.fromRGB(51, 105, 255)
	OptionsHolder.CanvasSize = UDim2.new(0, 0, 0, #options * ROW_H + LIST_PAD)
	OptionsHolder.ClipsDescendants = true
	OptionsHolder.ZIndex = 10
	local OHC = Instance.new("UICorner"); OHC.CornerRadius = UDim.new(0, 6); OHC.Parent = OptionsHolder
	local OHS = Instance.new("UIStroke"); OHS.Color = Color3.fromRGB(40, 40, 55); OHS.Thickness = 1; OHS.Parent = OptionsHolder

	local OHP = Instance.new("UIPadding")
	OHP.PaddingTop    = UDim.new(0, 5)
	OHP.PaddingBottom = UDim.new(0, 5)
	OHP.PaddingLeft   = UDim.new(0, 6)
	OHP.PaddingRight  = UDim.new(0, 6)
	OHP.Parent = OptionsHolder

	local OptionsList = Instance.new("UIListLayout")
	OptionsList.Parent = OptionsHolder
	OptionsList.SortOrder = Enum.SortOrder.LayoutOrder
	OptionsList.Padding = UDim.new(0, 2)

	local tweenInfo = TweenInfo.new(0.2, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
	local isOpen = false
	local optionRows = {}

	for _, optText in ipairs(options) do
		local Row = Instance.new("TextButton")
		Row.Parent = OptionsHolder
		Row.BackgroundColor3 = Color3.fromRGB(35, 35, 48)
		Row.BackgroundTransparency = 1
		Row.BorderSizePixel = 0
		Row.Size = UDim2.new(1, 0, 0, ROW_H - 2)
		Row.Text = ""
		Row.ZIndex = 11
		local RowC = Instance.new("UICorner"); RowC.CornerRadius = UDim.new(0, 4); RowC.Parent = Row

		-- Checkbox square — solid blue fill when selected, transparent + border when not
		local Check = Instance.new("Frame")
		Check.Parent = Row
		Check.BackgroundColor3 = Color3.fromRGB(51, 105, 255)
		Check.BackgroundTransparency = selected[optText] == true and 0 or 1
		Check.BorderSizePixel = 0
		Check.AnchorPoint = Vector2.new(0, 0.5)
		Check.Position = UDim2.new(0, 6, 0.5, 0)
		Check.Size = UDim2.new(0, 14, 0, 14)
		Check.ZIndex = 12
		local CC = Instance.new("UICorner"); CC.CornerRadius = UDim.new(0, 3); CC.Parent = Check
		local CS = Instance.new("UIStroke")
		CS.Color = Color3.fromRGB(51, 105, 255)
		CS.Thickness = 1.5
		CS.Parent = Check

		-- Option text
		local RowLabel = Instance.new("TextLabel")
		RowLabel.Parent = Row
		RowLabel.BackgroundTransparency = 1
		RowLabel.Position = UDim2.new(0, 30, 0, 0)
		RowLabel.Size = UDim2.new(1, -34, 1, 0)
		RowLabel.Font = Enum.Font.Gotham
		RowLabel.Text = optText
		RowLabel.TextColor3 = Color3.fromRGB(210, 210, 230)
		RowLabel.TextSize = 13
		RowLabel.TextXAlignment = Enum.TextXAlignment.Left
		RowLabel.ZIndex = 12

		Row.MouseButton1Click:Connect(function()
			selected[optText] = not (selected[optText] == true)
			local isNowSelected = selected[optText] == true
			TweenService:Create(Check, TweenInfo.new(0.12), {
				BackgroundTransparency = isNowSelected and 0 or 1,
			}):Play()
			ValLabel.Text = getSelectedText()
			local vals = {}
			for _, opt in ipairs(options) do
				if selected[opt] == true then table.insert(vals, opt) end
			end
			pcall(function() callback(vals) end)
		end)

		Row.MouseEnter:Connect(function()
			TweenService:Create(Row, TweenInfo.new(0.1), { BackgroundTransparency = 0 }):Play()
		end)
		Row.MouseLeave:Connect(function()
			TweenService:Create(Row, TweenInfo.new(0.1), { BackgroundTransparency = 1 }):Play()
		end)

		optionRows[optText] = { check = Check }
	end

	Button.MouseButton1Click:Connect(function()
		isOpen = not isOpen
		if isOpen then
			OptionsHolder.Visible = true
			-- Grow MDFrame to make room — ElementsHolder canvas auto-expands
			TweenService:Create(MDFrame, tweenInfo, { Size = UDim2.new(1, 0, 0, OPEN_H) }):Play()
			TweenService:Create(Arrow, tweenInfo, { Rotation = 180 }):Play()
		else
			TweenService:Create(MDFrame, tweenInfo, { Size = UDim2.new(1, 0, 0, CLOSED_H) }):Play()
			TweenService:Create(Arrow, tweenInfo, { Rotation = 0 }):Play()
			task.delay(0.22, function()
				if not isOpen then OptionsHolder.Visible = false end
			end)
		end
	end)

	local mdData = {
		Type = "MultiDropdown", Name = name, Element = MDFrame,
		GetValue = function()
			local vals = {}
			for _, opt in ipairs(options) do
				if selected[opt] == true then table.insert(vals, opt) end
			end
			return vals
		end,
		SetValue = function(vals)
			selected = {}
			for _, v in ipairs(vals) do selected[v] = true end
			for optText, row in pairs(optionRows) do
				local sel = selected[optText] == true
				row.check.BackgroundTransparency = sel and 0 or 1
			end
			ValLabel.Text = getSelectedText()
		end,
		SetLabel = function(newName) BtnLabel.Text = newName end,
		SetEnabled = function(state)
			Button.Active = state
			Button.AutoButtonColor = state
		end,
	}

	local configKey = name; local suffix = 2
	while self.ConfigData[configKey] do configKey = name .. "_" .. suffix; suffix = suffix + 1 end
	self.ConfigData[configKey] = mdData
	self:_attachTooltip(MDFrame, tooltip)
	return mdData
end

function SpareStackLib:AddToggleSlider(parent, name, toggleDefault, sliderMin, sliderMax, sliderDefault, callback, tooltip)
	callback = callback or function() end
	toggleDefault = toggleDefault or false
	sliderMin = sliderMin or 0
	sliderMax = sliderMax or 100
	sliderDefault = math.clamp(sliderDefault or sliderMin, sliderMin, sliderMax)

	-- Layout:  [Title...........] [Val] [Toggle]
	--          [===Slider bar============]
	local TSFrame = Instance.new("Frame")
	TSFrame.Name = "ToggleSlider_" .. name
	TSFrame.Parent = parent
	TSFrame.BackgroundTransparency = 1
	TSFrame.Size = UDim2.new(1, 0, 0, 58)

	-- Title – leaves 80px on right for value+toggle
	local TitleLabel = Instance.new("TextLabel")
	TitleLabel.Parent = TSFrame
	TitleLabel.BackgroundTransparency = 1
	TitleLabel.Position = UDim2.new(0, 0, 0, 0)
	TitleLabel.Size = UDim2.new(1, -82, 0, 22)
	TitleLabel.Font = Enum.Font.GothamBold
	TitleLabel.Text = name
	TitleLabel.TextColor3 = toggleDefault and Color3.fromRGB(255,255,255) or Color3.fromRGB(58,58,73)
	TitleLabel.TextSize = 13
	TitleLabel.TextXAlignment = Enum.TextXAlignment.Left
	TitleLabel.TextTruncate = Enum.TextTruncate.AtEnd

	-- Value label – sits to the left of the toggle, right-aligned
	local ValueLabel = Instance.new("TextLabel")
	ValueLabel.Parent = TSFrame
	ValueLabel.BackgroundTransparency = 1
	ValueLabel.AnchorPoint = Vector2.new(1, 0)
	ValueLabel.Position = UDim2.new(1, -42, 0, 3)
	ValueLabel.Size = UDim2.new(0, 36, 0, 16)
	ValueLabel.Font = Enum.Font.Gotham
	ValueLabel.TextSize = 11
	ValueLabel.TextColor3 = Color3.fromRGB(140, 140, 165)
	ValueLabel.TextXAlignment = Enum.TextXAlignment.Right
	ValueLabel.Text = tostring(sliderDefault)

	-- Toggle switch – far right
	local TogBg = Instance.new("TextButton")
	TogBg.Parent = TSFrame
	TogBg.BackgroundColor3 = toggleDefault and Color3.fromRGB(28,48,103) or Color3.fromRGB(21,21,28)
	TogBg.BorderSizePixel = 0
	TogBg.AnchorPoint = Vector2.new(1, 0)
	TogBg.Position = UDim2.new(1, 0, 0, 2)
	TogBg.Size = UDim2.new(0, 35, 0, 18)
	TogBg.Text = ""
	local TBC = Instance.new("UICorner"); TBC.CornerRadius = UDim.new(1,0); TBC.Parent = TogBg

	local Orb = Instance.new("Frame")
	Orb.Parent = TogBg
	Orb.BackgroundColor3 = toggleDefault and Color3.fromRGB(51,105,255) or Color3.fromRGB(37,37,57)
	Orb.BorderSizePixel = 0
	Orb.Position = toggleDefault and UDim2.new(0,18,0.15,0) or UDim2.new(0,4,0.15,0)
	Orb.Size = UDim2.new(0,12,0,12)
	local OC = Instance.new("UICorner"); OC.CornerRadius = UDim.new(1,0); OC.Parent = Orb

	-- Slider bar – full width, below
	local SliderBar = Instance.new("Frame")
	SliderBar.Parent = TSFrame
	SliderBar.BackgroundColor3 = Color3.fromRGB(21,21,27)
	SliderBar.BorderSizePixel = 0
	SliderBar.Position = UDim2.new(0, 0, 0, 34)
	SliderBar.Size = UDim2.new(1, -2, 0, 10)
	local SBC = Instance.new("UICorner"); SBC.Parent = SliderBar

	local Fill = Instance.new("Frame")
	Fill.Parent = SliderBar
	Fill.BackgroundColor3 = Color3.fromRGB(51,105,255)
	Fill.BorderSizePixel = 0
	Fill.Size = UDim2.new(0,0,1,0)
	local FC = Instance.new("UICorner"); FC.Parent = Fill

	local Knob = Instance.new("TextButton")
	Knob.Parent = SliderBar
	Knob.BackgroundColor3 = Color3.fromRGB(255,255,255)
	Knob.BorderSizePixel = 0
	Knob.AnchorPoint = Vector2.new(0.5,0.5)
	Knob.Position = UDim2.new(0,0,0.5,0)
	Knob.Size = UDim2.new(0,20,0,14)
	Knob.ZIndex = 2
	Knob.Text = ""
	local KC = Instance.new("UICorner"); KC.CornerRadius = UDim.new(1,0); KC.Parent = Knob

	local toggled = toggleDefault
	local currentValue = sliderDefault
	local tweenInfo = TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
	local sliderEnabled = toggled

	local function updateSlider(value)
		value = math.clamp(value, sliderMin, sliderMax)
		currentValue = math.floor(value)
		local pct = (currentValue - sliderMin) / (sliderMax - sliderMin)
		local bw = SliderBar.AbsoluteSize.X
		local px = 10 + pct * (bw - 20)
		TweenService:Create(Knob, tweenInfo, { Position = UDim2.new(0,px,0.5,0) }):Play()
		TweenService:Create(Fill, tweenInfo, { Size = UDim2.new(0,px,1,0) }):Play()
		ValueLabel.Text = tostring(currentValue)
		if sliderEnabled then pcall(function() callback(toggled, currentValue) end) end
	end

	local function setToggle(val)
		toggled = val
		sliderEnabled = val
		TweenService:Create(Orb, tweenInfo, { Position = val and UDim2.new(0,18,0.15,0) or UDim2.new(0,4,0.15,0) }):Play()
		TweenService:Create(TogBg, tweenInfo, { BackgroundColor3 = val and Color3.fromRGB(28,48,103) or Color3.fromRGB(21,21,28) }):Play()
		TweenService:Create(Orb, tweenInfo, { BackgroundColor3 = val and Color3.fromRGB(51,105,255) or Color3.fromRGB(37,37,57) }):Play()
		TweenService:Create(TitleLabel, tweenInfo, { TextColor3 = val and Color3.fromRGB(255,255,255) or Color3.fromRGB(58,58,73) }):Play()
		TweenService:Create(ValueLabel, tweenInfo, { TextColor3 = val and Color3.fromRGB(140,140,165) or Color3.fromRGB(55,55,70) }):Play()
		pcall(function() callback(toggled, currentValue) end)
	end

	TogBg.MouseButton1Click:Connect(function() setToggle(not toggled) end)

	local sliderDragging = false
	Knob.MouseButton1Down:Connect(function()
		if not sliderEnabled then return end
		sliderDragging = true
		self.SetSliderDragging(true)
	end)
	UIS.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			sliderDragging = false
			self.SetSliderDragging(false)
		end
	end)
	UIS.InputChanged:Connect(function(input)
		if sliderDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
			local bp = SliderBar.AbsolutePosition.X
			local bw = SliderBar.AbsoluteSize.X
			local pct = math.clamp((input.Position.X - bp) / bw, 0, 1)
			updateSlider(sliderMin + pct * (sliderMax - sliderMin))
		end
	end)
	SliderBar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 and sliderEnabled then
			self.SetSliderDragging(true)
			local pct = math.clamp((input.Position.X - SliderBar.AbsolutePosition.X) / SliderBar.AbsoluteSize.X, 0, 1)
			updateSlider(sliderMin + pct * (sliderMax - sliderMin))
		end
	end)

	task.spawn(function()
		task.wait(0.1)
		if SliderBar and SliderBar.Parent then updateSlider(sliderDefault) end
	end)

	local tsData = {
		Type = "ToggleSlider", Name = name, Element = TSFrame,
		GetValue = function() return toggled, currentValue end,
		SetToggle = setToggle,
		SetSlider = updateSlider,
		SetLabel = function(newName) TitleLabel.Text = newName end,
		SetEnabled = function(state)
			-- allow it to be used as a dependent
			TogBg.Active = state
			SliderBar.Active = state
		end,
	}
	local configKey = name; local suffix = 2
	while self.ConfigData[configKey] do configKey = name .. "_" .. suffix; suffix = suffix + 1 end
	self.ConfigData[configKey] = tsData
	self:_attachTooltip(TSFrame, tooltip)
	return tsData
end

