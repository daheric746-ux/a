	AccentBar.BackgroundColor3 = Color3.fromRGB(51, 105, 255)
	AccentBar.BorderSizePixel = 0
	AccentBar.Position = UDim2.new(0, 0, 0.15, 0)
	AccentBar.Size = UDim2.new(0, 3, 0.7, 0)
	AccentBar.BackgroundTransparency = 1

