		item.MouseLeave:Connect(function() tween(item, { BackgroundColor3 = Color3.fromRGB(22,21,32) }, TI_FAST) end)
		item.MouseButton1Click:Connect(function()
			selected[opt] = not selected[opt]
			refreshItems()
			if configKey then saveConfig(configRegistry) end
			if onChange then
				local out = {}
				for _, o in ipairs(options) do if selected[o] then table.insert(out, o) end end
				onChange(out)
			end
		end)
	end

	clickBtn.MouseButton1Click:Connect(function()
		open = not open
		if open then
			positionList()
			tween(listClip, { Size = UDim2.new(0, W_WIDE, 0, openH) })
			tween(chevron,  { Rotation = 180 }, TI_NORM)
			tween(frame,    { BackgroundColor3 = Color3.fromRGB(24,23,34) }, TI_FAST)
			trackConn = RunService.RenderStepped:Connect(function()
				positionList()
				if not frame or not frame.Parent then
					if trackConn then trackConn:Disconnect(); trackConn = nil end
				end
			end)
		else
			tween(listClip, { Size = UDim2.new(0, W_WIDE, 0, 0) })
			tween(chevron,  { Rotation = 0 }, TI_NORM)
			tween(frame,    { BackgroundColor3 = BG_INPUT }, TI_FAST)
			if trackConn then trackConn:Disconnect(); trackConn = nil end
		end
	end)

	return function()
		local out = {}
		for _, opt in ipairs(options) do if selected[opt] then table.insert(out, opt) end end
		return out
	end, function(fn) onChange = fn end
end

local function fuzzyMatch(str, query)
	str   = str:lower()
	query = query:lower()
	if str:find(query, 1, true) then return true end
	local si = 1
	for qi = 1, #query do
		local qc = query:sub(qi, qi)
		local found = false
		while si <= #str do
			if str:sub(si, si) == qc then si += 1; found = true; break end
			si += 1
		end
		if not found then return false end
	end
	return true
end

local function buildRow(parent, titleText, descText, order, widgetDef, pageEntry, navEntry, tabName)
	local row = Instance.new("Frame")
	row.Size             = UDim2.new(1, 0, 0, ROW_H)
	row.BackgroundColor3 = BG_ROW
	row.BorderSizePixel  = 0
	row.LayoutOrder      = order
	row.ClipsDescendants = false
	row.Parent           = parent
	corner(row, 6)
	pad(row, 0, 0, IS_MOBILE and 14 or 18, IS_MOBILE and 14 or 18)

	local title = Instance.new("TextLabel")
	title.Size             = IS_MOBILE and UDim2.new(1, 0, 0, 20) or UDim2.new(0.5, -10, 0, 20)
	title.Position         = UDim2.new(0, 0, 0, IS_MOBILE and 10 or 12)
	title.BackgroundTransparency = 1
	title.Text             = tostring(titleText)
	title.TextColor3       = TEXT_MAIN
	title.TextSize         = IS_MOBILE and 14 or 15
	title.Font             = Enum.Font.GothamBold
	title.TextXAlignment   = Enum.TextXAlignment.Left
	title.TextTruncate     = Enum.TextTruncate.AtEnd
	title.ZIndex           = 2
	title.Parent           = row

	local desc = Instance.new("TextLabel")
	desc.Size             = IS_MOBILE and UDim2.new(1, 0, 0, 14) or UDim2.new(0.5, -10, 0, 14)
	desc.Position         = UDim2.new(0, 0, 0, IS_MOBILE and 32 or 34)
	desc.BackgroundTransparency = 1
	desc.Text             = tostring(descText)
	desc.TextColor3       = TEXT_MUTED
	desc.TextSize         = IS_MOBILE and 11 or 12
	desc.Font             = Enum.Font.Gotham
	desc.TextXAlignment   = Enum.TextXAlignment.Left
	desc.TextTruncate     = Enum.TextTruncate.AtEnd
	desc.ZIndex           = 2
	desc.Parent           = row

	local hoverZone = Instance.new("TextButton")
	hoverZone.Size                = UDim2.new(1, 0, 1, 0)
	hoverZone.BackgroundTransparency = 1
	hoverZone.Text                = ""
	hoverZone.ZIndex              = 1
	hoverZone.Parent              = row

	hoverZone.MouseEnter:Connect(function() tween(row, { BackgroundColor3 = Color3.fromRGB(18,17,26) }, TI_FAST) end)
	hoverZone.MouseLeave:Connect(function() tween(row, { BackgroundColor3 = BG_ROW }, TI_FAST) end)

	local configKey = (navEntry and navEntry.name or "") .. "_" .. tostring(titleText)

	local getter
	local toggleFn
	local toggleSetState
	local wt = widgetDef and widgetDef.type

	if wt == "toggle" then
		local g, fn, oc, setS = buildToggle(row, widgetDef.default, configKey)
		getter = g; toggleFn = fn; toggleSetState = setS
		if widgetDef.onChange then oc(widgetDef.onChange) end
	elseif wt == "slider" then
		local g, oc = buildSlider(row, widgetDef.min, widgetDef.max, widgetDef.default, configKey, widgetDef.step)
		getter = g
		if widgetDef.onChange then oc(widgetDef.onChange) end
	elseif wt == "dropdown" then
		local g, oc = buildDropdown(row, widgetDef.options, widgetDef.default, configKey)
		getter = g
		if widgetDef.onChange then oc(widgetDef.onChange) end
	elseif wt == "keybind" then
		getter = buildKeybind(row, widgetDef.default, configKey, widgetDef.onChange)
	elseif wt == "input" then
		getter = buildInput(row, widgetDef.default, configKey)
	elseif wt == "button" then
		getter = buildButton(row, widgetDef.icon, widgetDef.iconLibrary, widgetDef.callback)
	elseif wt == "colorpicker" then
		local g, oc = buildColorPicker(row, widgetDef.default, configKey)
		getter = g
		if widgetDef.onChange then oc(widgetDef.onChange) end
	elseif wt == "multiselect" then
		local g, oc = buildMultiSelect(row, widgetDef.options, widgetDef.defaults, configKey)
		getter = g
		if widgetDef.onChange then oc(widgetDef.onChange) end
	end

	if wt == "toggle" and toggleFn then
		hoverZone.MouseButton1Click:Connect(toggleFn)
	end

	if getter and configKey then
		configRegistry[configKey] = { getter = getter }
	end

	table.insert(featureRegistry, {
		title          = tostring(titleText),
		desc           = tostring(descText),
		row            = row,
		widgetDef      = widgetDef,
		page           = pageEntry,
		navEntry       = navEntry,
		tabName        = tabName,
		configKey      = configKey,
		getter         = getter,
		toggleFn       = toggleFn,
		toggleSetState = toggleSetState,
	})

	return row, getter
end

local searchActive       = false
local searchResultFrames = {}
local searchDebounce     = nil

local function clearSearchResults()
	for _, f in ipairs(searchResultFrames) do f:Destroy() end
	searchResultFrames = {}
end

local function mountLiveWidget(shell, feat)
	local def = feat.widgetDef
	if not def then return end
	local wt = def.type

	if wt == "toggle" then
		local startState = false
		if feat.getter then
			local ok, v = pcall(feat.getter); if ok then startState = v end
		end
		local g, doToggle, setOnChange = buildToggle(shell, startState, feat.configKey)
		setOnChange(function(newState)
			if feat.toggleSetState then
				feat.toggleSetState(newState)
			end
		end)
		return

	elseif wt == "slider" then
		local g, oc, setVal = buildSlider(shell, def.min, def.max, (feat.getter and select(2, pcall(feat.getter))) or def.default, feat.configKey, def.step)
		if def.onChange then oc(def.onChange) end
		return

	elseif wt == "dropdown" then
		local g, oc = buildDropdown(shell, def.options, (feat.getter and select(2, pcall(feat.getter))) or def.default, feat.configKey)
		if def.onChange then oc(def.onChange) end
		return

	elseif wt == "multiselect" then
		local g, oc = buildMultiSelect(shell, def.options, def.defaults, feat.configKey)
		if def.onChange then oc(def.onChange) end
		return

	elseif wt == "colorpicker" then
		local g, oc = buildColorPicker(shell, def.default, feat.configKey)
		if def.onChange then oc(def.onChange) end
		return

	elseif wt == "input" then
		buildInput(shell, (feat.getter and select(2, pcall(feat.getter))) or def.default, feat.configKey)
		return

	elseif wt == "keybind" then
		buildKeybind(shell, def.default, feat.configKey, def.onChange)
		return

	elseif wt == "button" then
		buildButton(shell, def.icon, def.iconLibrary, def.callback)
		return
	end
end

local function showSearchResults(query)
	clearSearchResults()
	local count = 0
	for _, feat in ipairs(featureRegistry) do
		if fuzzyMatch(feat.title, query) or fuzzyMatch(feat.desc, query) then
			count += 1
			local shell = Instance.new("Frame")
			shell.Size             = UDim2.new(1, 0, 0, ROW_H)
			shell.BackgroundColor3 = BG_ROW
			shell.BorderSizePixel  = 0
			shell.LayoutOrder      = count
			shell.ClipsDescendants = false
			shell.Parent           = searchResultsScroll
			corner(shell, 6)
			pad(shell, 0, 0, IS_MOBILE and 14 or 18, IS_MOBILE and 14 or 18)
			table.insert(searchResultFrames, shell)

			local tl = Instance.new("TextLabel")
			tl.Size             = IS_MOBILE and UDim2.new(1, 0, 0, 20) or UDim2.new(0.6, -10, 0, 20)
			tl.Position         = UDim2.new(0, 0, 0, IS_MOBILE and 10 or 12)
			tl.BackgroundTransparency = 1
			tl.Text             = feat.title
			tl.TextColor3       = TEXT_MAIN
			tl.TextSize         = IS_MOBILE and 14 or 15
			tl.Font             = Enum.Font.GothamBold
			tl.TextXAlignment   = Enum.TextXAlignment.Left
			tl.TextTruncate     = Enum.TextTruncate.AtEnd
			tl.ZIndex           = 2
			tl.Parent           = shell

			local dl = Instance.new("TextLabel")
			dl.Size             = IS_MOBILE and UDim2.new(1, 0, 0, 14) or UDim2.new(0.6, -10, 0, 14)
			dl.Position         = UDim2.new(0, 0, 0, IS_MOBILE and 32 or 34)
			dl.BackgroundTransparency = 1
			dl.Text             = feat.desc
			dl.TextColor3       = TEXT_MUTED
			dl.TextSize         = IS_MOBILE and 11 or 12
			dl.Font             = Enum.Font.Gotham
			dl.TextXAlignment   = Enum.TextXAlignment.Left
			dl.TextTruncate     = Enum.TextTruncate.AtEnd
			dl.ZIndex           = 2
			dl.Parent           = shell

			mountLiveWidget(shell, feat)

			local hoverZone = Instance.new("TextButton")
			hoverZone.Size                = UDim2.new(0.5, -10, 1, 0)
			hoverZone.BackgroundTransparency = 1
			hoverZone.Text                = ""
			hoverZone.ZIndex              = 1
			hoverZone.Parent              = shell
			hoverZone.MouseEnter:Connect(function() tween(shell, { BackgroundColor3 = Color3.fromRGB(18,17,26) }, TI_FAST) end)
			hoverZone.MouseLeave:Connect(function() tween(shell, { BackgroundColor3 = BG_ROW }, TI_FAST) end)
		end
	end

	if count == 0 then
		local noResult = Instance.new("TextLabel")
		noResult.Size             = UDim2.new(1, 0, 0, 40)
		noResult.BackgroundTransparency = 1
		noResult.Text             = 'No features match "' .. query .. '"'
		noResult.TextColor3       = TEXT_MUTED
		noResult.TextSize         = 12
		noResult.Font             = Enum.Font.Gotham
		noResult.TextXAlignment   = Enum.TextXAlignment.Center
		noResult.LayoutOrder      = 1
		noResult.Parent           = searchResultsScroll
		table.insert(searchResultFrames, noResult)
	end
end

SearchInput:GetPropertyChangedSignal("Text"):Connect(function()
	local q = SearchInput.Text

	if q == "" then
		if searchDebounce then task.cancel(searchDebounce); searchDebounce = nil end
		if searchActive then
			searchActive = false
			searchResultsClip.Visible = false
			clearSearchResults()
			if activeNavBtn and activeNavBtn.page then activeNavBtn.page.clip.Visible = true end
			HeaderTitle.Text    = activeNavBtn and activeNavBtn.title    or ""
			HeaderSubtitle.Text = activeNavBtn and activeNavBtn.subtitle or ""
			TabBar.Visible      = activeNavBtn and (activeNavBtn.tabs ~= nil) or false
			TabsDivider.Visible = TabBar.Visible
		end
		for _, entry in ipairs(navButtons) do entry.btn.Visible = true end
		return
	end

	if not searchActive then
		searchActive = true
		for _, p in ipairs(pages) do p.clip.Visible = false end
		TabBar.Visible = false
		TabsDivider.Visible = false
	end

	HeaderTitle.Text    = "Search Results"
	HeaderSubtitle.Text = 'Showing results for "' .. q .. '"'
	searchResultsClip.Visible = true

	if searchDebounce then task.cancel(searchDebounce); searchDebounce = nil end
	searchDebounce = task.delay(0.15, function()
		showSearchResults(q)
		local ql = q:lower()
		for _, entry in ipairs(navButtons) do
			entry.btn.Visible = fuzzyMatch(entry.name, ql)
		end
	end)
end)

