	AccentCorner.Parent = AccentBar

	TabButton.MouseButton1Click:Connect(function()
		self:SwitchTab(tabName)
	end)

	self.Tabs[tabName] = {
		Frame = Tab,
		Category = categoryName,
		Cards = {},
	}

	if categoryName and self.Categories[categoryName] then
		table.insert(self.Categories[categoryName].Tabs, tabName)
	end

	if not self.CurrentTab then
		task.defer(function()
			self:SwitchTab(tabName)
		end)
	end

	return tabName
end

function SpareStackLib:SwitchTab(tabName)
	self.CurrentTab = tabName
	self.SettingsMode = false
	self.SearchBox.Text = ""

	local tabTweenInfo = TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

	-- Update tab highlight + accent bar
	for name, tab in pairs(self.Tabs) do
		local accentBar = tab.Frame:FindFirstChild("AccentBar")
		if name == tabName then
			TweenService:Create(tab.Frame, tabTweenInfo, {
				BackgroundTransparency = 0,
				BackgroundColor3 = Color3.fromRGB(20, 20, 27),
			}):Play()
			if accentBar then
				TweenService:Create(accentBar, tabTweenInfo, { BackgroundTransparency = 0 }):Play()
			end
		else
			TweenService:Create(tab.Frame, tabTweenInfo, {
				BackgroundTransparency = 1,
			}):Play()
			if accentBar then
				TweenService:Create(accentBar, tabTweenInfo, { BackgroundTransparency = 1 }):Play()
			end
		end
	end

	-- Overlay sits on Background (not CardHolder) so UIGridLayout ignores it
	local overlay = self.Background:FindFirstChild("_FadeOverlay")
	if not overlay then
		overlay = Instance.new("Frame")
		overlay.Name = "_FadeOverlay"
		overlay.Parent = self.Background
		overlay.BackgroundColor3 = Color3.fromRGB(12, 12, 16)
		overlay.BorderSizePixel = 0
		overlay.Position = UDim2.new(0.23, 0, 0.12, 0)
		overlay.Size = UDim2.new(0, 745, 0, 520)
		overlay.ZIndex = 50
		overlay.BackgroundTransparency = 1
		overlay.Active = false
	end

	-- Fade overlay in over the card area
	overlay.BackgroundTransparency = 1
	TweenService:Create(overlay, TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		BackgroundTransparency = 0,
	}):Play()

	task.wait(0.13)

	-- Swap cards while hidden behind overlay
	for _, card in pairs(self.SettingsCards) do
		card.Visible = false
	end

	local visibleCards = {}
	for _, card in pairs(self.AllCards) do
		if card:GetAttribute("Tab") == tabName then
			card.Visible = true
			card.LayoutOrder = card:GetAttribute("OriginalOrder")
			card.BackgroundTransparency = 1
			table.insert(visibleCards, card)
		else
			card.Visible = false
		end
	end

	self.CardHolder.CanvasPosition = Vector2.new(0, 0)

	-- Fade overlay back out
	TweenService:Create(overlay, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		BackgroundTransparency = 1,
	}):Play()

	-- Animate cards in with staggered fade
	task.spawn(function()
		table.sort(visibleCards, function(a,b) return a.LayoutOrder < b.LayoutOrder end)
		for i, card in ipairs(visibleCards) do
			task.delay((i - 1) * 0.04, function()
				if card and card.Parent then
					TweenService:Create(card, TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
						BackgroundTransparency = 1,
					}):Play()
					-- fade in the card background image child
					local bg = card:FindFirstChild("Background")
					if bg then
						bg.ImageTransparency = 1
						TweenService:Create(bg, TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
							ImageTransparency = 0,
						}):Play()
					end
					local placard = card:FindFirstChild("Placard")
					if placard then
						placard.ImageTransparency = 1
						TweenService:Create(placard, TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
							ImageTransparency = 0,
						}):Play()
					end
				end
			end)
		end
	end)
end

