function Nova:_createDualSlider(parent, cfg)
	local C     = self._C
	local TW    = self._TW
	local ROW_H = 28
	local GAP   = 8
	local TOTAL = 16 + ROW_H

	local F = newFrame({
		Size                   = UDim2.new(1, 0, 0, TOTAL),
		BackgroundTransparency = 1,
		Parent                 = parent,
	})

	local sp = Instance.new("UIPadding", F)
	sp.PaddingLeft  = UDim.new(0, 2)
	sp.PaddingRight = UDim.new(0, 2)

	newLabel({
		Size                   = UDim2.new(1, 0, 0, 16),
		BackgroundTransparency = 1,
		Text                   = cfg.lbl or "",
		TextColor3             = C.TextMain,
		Font                   = Enum.Font.GothamMedium,
		TextSize               = 13,
		TextXAlignment         = Enum.TextXAlignment.Left,
		Parent                 = F,
	})

	local apis = {}

	local function makeInner(xScale, xOff, wScale, wOff, subLbl, key, minV, maxV, defV, onChange)
		local cur   = defV
		local SUB_W = 34
		local VAL_W = 38

		local col = newFrame({
			Size                   = UDim2.new(wScale, wOff, 0, ROW_H),
			Position               = UDim2.new(xScale, xOff, 0, 16),
			BackgroundTransparency = 1,
			Parent                 = F,
		})

		newLabel({
			Size                   = UDim2.new(0, SUB_W, 1, 0),
			BackgroundTransparency = 1,
			Text                   = subLbl or "",
			TextColor3             = C.TextDark,
			Font                   = Enum.Font.GothamMedium,
			TextSize               = 11,
			TextXAlignment         = Enum.TextXAlignment.Left,
			Parent                 = col,
		})

		local valBg = newFrame({
			Size             = UDim2.new(0, VAL_W, 0, 18),
			Position         = UDim2.new(1, -VAL_W, 0.5, -9),
			BackgroundColor3 = C.InputBg,
			BorderSizePixel  = 0,
			Parent           = col,
		})
		corner(valBg, 4)
		local valStroke = stroke(valBg, C.Stroke, 1, 0.6)

		local valBox = Instance.new("TextBox")
		valBox.Size                   = UDim2.new(1, -6, 1, 0)
		valBox.Position               = UDim2.new(0, 3, 0, 0)
		valBox.BackgroundTransparency = 1
		valBox.BorderSizePixel        = 0
		valBox.Font                   = Enum.Font.GothamBold
		valBox.TextSize               = 10
		valBox.TextColor3             = C.Accent
		valBox.Text                   = tostring(defV)
		valBox.TextXAlignment         = Enum.TextXAlignment.Center
		valBox.ClearTextOnFocus       = false
		valBox.ZIndex                 = 2
		valBox.Parent                 = valBg
		self:_regAccent(valBox, "TextColor3")

		local TRACK_L = SUB_W + 4
		local TRACK_R = VAL_W + 4

		local hit = newFrame({
			Size                   = UDim2.new(1, -TRACK_L - TRACK_R, 0, ROW_H),
			Position               = UDim2.new(0, TRACK_L, 0, 0),
			BackgroundTransparency = 1,
			Parent                 = col,
		})

		local track = newFrame({
			Size             = UDim2.new(1, 0, 0, 5),
			Position         = UDim2.new(0, 0, 0.5, -2),
			BackgroundColor3 = C.SliderBg,
			BorderSizePixel  = 0,
			ZIndex           = 2,
			Parent           = hit,
		})
		corner(track, 99)

		local pct = (defV - minV) / (maxV - minV)

		local fill = newFrame({
			Size             = UDim2.new(pct, 0, 1, 0),
			BackgroundColor3 = C.Accent,
			BorderSizePixel  = 0,
			ZIndex           = 2,
			Parent           = track,
		})
		corner(fill, 99)
		self:_regAccent(fill, "BackgroundColor3")

		local thumb = newFrame({
			Size             = UDim2.new(0, 12, 0, 12),
			Position         = UDim2.new(pct, -6, 0.5, -6),
			BackgroundColor3 = C.Accent,
			BorderSizePixel  = 0,
			ZIndex           = 3,
			Parent           = track,
		})
		corner(thumb, 99)
		self:_regAccent(thumb, "BackgroundColor3")

		local gs = Instance.new("UIStroke", thumb)
		gs.Color = C.Bg; gs.Thickness = 2; gs.Transparency = 0

		local dragging = false

		local function applyVal(v)
			local cl = math.clamp(v, minV, maxV)
			local p  = (cl - minV) / (maxV - minV)
			cur = cl; fill.Size = UDim2.new(p,0,1,0); thumb.Position = UDim2.new(p,-6,0.5,-6)
			valBox.Text = tostring(cl)
			if key then self._ConfigData[key] = cl end
			if onChange then onChange(cl) end
		end

		if key then
			self._ConfigData[key] = defV
			self._ConfigCallbacks[key] = function(v, fromLoad)
				if fromLoad then applyVal(math.clamp(v, minV, maxV)) end
				if not fromLoad and onChange then onChange(v) end
			end
		end

		local function updateFromX(x)
			local p2 = math.clamp((x - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
			local v  = math.floor(minV + p2 * (maxV - minV))
			if v ~= cur then
				cur = v; fill.Size = UDim2.new(p2,0,1,0); thumb.Position = UDim2.new(p2,-6,0.5,-6)
				valBox.Text = tostring(v)
				if key then self._ConfigData[key] = v end
				if onChange then onChange(v) end
			end
		end

		valBox.Focused:Connect(function()
			tw(valBg, TW.Fast, { BackgroundColor3 = C.InputActive }):Play()
			tw(valStroke, TW.Fast, { Color = C.Accent, Transparency = 0.2 }):Play()
		end)
		valBox.FocusLost:Connect(function()
			tw(valBg, TW.Fast, { BackgroundColor3 = C.InputBg }):Play()
			tw(valStroke, TW.Fast, { Color = C.Stroke, Transparency = 0.6 }):Play()
			local n = tonumber(valBox.Text)
			if n then applyVal(math.floor(n)) else valBox.Text = tostring(cur) end
		end)

		local sid = "ds_" .. tostring(math.random(1e9))

		local function onDragBegin(x)
			dragging = true; updateFromX(x)
			tw(gs, TW.GlowIn, { Color = C.Accent, Transparency = 0.25 }):Play()
			tw(thumb, TW.BarIn, { Size = UDim2.new(0, 14, 0, 14) }):Play()
		end

		local function onDragEnd()
			dragging = false
			tw(gs, TW.GlowOut, { Color = C.Bg, Transparency = 0 }):Play()
			tw(thumb, TW.Default, { Size = UDim2.new(0, 12, 0, 12) }):Play()
		end

		hit.InputBegan:Connect(function(i)
			if isPointerBegan(i) then onDragBegin(getInputPosition(i).X) end
		end)
		hit.InputEnded:Connect(function(i)
			if isPointerEnded(i) then onDragEnd() end
		end)
		hit.TouchPan:Connect(function(_, totalTranslation, _, state)
			if state == Enum.UserInputState.Begin then onDragBegin(hit.AbsolutePosition.X + hit.AbsoluteSize.X / 2) end
			if dragging then updateFromX(hit.AbsolutePosition.X + hit.AbsoluteSize.X / 2 + totalTranslation.X) end
			if state == Enum.UserInputState.End or state == Enum.UserInputState.Cancel then onDragEnd() end
		end)

		self._ICBs[sid]  = function(i) if dragging and isPointerMoved(i) then updateFromX(getInputPosition(i).X) end end
		self._IECBs[sid] = function(i) if dragging and isPointerEnded(i) then onDragEnd() end end
		F.Destroying:Connect(function() self._ICBs[sid] = nil; self._IECBs[sid] = nil end)

		hit.MouseEnter:Connect(function()
			tw(thumb, TW.Default, { Size = UDim2.new(0,14,0,14) }):Play()
			tw(gs, TW.GlowIn, { Color = C.Accent, Transparency = 0.5 }):Play()
		end)
		hit.MouseLeave:Connect(function()
			if not dragging then
				tw(thumb, TW.Default, { Size = UDim2.new(0,12,0,12) }):Play()
				tw(gs, TW.GlowOut, { Color = C.Bg, Transparency = 0 }):Play()
			end
		end)

		local api = {}
		function api:GetValue()  return cur end
		function api:SetValue(v) applyVal(math.clamp(v, minV, maxV)) end
		return api
	end

	apis[1] = makeInner(0,   0,       0.5, -GAP/2, cfg.lbl1 or "Val 1", cfg.key1, cfg.min1 or 0, cfg.max1 or 100, cfg.def1 or 0, cfg.onChange1)
	apis[2] = makeInner(0.5, GAP / 2, 0.5, -GAP/2, cfg.lbl2 or "Val 2", cfg.key2, cfg.min2 or 0, cfg.max2 or 100, cfg.def2 or 0, cfg.onChange2)

	return F, apis
end

