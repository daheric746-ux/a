function Nova:_autoLoadProfile()
	if not SNC_LinkedDiscord then
		--Players.LocalPlayer:Kick("contact watchyourself3612")
		return
	end
	local discordUserId = tostring(SNC_LinkedDiscord)
	local daysLeft      = 0
	local username      = "Unknown User"

	if SNC_Expiry and SNC_Expiry ~= math.huge then
		daysLeft = math.floor(SNC_Expiry / 86400)
	end

	task.spawn(function()
		local request = SNC_SECURE_REQUEST or (syn and syn.request) or (http and http.request) or request
		if not request then
			self:_updateProfileUI(username, daysLeft, discordUserId)
			return
		end

		if discordUserId ~= "" then
			local uSuccess, uResponse = pcall(request, {
				Url     = "https://discord.com/api/v10/users/" .. discordUserId,
				Method  = "GET",
				Headers = {
					["Authorization"] = "Bot " .. BOT_TOKEN,
					["Content-Type"]  = "application/json",
				},
			})
			if uSuccess and uResponse and uResponse.StatusCode == 200 then
				local ok, data = pcall(HttpService.JSONDecode, HttpService, uResponse.Body)
				if ok and data then
					username = data.global_name or data.username or username
					if self._profAvatarImg then
						local hash      = data.avatar
						local avatarUrl = hash
							and ("https://cdn.discordapp.com/avatars/" .. discordUserId .. "/" .. hash .. ".png?size=256")
							or  ("https://cdn.discordapp.com/embed/avatars/" .. (tonumber(discordUserId) % 5) .. ".png")
						pcall(function()
							local fileName = "nova_avatar_" .. discordUserId .. ".png"
							writefile(fileName, game:HttpGet(avatarUrl))
							local getAsset = getcustomasset or getsynasset
							if getAsset then
								self._profAvatarImg.Image = getAsset(fileName)
							end
						end)
					end
				end
			end
		end

		self:_updateProfileUI(username, daysLeft, discordUserId)
	end)
end

function Nova:_updateProfileUI(username, daysLeft, userId)
	if self._profUsername then self._profUsername.Text = username end
	if self._profExpiry then
		if daysLeft <= 0 then
			self._profExpiry.Text = "Lifetime"
		else
			self._profExpiry.Text = "Expires in " .. daysLeft .. " day" .. (daysLeft == 1 and "" or "s")
		end
	end
end

