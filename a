	})
	makeInst("UICorner", { Parent = Open, CornerRadius = UDim.new(1, 0) })

	local HintLabel = makeInst("TextLabel", {
		Name                   = "HintLabel",
		Position               = UDim2.new(-1.240, 0, 1.200, 0),
		Size                   = UDim2.new(0, 174, 0, 25),
		BackgroundTransparency = 1,
		Font                   = Enum.Font.GothamBold,
		Text                   = "Double tap to lock",
		TextXAlignment         = Enum.TextXAlignment.Center,
		TextYAlignment         = Enum.TextYAlignment.Center,
		TextColor3             = Color3.fromRGB(255, 255, 255),
		BackgroundColor3       = Color3.fromRGB(255, 255, 255),
		TextSize               = 14,
		BorderSizePixel        = 0,
		ZIndex                 = 501,
		Parent                 = Open,
	})

	makeInst("UIStroke", {
		Parent       = Open,
		Color        = Color3.fromRGB(108, 59, 170),
		Thickness    = 3,
		LineJoinMode = Enum.LineJoinMode.Round,
		Transparency = 0.8,
	})

	makeInst("UIStroke", {
		Parent       = Open,
		Color        = Color3.fromRGB(108, 59, 170),
		Thickness    = 1,
		LineJoinMode = Enum.LineJoinMode.Round,
		Transparency = 0.3,
	})

	local locked       = false
	local dragging     = false
	local dragStartPos = nil
	local btnStartPos  = nil
	local lastTapTime  = 0
	local hasMoved     = false

	local DOUBLE_TAP_THRESHOLD = 0.35
	local DRAG_THRESHOLD       = 6

	Open.InputBegan:Connect(function(input)
		if input.UserInputType ~= Enum.UserInputType.Touch
			and input.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
		if locked then return end
		dragging     = true
		hasMoved     = false
		dragStartPos = input.Position
		btnStartPos  = Open.Position
	end)

	local moveConn = UIS.InputChanged:Connect(function(input)
		if not dragging then return end
		if input.UserInputType ~= Enum.UserInputType.Touch
			and input.UserInputType ~= Enum.UserInputType.MouseMovement then return end

		local delta = input.Position - dragStartPos

		if math.abs(delta.X) > DRAG_THRESHOLD or math.abs(delta.Y) > DRAG_THRESHOLD then
			hasMoved = true
		end

		if hasMoved then
			local gsz = Gui.AbsoluteSize
			local bsz = Open.AbsoluteSize
			local newX = btnStartPos.X.Scale * gsz.X + btnStartPos.X.Offset + delta.X
			local newY = btnStartPos.Y.Scale * gsz.Y + btnStartPos.Y.Offset + delta.Y
			newX = math.clamp(newX, bsz.X * 0.5, gsz.X - bsz.X * 0.5)
			newY = math.clamp(newY, bsz.Y * 0.5, gsz.Y - bsz.Y * 0.5)
			Open.Position    = UDim2.fromOffset(newX, newY)
			Open.AnchorPoint = Vector2.new(0.5, 0.5)
		end
	end)

	local endConn = UIS.InputEnded:Connect(function(input)
		if input.UserInputType ~= Enum.UserInputType.Touch
			and input.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
		dragging = false
	end)

	Open.Activated:Connect(function()
		if hasMoved then hasMoved = false; return end

		local now = tick()
		local dt  = now - lastTapTime

		if dt < DOUBLE_TAP_THRESHOLD then
			locked = not locked
			if locked then
				HintLabel.Text = "🔒 Locked"
				TweenService:Create(Open, TweenInfo.new(0.25, Enum.EasingStyle.Quint), {
					ImageColor3      = Color3.fromRGB(108, 59, 170),
					BackgroundColor3 = Color3.fromRGB(20, 10, 35),
				}):Play()
			else
				HintLabel.Text = "Double tap to lock"
				TweenService:Create(Open, TweenInfo.new(0.25, Enum.EasingStyle.Quint), {
					ImageColor3      = Color3.fromRGB(255, 255, 255),
					BackgroundColor3 = Color3.fromRGB(0, 0, 0),
				}):Play()
			end
			lastTapTime = 0
		else
			lastTapTime = now
			if self._Gui.Enabled then
				self:Hide()
				TweenService:Create(Open, TweenInfo.new(0.18, Enum.EasingStyle.Quint), { BackgroundTransparency = 0.35 }):Play()
			else
				self:Show()
				TweenService:Create(Open, TweenInfo.new(0.18, Enum.EasingStyle.Quint), { BackgroundTransparency = 0 }):Play()
			end
		end
	end)

	task.spawn(function()
		while Open and Open.Parent do
			if not self._Gui.Enabled then
				TweenService:Create(Open, TweenInfo.new(0.7, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), { BackgroundTransparency = 0.55 }):Play()
				task.wait(0.7)
				TweenService:Create(Open, TweenInfo.new(0.7, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), { BackgroundTransparency = 0.2 }):Play()
				task.wait(0.7)
			else
				task.wait(0.5)
			end
		end
	end)

	Gui.Destroying:Connect(function()
		pcall(function() moveConn:Disconnect() end)
		pcall(function() endConn:Disconnect() end)
	end)

	self._MobileToggleBtn = Open
end

function Nova:_setupDrag(Main)
	local dragging  = false
	local dragStart = nil
	local startPos  = nil

	local function onMove(pos)
		if not dragging then return end
		local d = pos - dragStart
		Main.Position = UDim2.new(
			startPos.X.Scale, startPos.X.Offset + d.X,
			startPos.Y.Scale, startPos.Y.Offset + d.Y
		)
	end

	local function onBegin(pos)
		dragging  = true
		dragStart = pos
		startPos  = Main.Position
	end

	local function onEnd() dragging = false end

	if self._dragStyle == 2 then
		UIS.InputBegan:Connect(function(i, proc)
			if proc then return end
			if not isPointerBegan(i) then return end
			local pos = getInputPosition(i)
			local mp  = Main.AbsolutePosition
			local ms  = Main.AbsoluteSize
			if pos.X < mp.X or pos.X > mp.X + ms.X or pos.Y < mp.Y or pos.Y > mp.Y + ms.Y then return end
			local ok, hits = pcall(function() return CoreGui:GetGuiObjectsAtPosition(pos.X, pos.Y) end)
			if ok and hits then
				for _, obj in ipairs(hits) do
					if obj:IsA("TextButton") or obj:IsA("TextBox") or obj:IsA("ImageButton") or obj:IsA("ScrollingFrame") then return end
				end
			end
			onBegin(pos)
			i.Changed:Connect(function()
				if i.UserInputState == Enum.UserInputState.End then onEnd() end
			end)
		end)
	else
		local dragHandle = newFrame({
			Size                   = UDim2.new(1, -180, 0, 50),
			Position               = UDim2.new(0, 180, 0, 0),
			BackgroundTransparency = 1,
			ZIndex                 = 10,
			Parent                 = Main,
		})
		dragHandle.InputBegan:Connect(function(i)
			if not isPointerBegan(i) then return end
			onBegin(getInputPosition(i))
			i.Changed:Connect(function()
				if i.UserInputState == Enum.UserInputState.End then onEnd() end
			end)
		end)
	end

	self._ICBs["drag"] = function(i)
		if dragging and isPointerMoved(i) then onMove(getInputPosition(i)) end
	end

	self._IECBs["drag"] = function(i)
		if isPointerEnded(i) then onEnd() end
	end
end

