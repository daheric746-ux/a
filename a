-- // accent tint helpers — keeps hover colors relative to the current accent
local function accentHover(c3)
	local h, s, v = Color3.toHSV(c3)
	return Color3.fromHSV(h, math.max(0, s - 0.05), math.min(1, v + 0.08))
end

local function accentPress(c3)
	local h, s, v = Color3.toHSV(c3)
	return Color3.fromHSV(h, math.min(1, s + 0.05), math.max(0, v - 0.1))
end

local NOVA_FOLDER = "Nova"

local function _ensureFolder()
	if not isfolder(NOVA_FOLDER) then makefolder(NOVA_FOLDER) end
end

local function _cfgPath(name)
	return NOVA_FOLDER .. "/" .. name .. ".json"
end

local function _listConfigs()
	_ensureFolder()
	local out = {}
	for _, f in ipairs(listfiles(NOVA_FOLDER)) do
		local n = f:match("[\\/]([^\\/]+)%.json$")
		if n then out[#out + 1] = n end
	end
	return out
end

local function _saveConfig(name, data)
	_ensureFolder()
	writefile(_cfgPath(name), HttpService:JSONEncode(data))
end

local function _loadConfig(name)
	local path = _cfgPath(name)
	if not isfile(path) then return nil end
	local ok, t = pcall(function() return HttpService:JSONDecode(readfile(path)) end)
	return ok and t or nil
end

local function _deleteConfig(name)
	local path = _cfgPath(name)
	if isfile(path) then delfile(path); return true end
	return false
end

local Nova = {}
Nova.__index = Nova

function Nova.new(cfg)
	cfg = cfg or {}
	local self = setmetatable({}, Nova)

	self._C  = defaultColors()
	self._TW = defaultTweens()

	if cfg.accentColor then
		self._C.Accent     = cfg.accentColor
		self._C.BtnPrimary = cfg.accentColor
		self._C.ActiveHl   = cfg.accentColor
	end

	local screenW  = workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize.X or 800
	local screenH  = workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize.Y or 600
	local isMobile = screenW < 600 or screenH < 500

	local targetW = cfg.size and cfg.size[1] or DEFAULT_W
	local targetH = cfg.size and cfg.size[2] or DEFAULT_H

	if isMobile then
		local scaleX = (screenW - 20) / targetW
		local scaleY = (screenH - 20) / targetH
		local scale  = math.min(scaleX, scaleY, 1)
		targetW = math.floor(targetW * scale)
		targetH = math.floor(targetH * scale)
	end

	self._W        = targetW
	self._H        = targetH
	self._isMobile = isMobile

	self._dragStyle       = cfg.dragStyle or 1
	self._pages           = {}
	self._closeCallbacks  = {}
	self._accentCBs       = {}
	self._ICBs            = {}
	self._IECBs           = {}
	self._activePageIdx   = nil
	self._activeTabIdx    = {}
	self._scrollMemory    = {}
	self._pageCache       = {}
	self._activePopup     = nil
	self._activeDrop      = nil
	self._sideActs        = {}
	self._ConfigData      = {}
	self._ConfigCallbacks = {}
	self._accentObjects   = {}

	self:_buildGui(cfg.guiName or "NovaLib_Window")
	self:_buildMobileToggle()
	return self
end

function Nova:_regAccent(obj, prop)
	table.insert(self._accentObjects, { obj = obj, prop = prop })
end

function Nova:_regConfig(key, defaultVal, applyFn)
	if not key then return end
	if self._ConfigData[key] == nil then self._ConfigData[key] = defaultVal end
	self._ConfigCallbacks[key] = applyFn
end

function Nova:_setConfig(key, value)
	if not key then return end
	self._ConfigData[key] = value
	local cb = self._ConfigCallbacks[key]
	if cb then pcall(cb, value, false) end
end

