local function sizeMainFrame()
	local cam = workspace.CurrentCamera
	local actualVp = cam and cam.ViewportSize or Vector2.new(1280, 720)
	local vp = MOBILE_PREVIEW_ON_PC and MOBILE_PREVIEW_SIZE or actualVp
	if IS_MOBILE then
		local maxH = vp.X < vp.Y and 760 or 560
		local w = math.min(math.clamp(vp.X * 0.96, 260, 780), actualVp.X - 16)
		local h = math.min(math.clamp(vp.Y * 0.90, 280, maxH), actualVp.Y - 16)
		MainFrame.Size     = UDim2.new(0, w, 0, h)
		MainFrame.Position = UDim2.new(0.5, -w/2, 0.5, -h/2)
	else
		MainFrame.Size     = UDim2.new(0, 860, 0, 540)
		MainFrame.Position = UDim2.new(0.5, -430, 0.5, -270)
	end
end
sizeMainFrame()

do
	local cam = workspace.CurrentCamera
	if cam then
		cam:GetPropertyChangedSignal("ViewportSize"):Connect(sizeMainFrame)
	end
end

do
	local dragging = false
	local dragStart, startAbs, activePointer

	local dragBar = Instance.new("Frame")
	dragBar.Name                = "DragBar"
	dragBar.Size                = UDim2.new(1, -SIDEBAR_W, 0, 60)
	dragBar.Position            = UDim2.new(0, SIDEBAR_W, 0, 0)
	dragBar.BackgroundTransparency = 1
	dragBar.ZIndex              = 0
	dragBar.Parent              = MainFrame

	dragBar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.Touch then
			dragging  = true
			dragStart = input.Position
			startAbs   = MainFrame.AbsolutePosition
			activePointer = input
		end
	end)

	onPointerMove(function(x, y, input)
		if not dragging then return end
		if activePointer.UserInputType == Enum.UserInputType.Touch and input ~= activePointer then return end
		local delta = Vector2.new(x, y) - Vector2.new(dragStart.X, dragStart.Y)
		local cam = workspace.CurrentCamera
		local vp = cam and cam.ViewportSize or Vector2.new(1280, 720)
		local size = MainFrame.AbsoluteSize
		local nx = math.clamp(startAbs.X + delta.X, 8, math.max(8, vp.X - size.X - 8))
		local ny = math.clamp(startAbs.Y + delta.Y, 8, math.max(8, vp.Y - size.Y - 8))
		MainFrame.Position = UDim2.fromOffset(nx, ny)
	end)
	onPointerEnd(function(input)
		if activePointer and activePointer.UserInputType == Enum.UserInputType.Touch and input ~= activePointer then return end
		dragging = false
		activePointer = nil
	end)
end

