	popupStroke.Thickness = 1
	popupStroke.Parent = popup

	local inner = Instance.new("Frame")
	inner.Size = UDim2.new(1, -20, 1, -16)
	inner.Position = UDim2.new(0, 10, 0, 8)
	inner.BackgroundTransparency = 1
	inner.ZIndex = 51
	inner.Parent = popup

	-- ── HSV wheel image ───────────────────────────────────────────────────────
	local DISC_SIZE = 180
	local DISC_R    = DISC_SIZE / 2

	local discContainer = Instance.new("Frame")
	discContainer.Size = UDim2.new(0, DISC_SIZE, 0, DISC_SIZE)
	discContainer.Position = UDim2.new(0.5, -DISC_R, 0, 0)
	discContainer.BackgroundTransparency = 1
	discContainer.BorderSizePixel = 0
	discContainer.ClipsDescendants = false
	discContainer.ZIndex = 51
	discContainer.Parent = inner

	-- Wheel image (public HSV wheel asset)
	local discImage = Instance.new("ImageLabel")
	discImage.Size = UDim2.new(1, 0, 1, 0)
	discImage.BackgroundTransparency = 1
	discImage.Image = "rbxassetid://1003599924"
	discImage.ZIndex = 52
	discImage.Parent = discContainer

	-- Value darkening overlay — black frame, transparency = v
	local valOverlay = Instance.new("Frame")
	valOverlay.Size = UDim2.new(1, 0, 1, 0)
	valOverlay.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
	valOverlay.BackgroundTransparency = v
	valOverlay.BorderSizePixel = 0
	valOverlay.ZIndex = 53
	valOverlay.Parent = discContainer
	corner(valOverlay, DISC_R)

	-- Knob
	local discKnob = Instance.new("Frame")
	discKnob.AnchorPoint = Vector2.new(0.5, 0.5)
	discKnob.Size = UDim2.new(0, 14, 0, 14)
	discKnob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	discKnob.BorderSizePixel = 0
	discKnob.ZIndex = 56
	discKnob.Parent = discContainer
	corner(discKnob, 7)

	local discKnobStroke = Instance.new("UIStroke")
	discKnobStroke.Color = Color3.fromRGB(0, 0, 0)
	discKnobStroke.Transparency = 0.45
	discKnobStroke.Thickness = 1.5
	discKnobStroke.Parent = discKnob

	local discHit = Instance.new("TextButton")
	discHit.Size = UDim2.new(1, 0, 1, 0)
	discHit.BackgroundTransparency = 1
	discHit.Text = ""
	discHit.ZIndex = 57
	discHit.Parent = discContainer

	-- ── Slider helper ─────────────────────────────────────────────────────────
	local function makeSliderRow(yPos, labelText)
		local holder = Instance.new("Frame")
		holder.Size = UDim2.new(1, 0, 0, 22)
		holder.Position = UDim2.new(0, 0, 0, yPos)
		holder.BackgroundTransparency = 1
		holder.ZIndex = 51
		holder.Parent = inner

		local lbl = Instance.new("TextLabel")
		lbl.Size = UDim2.new(0, 38, 1, 0)
		lbl.BackgroundTransparency = 1
		lbl.Text = labelText
		lbl.TextColor3 = TEXT_MUTED
		lbl.TextSize = 11
		lbl.Font = Enum.Font.GothamBold
		lbl.TextXAlignment = Enum.TextXAlignment.Left
		lbl.ZIndex = 52
		lbl.Parent = holder

		local track = Instance.new("Frame")
		track.Size = UDim2.new(1, -42, 0, 8)
		track.Position = UDim2.new(0, 42, 0.5, -4)
		track.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
		track.BackgroundTransparency = 0.88
		track.BorderSizePixel = 0
		track.ZIndex = 52
		track.Parent = holder
		corner(track, 4)

		local grad = Instance.new("UIGradient")
		grad.Parent = track

		local knob = Instance.new("Frame")
		knob.AnchorPoint = Vector2.new(0.5, 0.5)
		knob.Size = UDim2.new(0, 14, 0, 14)
		knob.Position = UDim2.new(0, 0, 0.5, 0)
		knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
		knob.BorderSizePixel = 0
		knob.ZIndex = 54
		knob.Parent = track
		corner(knob, 7)

		local ks = Instance.new("UIStroke")
		ks.Color = Color3.fromRGB(0, 0, 0)
		ks.Transparency = 0.55
		ks.Thickness = 1.5
		ks.Parent = knob

		local hit = Instance.new("TextButton")
		hit.Size = UDim2.new(1, 16, 1, 16)
		hit.Position = UDim2.new(0, -8, 0.5, -8)
		hit.BackgroundTransparency = 1
		hit.Text = ""
		hit.ZIndex = 55
		hit.Parent = track

		return { track = track, grad = grad, knob = knob, hit = hit }
	end

	local VAL_Y = DISC_SIZE + 12
	local ALP_Y = VAL_Y + 30
	local valS = makeSliderRow(VAL_Y, "Val")
	local alpS = makeSliderRow(ALP_Y, "Alpha")

	-- ── Hex input ─────────────────────────────────────────────────────────────
	local HEX_Y = ALP_Y + 34
	local inputBox = Instance.new("TextBox")
	inputBox.Size = UDim2.new(1, 0, 0, 26)
	inputBox.Position = UDim2.new(0, 0, 0, HEX_Y)
	inputBox.BackgroundColor3 = Color3.fromRGB(23, 22, 34)
	inputBox.BorderSizePixel = 0
	inputBox.Text = ""
	inputBox.PlaceholderText = "hex or r, g, b"
	inputBox.PlaceholderColor3 = TEXT_MUTED
	inputBox.TextColor3 = TEXT_MAIN
	inputBox.TextSize = 11
	inputBox.Font = Enum.Font.Gotham
	inputBox.TextXAlignment = Enum.TextXAlignment.Center
	inputBox.ClearTextOnFocus = false
	inputBox.ZIndex = 52
	inputBox.Parent = inner
	corner(inputBox, 6)

	-- ── Refresh ───────────────────────────────────────────────────────────────
	local function refresh()
		local col = Color3.fromHSV(h, s, v)
		currentColor = col
		swatch.BackgroundColor3 = col

		-- knob pixel position on disc
		local ang = h * math.pi * 2
		local px = DISC_R + math.cos(ang) * s * DISC_R
		local py = DISC_R + math.sin(ang) * s * DISC_R
		discKnob.Position = UDim2.new(0, px, 0, py)

		-- value overlay: v=1 fully transparent (bright), v=0 fully black
		valOverlay.BackgroundTransparency = v

		-- val slider: black → current hue at full brightness
		valS.knob.Position = UDim2.new(v, 0, 0.5, 0)
		valS.grad.Color = ColorSequence.new({
			ColorSequenceKeypoint.new(0,   Color3.fromRGB(0, 0, 0)),
			ColorSequenceKeypoint.new(1,   Color3.fromHSV(h, math.max(s, 0.6), 1)),
		})

		-- alpha slider: colour → faded
		alpS.knob.Position = UDim2.new(1 - alpha, 0, 0.5, 0)
		alpS.grad.Color = ColorSequence.new({
			ColorSequenceKeypoint.new(0,   Color3.fromRGB(17, 16, 26)),
			ColorSequenceKeypoint.new(1,   col),
		})
	end

	-- ── Mouse helpers ─────────────────────────────────────────────────────────
	local function getMousePos()
		local mp = UserInputService:GetMouseLocation()
		local inset = GuiService:GetGuiInset()
		return Vector2.new(mp.X - inset.X, mp.Y - inset.Y)
	end

	local dragTarget = nil

	local function discFromMouse()
		local mp   = getMousePos()
		local ap   = discContainer.AbsolutePosition
		local sz   = discContainer.AbsoluteSize
		local dx   = mp.X - (ap.X + sz.X / 2)
		local dy   = mp.Y - (ap.Y + sz.Y / 2)
		local dist = math.sqrt(dx*dx + dy*dy)
		local ang  = math.atan2(dy, dx)
		if ang < 0 then ang = ang + math.pi * 2 end
		h = ang / (math.pi * 2)
		s = math.clamp(dist / (sz.X / 2), 0, 1)
		refresh()
	end

	local function linearPct(track)
		local mp = getMousePos()
		return math.clamp((mp.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
	end

	discHit.MouseButton1Down:Connect(function() dragTarget = "disc"; discFromMouse() end)
	valS.hit.MouseButton1Down:Connect(function() dragTarget = "val"; v = linearPct(valS.track); refresh() end)
	alpS.hit.MouseButton1Down:Connect(function() dragTarget = "alpha"; alpha = 1 - linearPct(alpS.track); refresh() end)

	UserInputService.InputChanged:Connect(function(input)
		if not dragTarget or input.UserInputType ~= Enum.UserInputType.MouseMovement then return end
		if dragTarget == "disc"  then discFromMouse()
		elseif dragTarget == "val"   then v     = linearPct(valS.track);          refresh()
		elseif dragTarget == "alpha" then alpha = 1 - linearPct(alpS.track);      refresh()
		end
	end)

	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then dragTarget = nil end
	end)

	inputBox.FocusLost:Connect(function()
		local raw = inputBox.Text:gsub("%s", "")
		if raw == "" then return end
		local parsed = nil
		local hex = raw:gsub("#", "")
		if #hex == 6 then
			local r = tonumber(hex:sub(1,2), 16)
			local g = tonumber(hex:sub(3,4), 16)
			local b = tonumber(hex:sub(5,6), 16)
			if r and g and b then parsed = Color3.fromRGB(r, g, b) end
		end
		if not parsed then
			local r, g, b = raw:match("^(%d+),(%d+),(%d+)$")
			if r and g and b then
				r, g, b = tonumber(r), tonumber(g), tonumber(b)
				if r <= 255 and g <= 255 and b <= 255 then parsed = Color3.fromRGB(r, g, b) end
			end
		end
		if parsed then h, s, v = parsed:ToHSV(); refresh() end
		inputBox.Text = ""
	end)

	-- ── Popup positioning ─────────────────────────────────────────────────────
	local function positionPopup()
		local ap = swatch.AbsolutePosition
		local fp = MainFrame.AbsolutePosition
		local belowY = ap.Y - fp.Y + 42
		if belowY + POPUP_H > MainFrame.AbsoluteSize.Y then
			belowY = ap.Y - fp.Y - POPUP_H - 8
		end
		popup.Position = UDim2.new(0, ap.X - fp.X - POPUP_W + 34, 0, belowY)
	end

	swatchBtn.MouseButton1Click:Connect(function()
		open = not open
		positionPopup()
		popup.Visible = open
		tween(parent, { BackgroundColor3 = open and Color3.fromRGB(18, 17, 26) or BG_ROW }, tweenInfoFast)
	end)

	UserInputService.InputBegan:Connect(function(input)
		if not open then return end
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			task.defer(function()
				if not popup.Visible then return end
				if inputBox:IsFocused() then return end
				if dragTarget then return end
				local mp = getMousePos()
				local ap, as = popup.AbsolutePosition, popup.AbsoluteSize
				local inside = mp.X >= ap.X and mp.X <= ap.X + as.X and mp.Y >= ap.Y and mp.Y <= ap.Y + as.Y
				local onS = mp.X >= swatch.AbsolutePosition.X and mp.X <= swatch.AbsolutePosition.X + swatch.AbsoluteSize.X
					and mp.Y >= swatch.AbsolutePosition.Y and mp.Y <= swatch.AbsolutePosition.Y + swatch.AbsoluteSize.Y
				if not inside and not onS then
					open = false
					popup.Visible = false
					tween(parent, { BackgroundColor3 = BG_ROW }, tweenInfoFast)
				end
			end)
		end
	end)

	refresh()
	return function() return currentColor end
end

