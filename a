local function buildToggle(parent, defaultOn, configKey)
	local saved = savedConfig[configKey]
	local state = (saved and saved.type == "boolean") and saved.value or (defaultOn or false)

	local track = Instance.new("Frame")
	track.Size             = UDim2.new(0, 44, 0, 24)
	track.Position         = IS_MOBILE and UDim2.new(1, -44, 1, -36) or UDim2.new(1, -44, 0.5, -12)
	track.BackgroundColor3 = state and ACCENT or BG_INPUT
	track.BorderSizePixel  = 0
	track.ZIndex           = 3
	track.Parent           = parent
	corner(track, 12)

	local ball = Instance.new("Frame")
	ball.Size             = UDim2.new(0, 16, 0, 16)
	ball.Position         = state and UDim2.new(1, -20, 0.5, -8) or UDim2.new(0, 4, 0.5, -8)
	ball.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	ball.BorderSizePixel  = 0
	ball.ZIndex           = 4
	ball.Parent           = track
	corner(ball, 8)

	local hitBtn = Instance.new("TextButton")
	hitBtn.Size                = UDim2.new(1, 0, 1, 0)
	hitBtn.BackgroundTransparency = 1
	hitBtn.Text                = ""
	hitBtn.ZIndex              = 5
	hitBtn.Parent              = track

	local onChange = nil

	local function applyVisual()
		tween(track, { BackgroundColor3 = state and ACCENT or BG_INPUT })
		tween(ball,  { Position = state and UDim2.new(1,-20,0.5,-8) or UDim2.new(0,4,0.5,-8) }, TI_SPRING)
	end

	local function doToggle()
		state = not state
		applyVisual()
		tween(parent, { BackgroundColor3 = Color3.fromRGB(20, 19, 30) }, TI_FAST)
		task.delay(0.12, function() tween(parent, { BackgroundColor3 = BG_ROW }) end)
		if configKey then saveConfig(configRegistry) end
		if onChange then onChange(state) end
	end

	local function setState(v, silent)
		if state == v then return end
		state = v
		applyVisual()
		if configKey then saveConfig(configRegistry) end
		if onChange and not silent then onChange(state) end
	end

	hitBtn.MouseButton1Click:Connect(doToggle)
	hitBtn.MouseEnter:Connect(function() tween(parent, { BackgroundColor3 = Color3.fromRGB(18,17,26) }, TI_FAST) end)
	hitBtn.MouseLeave:Connect(function() tween(parent, { BackgroundColor3 = BG_ROW }, TI_FAST) end)

	return function() return state end, doToggle, function(fn) onChange = fn end, setState
end

local function buildSlider(parent, minVal, maxVal, defaultVal, configKey, step)
	local hasFrac = (minVal ~= math.floor(minVal)) or (maxVal ~= math.floor(maxVal))
		or (defaultVal and defaultVal ~= math.floor(defaultVal))
		or (step ~= nil and step ~= math.floor(step))
	local stepVal = step or (hasFrac and 0.1 or 1)

	local function roundValue(v)
		v = math.clamp(v, minVal, maxVal)
		local snapped = minVal + math.floor((v - minVal) / stepVal + 0.5) * stepVal
		snapped = math.clamp(snapped, minVal, maxVal)
		return math.floor(snapped * 1000 + 0.5) / 1000
	end

	local function fmt(v)
		if hasFrac then
			local s = string.format("%.3f", v):gsub("0+$", ""):gsub("%.$", ".0")
			return s
		end
		return tostring(math.round(v))
	end

	local saved = savedConfig[configKey]
	local value = roundValue((saved and saved.type == "number" and saved.value) or defaultVal or minVal)

	local container = Instance.new("Frame")
	container.Size             = UDim2.new(0, W_SLIDER, 0, 40)
	container.Position         = IS_MOBILE and UDim2.new(1, -W_SLIDER, 1, -44) or UDim2.new(1, -W_SLIDER, 0.5, -20)
	container.BackgroundTransparency = 1
	container.BorderSizePixel  = 0
	container.ZIndex           = 3
	container.Parent           = parent

	local valBox = Instance.new("TextBox")
	valBox.Size             = UDim2.new(0, 46, 0, 16)
	valBox.ClearTextOnFocus = false
	valBox.Position         = UDim2.new(0, 0, 0.5, -8)
	valBox.BackgroundTransparency = 1
	valBox.BorderSizePixel  = 0
	valBox.Text             = fmt(value)
	valBox.TextColor3       = ACCENT
	valBox.TextSize         = 13
	valBox.Font             = Enum.Font.GothamBold
	valBox.TextXAlignment   = Enum.TextXAlignment.Right
	valBox.ZIndex           = 4
	valBox.Parent           = container

	local track = Instance.new("Frame")
	track.Size             = UDim2.new(0, SLIDER_TRACK_W, 0, 4)
	track.Position         = UDim2.new(0, 56, 0.5, -2)
	track.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
	track.BorderSizePixel  = 0
	track.ZIndex           = 3
	track.Parent           = container
	corner(track, 2)

	local fill = Instance.new("Frame")
	fill.Size             = UDim2.new((value - minVal) / (maxVal - minVal), 0, 1, 0)
	fill.BackgroundColor3 = ACCENT
	fill.BorderSizePixel  = 0
	fill.ZIndex           = 4
	fill.Parent           = track
	corner(fill, 2)

	local thumb = Instance.new("Frame")
	thumb.Size             = UDim2.new(0, 12, 0, 12)
	thumb.Position         = UDim2.new((value - minVal) / (maxVal - minVal), -6, 0.5, -6)
	thumb.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	thumb.BorderSizePixel  = 0
	thumb.ZIndex           = 5
	thumb.Parent           = track
	corner(thumb, 6)

	local onChange = nil

	local function applyValue(v, silent)
		value = v
		local pct = (value - minVal) / (maxVal - minVal)
		fill.Size      = UDim2.new(pct, 0, 1, 0)
		thumb.Position = UDim2.new(pct, -6, 0.5, -6)
		valBox.Text    = fmt(value)
		if configKey then saveConfig(configRegistry) end
		if onChange and not silent then onChange(value) end
	end

	local dragging = false
	local dragPointer = nil
	local hitPad = IS_MOBILE and 36 or 12
	local hitbox = Instance.new("TextButton")
	hitbox.Size             = UDim2.new(1, hitPad, 1, hitPad + 2)
	hitbox.Position         = UDim2.new(0, -hitPad/2, 0.5, -(hitPad+2)/2)
	hitbox.BackgroundTransparency = 1
	hitbox.Text             = ""
	hitbox.ZIndex           = 6
	hitbox.Parent           = track

	local function updateFromX(x)
		applyValue(roundValue(minVal + math.clamp((x - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1) * (maxVal - minVal)))
	end

	hitbox.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragPointer = input
			updateFromX(input.Position.X)
		end
	end)
	onPointerMove(function(x, _, input)
		if not dragging then return end
		if dragPointer.UserInputType == Enum.UserInputType.Touch and input ~= dragPointer then return end
		updateFromX(x)
	end)
	onPointerEnd(function(input)
		if dragPointer and dragPointer.UserInputType == Enum.UserInputType.Touch and input ~= dragPointer then return end
		dragging = false
		dragPointer = nil
	end)

	valBox.FocusLost:Connect(function()
		local n = tonumber(valBox.Text)
		if n then applyValue(roundValue(n)) else valBox.Text = fmt(value) end
	end)

	return function() return value end, function(fn) onChange = fn end, function(v) applyValue(roundValue(v), true) end
end

local function buildDropdown(parent, options, default, configKey)
