function Nova:_buildMobileToggle()
	local PC_DEBUG_MODE = true

	if not self._isMobile and not PC_DEBUG_MODE then return end

	local C   = self._C
	local Gui = self._Gui

	local function makeInst(className, properties)
		local inst = Instance.new(className)
		for k, v in pairs(properties) do
			if typeof(k) == "string" then inst[k] = v end
		end
