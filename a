		TextColor3             = isOn and C.TextMain or C.TextDark,
		Font                   = Enum.Font.GothamMedium,
		TextSize               = 13,
		TextXAlignment         = Enum.TextXAlignment.Left,
		Parent                 = F,
	})

	local sgear = Instance.new("ImageButton")
	sgear.Size                   = UDim2.new(0, 12, 0, 12)
	sgear.AnchorPoint            = Vector2.new(0, 0.5)
	sgear.Position               = UDim2.new(0, 42, 0.5, 0)
	sgear.BackgroundTransparency = 1
	sgear.Image                  = "rbxassetid://70543102142774"
	sgear.ImageColor3            = C.TextDark
	sgear.ImageTransparency      = 0.35
	sgear.ZIndex                 = 2
	sgear.Parent                 = F

	lbObj:GetPropertyChangedSignal("TextBounds"):Connect(function()
		sgear.Position = UDim2.new(0, 42 + lbObj.TextBounds.X + 6, 0.5, 0)
	end)

	local kbs = { key = nil, mode = "toggle", tag = keytag }

	local function setToggle(v, fire)
		toggled = v
		-- // box color is driven through _regAccent, but we still tween it directly for instant feedback
		tw(box,      TW.Default, { BackgroundColor3 = v and C.Accent or C.ElemBg }):Play()
		tw(checkImg, TW.Default, { ImageTransparency = v and 0 or 1 }):Play()
		tw(lbObj,    TW.Default, { TextColor3 = v and C.TextMain or C.TextDark }):Play()
		if fire ~= false then
			if key then self._ConfigData[key] = v end
			if onChange then onChange(v) end
		end
	end

	if key then
		self._ConfigData[key] = isOn
		self._ConfigCallbacks[key] = function(v, fromLoad)
			if fromLoad then setToggle(v, false) end
			if not fromLoad and onChange then onChange(v) end
		end
	end

	local tid   = "tog_" .. tostring(math.random(1e9))
	local kconn = UIS.InputBegan:Connect(function(i, proc)
		if proc or not kbs.key or i.UserInputType ~= Enum.UserInputType.Keyboard then return end
		local k = tostring(i.KeyCode):gsub("Enum.KeyCode.", "")
		if k ~= kbs.key then return end
		if kbs.mode == "toggle" then setToggle(not toggled)
		elseif kbs.mode == "hold" then setToggle(true) end
	end)

	self._IECBs[tid] = function(i)
		if not kbs.key or i.UserInputType ~= Enum.UserInputType.Keyboard then return end
		local k = tostring(i.KeyCode):gsub("Enum.KeyCode.", "")
		if k == kbs.key and kbs.mode == "hold" then setToggle(false) end
	end

	F.Destroying:Connect(function()
		self._ICBs[tid]  = nil
		self._IECBs[tid] = nil
		kconn:Disconnect()
	end)

	local function doToggle()
		if self._activePopup then self:_closePopup(); return end
		setToggle(not toggled)
	end

	F.MouseButton1Click:Connect(doToggle)
	F.TouchTap:Connect(doToggle)
	F.MouseEnter:Connect(function() ftw(bs, { Transparency = 0   }):Play() end)
	F.MouseLeave:Connect(function() ftw(bs, { Transparency = 0.5 }):Play() end)

	local function doGear()
		if self._activePopup then self:_closePopup()
		else self:_openKeybindPopup(sgear, kbs) end
	end

	sgear.MouseButton1Click:Connect(doGear)
	sgear.TouchTap:Connect(doGear)

	keytag:GetPropertyChangedSignal("Text"):Connect(function()
		if kbs.key then
			tw(keytag, TW.Default, { TextColor3 = C.Accent, TextTransparency = 0 }):Play()
		else
			tw(keytag, TW.Default, { TextColor3 = C.TextDark, TextTransparency = 0.55 }):Play()
			keytag.Text = "[--]"
		end
	end)

	local API = {}
	function API:GetValue()  return toggled end
	function API:SetValue(v) setToggle(v, false) end
	return F, API
end

function Nova:_createSlider(parent, lbl, key, minV, maxV, defV, onChange)
	local C   = self._C
	local TW  = self._TW
	local cur = defV

	local F = newFrame({
		Size                   = UDim2.new(1, 0, 0, 42),
		BackgroundTransparency = 1,
		Parent                 = parent,
	})

	local sp = Instance.new("UIPadding", F)
	sp.PaddingLeft  = UDim.new(0, 2)
	sp.PaddingRight = UDim.new(0, 2)

	local row = newFrame({
		Size                   = UDim2.new(1, 0, 0, 16),
		BackgroundTransparency = 1,
		Parent                 = F,
	})

	newLabel({
		Size                   = UDim2.new(0.6, 0, 1, 0),
		BackgroundTransparency = 1,
		Text                   = lbl,
		TextColor3             = C.TextMain,
		Font                   = Enum.Font.GothamMedium,
		TextSize               = 13,
		TextXAlignment         = Enum.TextXAlignment.Left,
		Parent                 = row,
	})

	local valBg = newFrame({
		Size             = UDim2.new(0, 52, 0, 18),
		Position         = UDim2.new(1, -52, 0, -1),
		BackgroundColor3 = C.InputBg,
		BorderSizePixel  = 0,
		Parent           = row,
	})
	corner(valBg, 4)
	local valStroke = stroke(valBg, C.Stroke, 1, 0.6)

	local valBox = Instance.new("TextBox")
	valBox.Size                   = UDim2.new(1, -8, 1, 0)
	valBox.Position               = UDim2.new(0, 4, 0, 0)
	valBox.BackgroundTransparency = 1
	valBox.BorderSizePixel        = 0
	valBox.Font                   = Enum.Font.GothamBold
	valBox.TextSize               = 11
	valBox.TextColor3             = C.Accent
	valBox.Text                   = tostring(defV)
	valBox.TextXAlignment         = Enum.TextXAlignment.Center
	valBox.ClearTextOnFocus       = false
	valBox.ZIndex                 = 2
	valBox.Parent                 = valBg
	self:_regAccent(valBox, "TextColor3")

	local hit = Instance.new("TextButton")
	hit.Size                   = UDim2.new(1, 0, 0, self._isMobile and 44 or 28)
	hit.Position               = UDim2.new(0, 0, 0, 14)
	hit.BackgroundTransparency = 1
	hit.Text                   = ""
	hit.ZIndex                 = 2
	hit.Parent                 = F

	local track = newFrame({
		Size             = UDim2.new(1, 0, 0, 6),
		Position         = UDim2.new(0, 0, 0.5, -3),
		BackgroundColor3 = C.SliderBg,
		BorderSizePixel  = 0,
		ZIndex           = 2,
		Parent           = hit,
	})
	corner(track, 99)

	local pct = (defV - minV) / (maxV - minV)

	local fill = newFrame({
		Size             = UDim2.new(pct, 0, 1, 0),
		BackgroundColor3 = C.Accent,
		BorderSizePixel  = 0,
		ZIndex           = 2,
		Parent           = track,
	})
	corner(fill, 99)
	self:_regAccent(fill, "BackgroundColor3")

	local thumb = newFrame({
		Size             = UDim2.new(0, 14, 0, 14),
		Position         = UDim2.new(pct, -7, 0.5, -7),
		BackgroundColor3 = C.Accent,
		BorderSizePixel  = 0,
		ZIndex           = 3,
		Parent           = track,
	})
	corner(thumb, 99)
	self:_regAccent(thumb, "BackgroundColor3")

	local gs = Instance.new("UIStroke", thumb)
	gs.Color        = C.Bg
	gs.Thickness    = 2
	gs.Transparency = 0

	local dragging = false

	local function applyVal(v)
		local cl = math.clamp(v, minV, maxV)
		local p  = (cl - minV) / (maxV - minV)
		cur               = cl
		fill.Size         = UDim2.new(p, 0, 1, 0)
		thumb.Position    = UDim2.new(p, -7, 0.5, -7)
		valBox.Text       = tostring(cl)
		if key then self._ConfigData[key] = cl end
		if onChange then onChange(cl) end
	end

	if key then
		self._ConfigData[key] = defV
		self._ConfigCallbacks[key] = function(v, fromLoad)
			if fromLoad then
				local cl = math.clamp(v, minV, maxV)
				local p  = (cl - minV) / (maxV - minV)
				cur            = cl
				fill.Size      = UDim2.new(p, 0, 1, 0)
				thumb.Position = UDim2.new(p, -7, 0.5, -7)
				valBox.Text    = tostring(cl)
			end
			if not fromLoad and onChange then onChange(v) end
		end
	end

	local function updateFromX(x)
		local p2 = math.clamp((x - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
		local v  = math.floor(minV + p2 * (maxV - minV))
		if v ~= cur then
			cur            = v
			fill.Size      = UDim2.new(p2, 0, 1, 0)
			thumb.Position = UDim2.new(p2, -7, 0.5, -7)
			valBox.Text    = tostring(v)
			if key then self._ConfigData[key] = v end
			if onChange then onChange(v) end
		end
	end

	valBox.Focused:Connect(function()
		tw(valBg,     TW.Fast, { BackgroundColor3 = C.InputActive }):Play()
		tw(valStroke, TW.Fast, { Color = C.Accent, Transparency = 0.2 }):Play()
	end)

	valBox.FocusLost:Connect(function()
		tw(valBg,     TW.Fast, { BackgroundColor3 = C.InputBg }):Play()
		tw(valStroke, TW.Fast, { Color = C.Stroke, Transparency = 0.6 }):Play()
		local n = tonumber(valBox.Text)
		if n then applyVal(math.floor(n))
		else valBox.Text = tostring(cur) end
	end)

	valBox:GetPropertyChangedSignal("Text"):Connect(function()
		if valBox:IsFocused() then
			local n = tonumber(valBox.Text)
			if n then
				local cl = math.clamp(math.floor(n), minV, maxV)
				local p2 = (cl - minV) / (maxV - minV)
				fill.Size      = UDim2.new(p2, 0, 1, 0)
				thumb.Position = UDim2.new(p2, -7, 0.5, -7)
			end
		end
	end)

	local sid = "sl_" .. tostring(math.random(1e9))

	local function onDragBegin(x)
		dragging = true
		updateFromX(x)
		tw(gs,    TW.GlowIn, { Color = C.Accent, Transparency = 0.25 }):Play()
		tw(thumb, TW.BarIn,  { Size  = UDim2.new(0, 16, 0, 16) }):Play()
	end

	local function onDragEnd()
		dragging = false
		tw(gs,    TW.GlowOut, { Color = C.Bg, Transparency = 0 }):Play()
		tw(thumb, TW.Default, { Size  = UDim2.new(0, 14, 0, 14) }):Play()
	end

	hit.MouseButton1Down:Connect(function() onDragBegin(UIS:GetMouseLocation().X) end)
	hit.MouseButton1Up:Connect(onDragEnd)

	hit.TouchPan:Connect(function(_, totalTranslation, _, state)
		if state == Enum.UserInputState.Begin then onDragBegin(hit.AbsolutePosition.X + hit.AbsoluteSize.X / 2) end
		if dragging then updateFromX(hit.AbsolutePosition.X + hit.AbsoluteSize.X / 2 + totalTranslation.X) end
		if state == Enum.UserInputState.End or state == Enum.UserInputState.Cancel then onDragEnd() end
	end)

	hit.InputBegan:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.Touch then onDragBegin(i.Position.X) end
	end)

	self._ICBs[sid] = function(i)
		if dragging and isPointerMoved(i) then updateFromX(i.Position.X) end
	end

	self._IECBs[sid] = function(i)
		if dragging and isPointerEnded(i) then onDragEnd() end
	end

	F.Destroying:Connect(function()
		self._ICBs[sid]  = nil
		self._IECBs[sid] = nil
	end)

	hit.MouseEnter:Connect(function()
		tw(thumb, TW.Default, { Size = UDim2.new(0, 16, 0, 16) }):Play()
		tw(gs,    TW.GlowIn,  { Color = C.Accent, Transparency = 0.5 }):Play()
	end)

	hit.MouseLeave:Connect(function()
		if not dragging then
			tw(thumb, TW.Default, { Size = UDim2.new(0, 14, 0, 14) }):Play()
			tw(gs,    TW.GlowOut, { Color = C.Bg, Transparency = 0 }):Play()
		end
	end)

	local API = {}
	function API:GetValue() return cur end
	function API:SetValue(v)
		local cl = math.clamp(v, minV, maxV)
		local p2 = (cl - minV) / (maxV - minV)
		cur            = cl
		valBox.Text    = tostring(cl)
		fill.Size      = UDim2.new(p2, 0, 1, 0)
		thumb.Position = UDim2.new(p2, -7, 0.5, -7)
	end
	return F, API
end

function Nova:_createDropdown(parent, lbl, key, opts, defVal, isMulti, onChange)
	local C   = self._C
	local TW  = self._TW
	local ftw = function(o, p) return tw(o, TW.Fast, p) end
	local sel = {}

	if isMulti then
		if type(defVal) == "table" then for _, v in ipairs(defVal) do sel[v] = true end end
	else
		sel[type(defVal) == "string" and defVal or (opts[1] or "")] = true
	end

	local isOpen = false
	local listH  = math.min(#opts, 6) * ITEM_H + LIST_PAD * 2

	local function getList()
		local t = {}
		for _, o in ipairs(opts) do if sel[o] then t[#t + 1] = o end end
		return t
	end

	local function getDisplay()
		local t = getList()
		if isMulti then return #t == 0 and "None" or table.concat(t, ", ")
		else return t[1] or opts[1] or "" end
	end

	if key then
		local defSnapshot = isMulti and getList() or (getList()[1] or opts[1] or "")
		self._ConfigData[key] = defSnapshot
	end

	local F = newFrame({
		Size                   = UDim2.new(1, 0, 0, TOTAL_H),
		BackgroundTransparency = 1,
		ClipsDescendants       = false,
		Parent                 = parent,
	})

	newLabel({
		Size                   = UDim2.new(1, 0, 0, LABEL_H),
		BackgroundTransparency = 1,
		Text                   = lbl,
		TextColor3             = C.TextMain,
		Font                   = Enum.Font.GothamMedium,
		TextSize               = 13,
		TextXAlignment         = Enum.TextXAlignment.Left,
		Parent                 = F,
	})

	if isMulti then
		local mb = newLabel({
			Size                   = UDim2.new(0, 36, 0, 14),
			Position               = UDim2.new(1, -36, 0, 2),
			BackgroundColor3       = C.Accent,
			BackgroundTransparency = 0.6,
			Text                   = "MULTI",
			TextColor3             = C.White,
			Font                   = Enum.Font.GothamBold,
			TextSize               = 9,
			TextXAlignment         = Enum.TextXAlignment.Center,
			Parent                 = F,
		})
		corner(mb, 3)
	end

	local H = Instance.new("TextButton")
	H.Size             = UDim2.new(1, 0, 0, HEADER_H)
	H.Position         = UDim2.new(0, 0, 0, LABEL_H + 4)
	H.BackgroundColor3 = C.ElemBg
	H.BorderSizePixel  = 0
	H.Text             = ""
	H.ZIndex           = 2
	H.Parent           = F
	corner(H, 6)
	local hs = stroke(H, C.Stroke, 1, 0.5)

	local vt = newLabel({
		Size                   = UDim2.new(1, -36, 1, 0),
		Position               = UDim2.new(0, 10, 0, 0),
		BackgroundTransparency = 1,
		Text                   = getDisplay(),
		TextColor3             = C.Accent,
		Font                   = Enum.Font.GothamMedium,
		TextSize               = 12,
		TextXAlignment         = Enum.TextXAlignment.Left,
		ZIndex                 = 3,
		Parent                 = H,
	})
	self:_regAccent(vt, "TextColor3")

	local chev = Instance.new("ImageLabel")
	chev.Size                   = UDim2.new(0, 14, 0, 14)
	chev.Position               = UDim2.new(1, -24, 0.5, -7)
	chev.BackgroundTransparency = 1
	chev.Image                  = "rbxassetid://134116754541554"
	chev.ImageColor3            = C.TextDark
	chev.ZIndex                 = 3
	chev.Parent                 = H

	local LF = newFrame({
		Size             = UDim2.new(0, 1, 0, 0),
		BackgroundColor3 = C.DropBg,
		BorderSizePixel  = 0,
		ClipsDescendants = true,
		ZIndex           = 210,
		Visible          = false,
		Parent           = self._OverlayLayer,
	})
	corner(LF, 6)
	stroke(LF, C.PopupStroke, 1, 0.3)

	local sl = Instance.new("ScrollingFrame")
	sl.Size                   = UDim2.new(1, 0, 1, 0)
	sl.BackgroundTransparency = 1
	sl.BorderSizePixel        = 0
	sl.ScrollBarThickness     = 3
	sl.ScrollBarImageColor3   = C.Scrollbar
	sl.CanvasSize             = UDim2.new(0, 0, 0, 0)
	sl.AutomaticCanvasSize    = Enum.AutomaticSize.Y
	sl.Parent                 = LF

	local ll = Instance.new("UIListLayout", sl)
	ll.Padding   = UDim.new(0, 2)
	ll.SortOrder = Enum.SortOrder.LayoutOrder

	local lp = Instance.new("UIPadding", sl)
	lp.PaddingTop    = UDim.new(0, LIST_PAD)
	lp.PaddingBottom = UDim.new(0, LIST_PAD)
	lp.PaddingLeft   = UDim.new(0, 4)
	lp.PaddingRight  = UDim.new(0, 4)

	local closeGen = 0
	local imap     = {}

	local function fire()
		local l = getList()
		local v = isMulti and l or (l[1] or "")
		if key then self._ConfigData[key] = v end
		if onChange then onChange(v) end
	end

	local function refreshItem(o)
		local e = imap[o]
		if not e then return end
		local s = sel[o]
		ftw(e.btn, { BackgroundTransparency = 1, BackgroundColor3 = C.DropItem, TextColor3 = s and C.Accent or C.TextDark }):Play()
		ftw(e.dot, { BackgroundTransparency = s and 0 or 1, Size = s and UDim2.new(0, 6, 0, 6) or UDim2.new(0, 4, 0, 4) }):Play()
	end

	for idx, o in ipairs(opts) do
		local s  = sel[o]
		local ib = Instance.new("TextButton")
		ib.Size                   = UDim2.new(1, 0, 0, ITEM_H)
		ib.BackgroundColor3       = C.DropItem
		ib.BackgroundTransparency = 1
		ib.BorderSizePixel        = 0
		ib.Text                   = o
		ib.TextColor3             = s and C.Accent or C.TextDark
		ib.Font                   = Enum.Font.GothamMedium
		ib.TextSize               = 12
		ib.TextXAlignment         = Enum.TextXAlignment.Left
		ib.ZIndex                 = 211
		ib.LayoutOrder            = idx
		ib.Parent                 = sl
		corner(ib, 4)

		local ip = Instance.new("UIPadding", ib)
		ip.PaddingLeft = UDim.new(0, 10)

		local dot = newFrame({
			Size                   = s and UDim2.new(0, 6, 0, 6) or UDim2.new(0, 4, 0, 4),
			Position               = UDim2.new(1, -16, 0.5, 0),
			AnchorPoint            = Vector2.new(0.5, 0.5),
			BackgroundColor3       = C.Accent,
			BorderSizePixel        = 0,
			BackgroundTransparency = s and 0 or 1,
			ZIndex                 = 212,
			Parent                 = ib,
		})
		corner(dot, 99)
		self:_regAccent(dot, "BackgroundColor3")
		imap[o] = { btn = ib, dot = dot }

		ib.MouseEnter:Connect(function()
			if not sel[o] then ftw(ib, { BackgroundTransparency = 0, BackgroundColor3 = C.DropHover, TextColor3 = C.TextMain }):Play() end
		end)
		ib.MouseLeave:Connect(function()
			ftw(ib, { BackgroundTransparency = 1, BackgroundColor3 = C.DropItem, TextColor3 = sel[o] and C.Accent or C.TextDark }):Play()
		end)

		local function onItemSelect()
			if isMulti then
				sel[o] = not sel[o] or nil
				refreshItem(o)
				vt.Text = getDisplay()
				fire()
			else
				for k in pairs(sel) do sel[k] = nil; if imap[k] then refreshItem(k) end end
				sel[o]  = true
				refreshItem(o)
				vt.Text = o
				fire()
				self:_closeDrop()
			end
		end

		ib.MouseButton1Click:Connect(onItemSelect)
		ib.TouchTap:Connect(onItemSelect)
	end

	if key then
		self._ConfigCallbacks[key] = function(v, fromLoad)
			if fromLoad then
				sel = {}
				if isMulti and type(v) == "table" then for _, o in ipairs(v) do sel[o] = true end
				elseif type(v) == "string" then sel[v] = true end
				vt.Text = getDisplay()
				for _, o in ipairs(opts) do refreshItem(o) end
			end
			if not fromLoad and onChange then onChange(v) end
		end
	end

	local function resetAllItems() for _, o in ipairs(opts) do refreshItem(o) end end

	local function closeDD()
		closeGen = closeGen + 1
		local myGen = closeGen
		isOpen = false
		resetAllItems()
		tw(chev, TW.Fast, { Rotation = 0 }):Play()
		tw(hs,   TW.Fast, { Transparency = 0.5 }):Play()
		tw(H,    TW.Fast, { BackgroundColor3 = C.ElemBg }):Play()
		tw(LF,   TW.DropClose, { Size = UDim2.new(0, LF.Size.X.Offset, 0, 0) }):Play()
		task.delay(0.20, function()
			if closeGen ~= myGen then return end
			if LF and LF.Parent then LF.Visible = false end
		end)
	end

	local function openDD()
		if self._activeDrop then self:_closeDrop() end
		local ap   = H.AbsolutePosition
		local as   = H.AbsoluteSize
		local lw   = as.X
		local posX = ap.X
		local posY = ap.Y + as.Y + 4
		if (posY + listH) > self._Gui.AbsoluteSize.Y then posY = ap.Y - listH - 4 end
		LF.Position       = UDim2.fromOffset(posX, posY)
		LF.Size           = UDim2.new(0, lw, 0, 0)
		LF.Visible        = true
		sl.CanvasPosition = Vector2.new(0, 0)
		isOpen            = true
		closeGen          = closeGen + 1
		tw(chev, TW.Fast, { Rotation = 180 }):Play()
		tw(hs,   TW.Fast, { Transparency = 0.1 }):Play()
		tw(H,    TW.Fast, { BackgroundColor3 = Color3.fromRGB(22, 22, 34) }):Play()
		tw(LF,   TW.Drop, { Size = UDim2.new(0, lw, 0, listH) }):Play()
		self._activeDrop  = { close = closeDD }
		self._GCD.Visible = true
	end

	local function onHeaderActivate()
		self:_closePopup()
		if isOpen then self:_closeDrop() else openDD() end
	end

	H.MouseButton1Click:Connect(onHeaderActivate)
	H.TouchTap:Connect(onHeaderActivate)
	H.MouseEnter:Connect(function()
		if not isOpen then tw(hs, TW.Fast, { Transparency = 0.2 }):Play(); tw(chev, TW.Fast, { ImageColor3 = C.TextMain }):Play() end
	end)
	H.MouseLeave:Connect(function()
		if not isOpen then tw(hs, TW.Fast, { Transparency = 0.5 }):Play(); tw(chev, TW.Fast, { ImageColor3 = C.TextDark }):Play() end
	end)

	local scrollParent = parent
	while scrollParent and not scrollParent:IsA("ScrollingFrame") do scrollParent = scrollParent.Parent end
	if scrollParent then
		scrollParent:GetPropertyChangedSignal("CanvasPosition"):Connect(function()
			if isOpen then self:_closeDrop() end
		end)
	end

	F.Destroying:Connect(function()
		if isOpen then isOpen = false; self._activeDrop = nil; self._GCD.Visible = false end
		if LF and LF.Parent then LF:Destroy() end
	end)

	local API = {}
	function API:GetValue()
		local l = getList()
		return isMulti and l or (l[1] or "")
	end
	function API:SetValue(v)
		if isMulti and type(v) == "table" then
			sel = {}; for _, o in ipairs(v) do sel[o] = true end
		elseif type(v) == "string" then
			sel = {}; sel[v] = true
		end
		vt.Text = getDisplay()
		for _, o in ipairs(opts) do refreshItem(o) end
	end
	return F, API
end

function Nova:_createButton(parent, lbl, style, cb, disabled)
	local C   = self._C
	local TW  = self._TW
	local ftw = function(o, p) return tw(o, TW.Fast, p) end

	local F     = newFrame({ Size = UDim2.new(1, 0, 0, 34), BackgroundTransparency = 1, Parent = parent })
	local isPri = style == "primary"
	local isDis = disabled == true

	-- // normBg is a closure-captured reference — reads live from C so accent changes apply
	local function getNormBg() return isPri and C.BtnPrimary or C.ElemBg end

	local btn = Instance.new("TextButton")
	btn.Size             = UDim2.new(1, 0, 1, 0)
	btn.BackgroundColor3 = isDis and C.BtnDisabled or getNormBg()
	btn.BorderSizePixel  = 0
	btn.Font             = Enum.Font.GothamBold
	btn.TextSize         = 12
	btn.Text             = lbl
	btn.TextColor3       = isDis and C.TextDark or (isPri and C.White or C.Accent)
	btn.AutoButtonColor  = false
	btn.Parent           = F
	corner(btn, 6)

	if isPri and not isDis then
		stroke(btn, C.Accent, 1, 0.5)
		self:_regAccent(btn, "BackgroundColor3")
	else
		stroke(btn, C.Stroke, 1, isDis and 0.7 or 0.3)
		if not isDis then self:_regAccent(btn, "TextColor3") end
	end

	if not isDis then
		btn.MouseEnter:Connect(function()
			ftw(btn, { BackgroundColor3 = isPri and accentHover(C.Accent) or Color3.fromRGB(28, 28, 40) }):Play()
		end)
		btn.MouseLeave:Connect(function()
			ftw(btn, { BackgroundColor3 = getNormBg() }):Play()
		end)
		btn.MouseButton1Down:Connect(function()
			ftw(btn, { BackgroundColor3 = isPri and accentPress(C.Accent) or Color3.fromRGB(36, 36, 50) }):Play()
		end)
		btn.MouseButton1Up:Connect(function()
			ftw(btn, { BackgroundColor3 = getNormBg() }):Play()
		end)

		local function doClick() if cb then cb() end end
		btn.MouseButton1Click:Connect(doClick)
		btn.TouchTap:Connect(doClick)
	end

	local API = {}
	function API:SetDisabled(v)
		isDis = v
		ftw(btn, {
			BackgroundColor3 = v and C.BtnDisabled or getNormBg(),
			TextColor3       = v and C.TextDark    or (isPri and C.White or C.Accent),
		}):Play()
	end
	function API:UpdateText(t) btn.Text = t end
	return F, API
end

function Nova:_createTextInput(parent, lbl, key, ph, def, onChange)
	local C  = self._C
	local TW = self._TW

	local F = newFrame({
		Size                   = UDim2.new(1, 0, 0, 32),
		BackgroundTransparency = 1,
		Parent                 = parent,
	})

	newLabel({
		Size                   = UDim2.new(0.44, 0, 1, 0),
		BackgroundTransparency = 1,
		Text                   = lbl,
		TextColor3             = C.TextMain,
		Font                   = Enum.Font.GothamMedium,
		TextSize               = 13,
		TextXAlignment         = Enum.TextXAlignment.Left,
		Parent                 = F,
	})

	local bg = newFrame({
		Size             = UDim2.new(0.54, 0, 1, 0),
		Position         = UDim2.new(0.46, 0, 0, 0),
		BackgroundColor3 = C.InputBg,
		BorderSizePixel  = 0,
		Parent           = F,
	})
	corner(bg, 6)
	local bs = stroke(bg, C.Stroke, 1, 0.4)

	local plbl = newLabel({
		Size                   = UDim2.new(1, -20, 1, 0),
		Position               = UDim2.new(0, 10, 0, 0),
		BackgroundTransparency = 1,
		Text                   = ph or "",
		TextColor3             = C.TextDark,
		Font                   = Enum.Font.Gotham,
		TextSize               = 12,
		TextXAlignment         = Enum.TextXAlignment.Left,
		ZIndex                 = 2,
		Parent                 = bg,
	})

	local box = Instance.new("TextBox")
	box.Size                   = UDim2.new(1, -20, 1, 0)
	box.Position               = UDim2.new(0, 10, 0, 0)
	box.BackgroundTransparency = 1
	box.BorderSizePixel        = 0
	box.ClearTextOnFocus       = false
	box.Font                   = Enum.Font.GothamMedium
	box.TextSize               = 12
	box.TextColor3             = C.TextMain
	box.PlaceholderText        = ""
	box.Text                   = def or ""
	box.TextXAlignment         = Enum.TextXAlignment.Left
	box.ZIndex                 = 3
	box.Parent                 = bg

	if key then
		self._ConfigData[key] = def or ""
		self._ConfigCallbacks[key] = function(v, fromLoad)
			if fromLoad then box.Text = tostring(v) end
			if not fromLoad and onChange then onChange(v) end
		end
	end

	local function refreshPH() plbl.Visible = box.Text == "" end
	refreshPH()

	box:GetPropertyChangedSignal("Text"):Connect(function()
		refreshPH()
		if key then self._ConfigData[key] = box.Text end
		if onChange then onChange(box.Text) end
	end)

	box.Focused:Connect(function()
		tw(bg, TW.Fast, { BackgroundColor3 = C.InputActive }):Play()
		tw(bs, TW.Fast, { Color = C.Accent, Transparency = 0.2 }):Play()
	end)

	box.FocusLost:Connect(function()
		tw(bg, TW.Fast, { BackgroundColor3 = C.InputBg }):Play()
		tw(bs, TW.Fast, { Color = C.Stroke, Transparency = 0.4 }):Play()
	end)

	local API = {}
	function API:GetValue()  return box.Text end
	function API:SetValue(v) box.Text = tostring(v) end
	return F, API
end

function Nova:_createColorPicker(parent, lbl, key, defColor, onChange)
	local C   = self._C
	local TW  = self._TW
	local ftw = function(o, p) return tw(o, TW.Fast, p) end

	defColor           = defColor or Color3.fromRGB(255, 110, 150)
	local curH, curS, curV = Color3.toHSV(defColor)

	local PAD       = 10
	local POPUP_W   = 240
	local IW        = POPUP_W - PAD * 2
	local SV_H      = 130
	local STRIP_H   = 12
	local HEX_H     = 28
	local REC_DOT   = 16
	local STRIP_ROW = 14
	local POPUP_H   = PAD + SV_H + 10 + STRIP_ROW + 6 + STRIP_ROW + 10 + HEX_H + 8 + 10 + 4 + REC_DOT + PAD

	local function colorToHex(c)
		return string.format("#%02X%02X%02X",
			math.floor(c.R * 255 + 0.5),
			math.floor(c.G * 255 + 0.5),
			math.floor(c.B * 255 + 0.5))
	end

	local function curColor() return Color3.fromHSV(curH, curS, curV) end

	local function toRGB(c)
		return { r = math.round(c.R * 255), g = math.round(c.G * 255), b = math.round(c.B * 255) }
	end

	local F = newFrame({
		Size                   = UDim2.new(1, 0, 0, 36),
		BackgroundTransparency = 1,
		Parent                 = parent,
	})

	newLabel({
		Size                   = UDim2.new(1, -76, 1, 0),
		BackgroundTransparency = 1,
		Text                   = lbl,
		TextColor3             = C.TextMain,
		Font                   = Enum.Font.GothamMedium,
		TextSize               = 13,
		TextXAlignment         = Enum.TextXAlignment.Left,
		Parent                 = F,
	})

	local swatchBtn = Instance.new("TextButton")
	swatchBtn.Size             = UDim2.new(0, 60, 0, 22)
	swatchBtn.Position         = UDim2.new(1, -64, 0.5, -11)
	swatchBtn.BackgroundColor3 = defColor
	swatchBtn.BorderSizePixel  = 0
	swatchBtn.Text             = ""
	swatchBtn.AutoButtonColor  = false
	swatchBtn.Parent           = F
	corner(swatchBtn, 5)
	stroke(swatchBtn, C.Stroke, 1, 0.4)

	if key then
		self._ConfigData[key] = toRGB(defColor)
		self._ConfigCallbacks[key] = function(v, fromLoad)
			if fromLoad and type(v) == "table" and v.r then
				local c3 = Color3.fromRGB(v.r, v.g, v.b)
				curH, curS, curV           = Color3.toHSV(c3)
				swatchBtn.BackgroundColor3 = c3
				if onChange then onChange(c3) end
			end
			if not fromLoad and onChange then
				onChange(type(v) == "table" and Color3.fromRGB(v.r, v.g, v.b) or v)
			end
		end
	end

	local recentColors = {}
	local dragCount    = 0
	local activeCP     = nil

	local function refreshSwatch()
		local c = curColor()
		ftw(swatchBtn, { BackgroundColor3 = c }):Play()
		if key then self._ConfigData[key] = toRGB(c) end
		if onChange then onChange(c) end
	end

	local function closeCP()
		if not activeCP then return end
		local p = activeCP
		activeCP = nil
		ftw(p, { BackgroundTransparency = 1 }):Play()
		task.delay(0.20, function() if p and p.Parent then p:Destroy() end end)
	end

	local function makeDragSlider(trackF, onDrag)
		local dragging = false
		local sid      = "cpsl_" .. tostring(math.random(1e9))

		local function eval(mx)
			local ap = trackF.AbsolutePosition.X
			local as = trackF.AbsoluteSize.X
			onDrag(math.clamp((mx - ap) / as, 0, 1))
		end

		trackF.InputBegan:Connect(function(i)
			if not isPointerBegan(i) then return end
			dragging  = true
			dragCount = dragCount + 1
			eval(getInputPosition(i).X)
		end)

		trackF.TouchPan:Connect(function(_, totalTranslation, _, state)
			if state == Enum.UserInputState.Begin then dragging = true; dragCount = dragCount + 1 end
			if dragging then
				local midX = trackF.AbsolutePosition.X + trackF.AbsoluteSize.X / 2
				eval(midX + totalTranslation.X)
			end
			if state == Enum.UserInputState.End or state == Enum.UserInputState.Cancel then
				if dragging then dragging = false; dragCount = math.max(0, dragCount - 1) end
			end
		end)

		self._ICBs[sid] = function(i)
			if dragging and isPointerMoved(i) then eval(getInputPosition(i).X) end
		end

		self._IECBs[sid] = function(i)
			if dragging and isPointerEnded(i) then dragging = false; dragCount = math.max(0, dragCount - 1) end
		end

		trackF.Destroying:Connect(function() self._ICBs[sid] = nil; self._IECBs[sid] = nil end)
	end

	local function openCP()
		if activeCP then closeCP(); return end
		self:_closePopup()
		self:_closeDrop()
		dragCount = 0

		local ap  = swatchBtn.AbsolutePosition
		local as  = swatchBtn.AbsoluteSize
		local gsz = self._Gui.AbsoluteSize
		local px  = math.clamp(ap.X + as.X / 2 - POPUP_W / 2, 4, gsz.X - POPUP_W - 4)
		local py  = ap.Y + as.Y + 6
		if py + POPUP_H > gsz.Y - 4 then py = ap.Y - POPUP_H - 6 end

		local pop = newFrame({
			Size             = UDim2.fromOffset(POPUP_W, POPUP_H),
			Position         = UDim2.fromOffset(px, py),
			BackgroundColor3 = C.PopupBg,
			BorderSizePixel  = 0,
			ZIndex           = 201,
			ClipsDescendants = false,
			Parent           = self._PopupLayer,
		})

		local popBg = newFrame({
			Size             = UDim2.new(1, 0, 1, 0),
			BackgroundColor3 = C.PopupBg,
			BorderSizePixel  = 0,
			ZIndex           = 201,
			ClipsDescendants = true,
			Parent           = pop,
		})
		corner(popBg, 8)
		stroke(popBg, C.PopupStroke, 1, 0.25)
		pop.BackgroundTransparency = 1

		local shield = Instance.new("TextButton")
		shield.Size                   = UDim2.new(1, 0, 1, 0)
		shield.BackgroundTransparency = 1
		shield.Text                   = ""
		shield.ZIndex                 = 199
		shield.Parent                 = self._PopupLayer

		local function shieldDismiss()
			if dragCount > 0 then return end
			closeCP()
		end

		shield.MouseButton1Click:Connect(shieldDismiss)
		shield.TouchTap:Connect(shieldDismiss)
		shield.InputEnded:Connect(function(i)
			if isPointerEnded(i) and dragCount > 0 then dragCount = math.max(0, dragCount - 1) end
		end)

		local y = PAD

		local svOuter = newFrame({
			Size             = UDim2.new(0, IW, 0, SV_H),
			Position         = UDim2.new(0, PAD, 0, y),
			BackgroundColor3 = Color3.fromHSV(curH, 1, 1),
			BorderSizePixel  = 0,
			ZIndex           = 202,
			ClipsDescendants = true,
			Parent           = popBg,
		})
		corner(svOuter, 5)

		local svW = newFrame({ Size = UDim2.new(1,0,1,0), BackgroundColor3 = C.White, BorderSizePixel = 0, ZIndex = 203, Parent = svOuter })
		local wg  = Instance.new("UIGradient", svW)
		wg.Transparency = NumberSequence.new({ NumberSequenceKeypoint.new(0,0), NumberSequenceKeypoint.new(1,1) })

		local svBl = newFrame({ Size = UDim2.new(1,0,1,0), BackgroundColor3 = Color3.new(0,0,0), BorderSizePixel = 0, ZIndex = 204, Parent = svOuter })
		local bg2  = Instance.new("UIGradient", svBl)
		bg2.Transparency = NumberSequence.new({ NumberSequenceKeypoint.new(0,1), NumberSequenceKeypoint.new(1,0) })
		bg2.Rotation = 90

		local svThumb = newFrame({
			Size             = UDim2.new(0, 12, 0, 12),
			AnchorPoint      = Vector2.new(0.5, 0.5),
			BackgroundColor3 = curColor(),
			BorderSizePixel  = 0,
			ZIndex           = 207,
			Parent           = popBg,
		})
		corner(svThumb, 99)
		stroke(svThumb, C.White, 2, 0)

		local function refreshSVGradient() svOuter.BackgroundColor3 = Color3.fromHSV(curH, 1, 1) end

		local refreshBright
		local svBaseY = y

		local function refreshSVThumb()
			svThumb.Position         = UDim2.fromOffset(PAD + curS * IW, svBaseY + (1 - curV) * SV_H)
			svThumb.BackgroundColor3 = curColor()
		end
		refreshSVThumb()

		local svDragging = false
		local svId       = "cpsvd_" .. tostring(math.random(1e9))

		local function evalSV(mx, my)
			curS = math.clamp((mx - svOuter.AbsolutePosition.X) / svOuter.AbsoluteSize.X, 0, 1)
			curV = 1 - math.clamp((my - svOuter.AbsolutePosition.Y) / svOuter.AbsoluteSize.Y, 0, 1)
			refreshSVThumb()
			if refreshBright then refreshBright() end
			refreshSwatch()
		end

		svOuter.InputBegan:Connect(function(i)
			if not isPointerBegan(i) then return end
			svDragging = true; dragCount = dragCount + 1
			local pos = getInputPosition(i)
			evalSV(pos.X, pos.Y)
		end)

		svOuter.TouchPan:Connect(function(_, totalTranslation, _, state)
			if state == Enum.UserInputState.Begin then svDragging = true; dragCount = dragCount + 1 end
			if svDragging then
				local cx = svOuter.AbsolutePosition.X + curS * IW
				local cy = svOuter.AbsolutePosition.Y + (1 - curV) * SV_H
				evalSV(cx + totalTranslation.X, cy + totalTranslation.Y)
			end
			if state == Enum.UserInputState.End or state == Enum.UserInputState.Cancel then
				if svDragging then svDragging = false; dragCount = math.max(0, dragCount - 1) end
			end
		end)

		self._ICBs[svId] = function(i)
			if svDragging and isPointerMoved(i) then
				local pos = getInputPosition(i); evalSV(pos.X, pos.Y)
			end
		end
		self._IECBs[svId] = function(i)
			if svDragging and isPointerEnded(i) then svDragging = false; dragCount = math.max(0, dragCount - 1) end
		end
		svOuter.Destroying:Connect(function() self._ICBs[svId] = nil; self._IECBs[svId] = nil end)

		y = y + SV_H + 10

		local hueTrack = newFrame({
			Size             = UDim2.new(0, IW, 0, STRIP_H),
			Position         = UDim2.new(0, PAD, 0, y + (STRIP_ROW - STRIP_H) / 2),
			BackgroundColor3 = Color3.new(1,1,1),
			BorderSizePixel  = 0,
			ZIndex           = 202,
			Parent           = popBg,
		})
		corner(hueTrack, 99)

		local hg = Instance.new("UIGradient", hueTrack)
		hg.Color = ColorSequence.new({
			ColorSequenceKeypoint.new(0/6, Color3.fromHSV(0/6,1,1)),
			ColorSequenceKeypoint.new(1/6, Color3.fromHSV(1/6,1,1)),
			ColorSequenceKeypoint.new(2/6, Color3.fromHSV(2/6,1,1)),
			ColorSequenceKeypoint.new(3/6, Color3.fromHSV(3/6,1,1)),
			ColorSequenceKeypoint.new(4/6, Color3.fromHSV(4/6,1,1)),
			ColorSequenceKeypoint.new(5/6, Color3.fromHSV(5/6,1,1)),
			ColorSequenceKeypoint.new(1,   Color3.fromHSV(1,  1,1)),
		})

		local hueThumb = newFrame({
			Size             = UDim2.new(0, 14, 0, 14),
			AnchorPoint      = Vector2.new(0.5, 0.5),
			BackgroundColor3 = Color3.fromHSV(curH, 1, 1),
			BorderSizePixel  = 0,
			ZIndex           = 205,
			Parent           = popBg,
		})
		corner(hueThumb, 99)
		stroke(hueThumb, C.White, 2, 0)

		local hueBaseY = y

		local function refreshHueThumb()
			hueThumb.Position         = UDim2.fromOffset(PAD + curH * IW, hueBaseY + STRIP_ROW / 2)
			hueThumb.BackgroundColor3 = Color3.fromHSV(curH, 1, 1)
		end
		refreshHueThumb()

		makeDragSlider(hueTrack, function(pct)
			curH = pct
			refreshHueThumb(); refreshSVGradient(); refreshSVThumb(); refreshSwatch()
		end)

		y = y + STRIP_ROW + 6

		local brightTrack = newFrame({
			Size             = UDim2.new(0, IW, 0, STRIP_H),
			Position         = UDim2.new(0, PAD, 0, y + (STRIP_ROW - STRIP_H) / 2),
			BackgroundColor3 = Color3.new(1,1,1),
			BorderSizePixel  = 0,
			ZIndex           = 202,
			ClipsDescendants = true,
			Parent           = popBg,
		})
		corner(brightTrack, 99)

		local bg3 = Instance.new("UIGradient", brightTrack)
		bg3.Color = ColorSequence.new({
			ColorSequenceKeypoint.new(0, Color3.new(1,1,1)),
			ColorSequenceKeypoint.new(1, Color3.new(0,0,0)),
		})

		local brightThumb = newFrame({
			Size             = UDim2.new(0, 14, 0, 14),
			AnchorPoint      = Vector2.new(0.5, 0.5),
			BackgroundColor3 = curColor(),
			BorderSizePixel  = 0,
			ZIndex           = 205,
			Parent           = popBg,
		})
		corner(brightThumb, 99)
		stroke(brightThumb, C.White, 2, 0)

		local brightBaseY = y

		refreshBright = function()
			brightThumb.Position         = UDim2.fromOffset(PAD + (1 - curV) * IW, brightBaseY + STRIP_ROW / 2)
			brightThumb.BackgroundColor3 = curColor()
		end
		refreshBright()

		makeDragSlider(brightTrack, function(pct)
			curV = 1 - pct
			refreshBright(); refreshSVThumb(); refreshSwatch()
		end)

		y = y + STRIP_ROW + 10

		local hexRow = newFrame({
			Size                   = UDim2.new(0, IW, 0, HEX_H),
			Position               = UDim2.new(0, PAD, 0, y),
			BackgroundTransparency = 1,
			ZIndex                 = 202,
			Parent                 = popBg,
		})

		local hexBg = newFrame({
			Size             = UDim2.new(1, -44, 1, 0),
			BackgroundColor3 = C.ElemBg,
			BorderSizePixel  = 0,
			ZIndex           = 202,
			Parent           = hexRow,
		})
		corner(hexBg, 5)
		stroke(hexBg, C.Stroke, 1, 0.5)

		local hexBox = Instance.new("TextBox")
		hexBox.Size                   = UDim2.new(1, -12, 1, 0)
		hexBox.Position               = UDim2.new(0, 8, 0, 0)
		hexBox.BackgroundTransparency = 1
		hexBox.BorderSizePixel        = 0
		hexBox.Font                   = Enum.Font.GothamMedium
		hexBox.TextSize               = 11
		hexBox.TextColor3             = C.TextMain
		hexBox.Text                   = colorToHex(curColor())
		hexBox.TextXAlignment         = Enum.TextXAlignment.Left
		hexBox.PlaceholderText        = "#RRGGBB"
		hexBox.ZIndex                 = 203
		hexBox.ClearTextOnFocus       = false
		hexBox.Parent                 = hexBg

		local function syncHexBox()
			if hexBox and hexBox.Parent and not hexBox:IsFocused() then
				hexBox.Text = colorToHex(curColor())
			end
		end

		hexBox.Focused:Connect(function() ftw(hexBg, { BackgroundColor3 = C.InputActive }):Play() end)
		hexBox.FocusLost:Connect(function(enter)
			ftw(hexBg, { BackgroundColor3 = C.ElemBg }):Play()
			if not enter then return end
			local raw = hexBox.Text:gsub("[^%x#]", ""):upper()
			if raw:sub(1,1) ~= "#" then raw = "#" .. raw end
			local h6 = raw:sub(2)
			local function hi(s, e) return tonumber(h6:sub(s, e), 16) or 0 end
			if #h6 ~= 6 then return end
			curH, curS, curV = Color3.toHSV(Color3.new(hi(1,2)/255, hi(3,4)/255, hi(5,6)/255))
			refreshSVGradient(); refreshSVThumb(); refreshHueThumb(); refreshBright(); refreshSwatch(); syncHexBox()
		end)

		local copyB = Instance.new("TextButton")
		copyB.Size             = UDim2.new(0, 38, 1, 0)
		copyB.Position         = UDim2.new(1, -38, 0, 0)
		copyB.BackgroundColor3 = C.Accent
		copyB.BorderSizePixel  = 0
		copyB.Font             = Enum.Font.GothamBold
		copyB.TextSize         = 10
		copyB.Text             = "Copy"
		copyB.TextColor3       = C.White
		copyB.AutoButtonColor  = false
		copyB.ZIndex           = 203
		copyB.Parent           = hexRow
		corner(copyB, 5)

		local recRowRef

		local function rebuildRecents()
			if not recRowRef or not recRowRef.Parent then return end
			for _, ch in ipairs(recRowRef:GetChildren()) do
				if ch:IsA("TextButton") then ch:Destroy() end
			end
			for _, rc in ipairs(recentColors) do
				local h6 = rc:sub(2)
				local function rhi(s, e) return tonumber(h6:sub(s, e), 16) or 0 end
				local rc3 = Color3.fromRGB(rhi(1,2), rhi(3,4), rhi(5,6))
				local dot = Instance.new("TextButton")
				dot.Size             = UDim2.new(0, REC_DOT, 0, REC_DOT)
				dot.BackgroundColor3 = rc3
				dot.BorderSizePixel  = 0
				dot.Text             = ""
				dot.AutoButtonColor  = false
				dot.ZIndex           = 203
				dot.Parent           = recRowRef
				corner(dot, 4)
				stroke(dot, C.Stroke, 1, 0.5)
				local function applyRecent()
					curH, curS, curV = Color3.toHSV(rc3)
					refreshSVGradient(); refreshSVThumb(); refreshHueThumb(); refreshBright(); refreshSwatch(); syncHexBox()
				end
				dot.MouseButton1Click:Connect(applyRecent)
				dot.TouchTap:Connect(applyRecent)
			end
		end

		local function doCopy()
			local hex = colorToHex(curColor())
			local n   = { hex }
			for _, x in ipairs(recentColors) do if x ~= hex then n[#n+1] = x end end
			while #n > 8 do table.remove(n) end
			recentColors = n
			rebuildRecents()
			copyB.Text = "✓"
			task.delay(1.2, function() if copyB and copyB.Parent then copyB.Text = "Copy" end end)
		end

		copyB.MouseButton1Click:Connect(doCopy)
		copyB.TouchTap:Connect(doCopy)

		y = y + HEX_H + 8

		newLabel({
			Size                   = UDim2.new(0, IW, 0, 10),
			Position               = UDim2.new(0, PAD, 0, y),
			BackgroundTransparency = 1,
			Text                   = "RECENT",
			TextColor3             = C.TextDark,
			Font                   = Enum.Font.GothamMedium,
			TextSize               = 9,
			TextXAlignment         = Enum.TextXAlignment.Left,
			ZIndex                 = 202,
			Parent                 = popBg,
		})

		y = y + 10 + 4

		local recRow = newFrame({
			Size                   = UDim2.new(0, IW, 0, REC_DOT),
			Position               = UDim2.new(0, PAD, 0, y),
			BackgroundTransparency = 1,
			ZIndex                 = 202,
			ClipsDescendants       = true,
			Parent                 = popBg,
		})

		local rll = Instance.new("UIListLayout", recRow)
		rll.FillDirection = Enum.FillDirection.Horizontal
		rll.Padding       = UDim.new(0, 4)
		rll.SortOrder     = Enum.SortOrder.LayoutOrder

		recRowRef = recRow
		rebuildRecents()

		local origRS  = refreshSwatch
		refreshSwatch = function() origRS(); syncHexBox() end
		activeCP      = pop
		ftw(popBg, { BackgroundTransparency = 0 }):Play()

		pop.Destroying:Connect(function() pcall(function() shield:Destroy() end) end)
	end

	local function doSwatch()
		if activeCP then closeCP() else openCP() end
	end

	swatchBtn.MouseButton1Click:Connect(doSwatch)
	swatchBtn.TouchTap:Connect(doSwatch)

	local API = {}
	function API:GetValue()  return curColor() end
	function API:SetValue(c3)
		curH, curS, curV = Color3.toHSV(c3)
		refreshSwatch()
	end
	return F, API
end

function Nova:_createKeybind(parent, lbl, key, defaultKey, onChange)
	local C   = self._C
	local TW  = self._TW
	local ftw = function(o, p) return tw(o, TW.Fast, p) end

	local currentKey = defaultKey or nil
	local listening  = false

	local F = Instance.new("TextButton")
	F.Size                   = UDim2.new(1, 0, 0, self._isMobile and 44 or 28)
	F.BackgroundTransparency = 1
	F.Text                   = ""
	F.Parent                 = parent

	newLabel({
		Size                   = UDim2.new(1, -110, 1, 0),
		Position               = UDim2.new(0, 8, 0, 0),
		BackgroundTransparency = 1,
		Text                   = lbl,
		TextColor3             = C.TextMain,
		Font                   = Enum.Font.GothamMedium,
		TextSize               = 13,
		TextXAlignment         = Enum.TextXAlignment.Left,
		Parent                 = F,
	})

	local badgeBg = newFrame({
		Size             = UDim2.new(0, 92, 0, 20),
		Position         = UDim2.new(1, -96, 0.5, -10),
		BackgroundColor3 = C.ElemBg,
		BorderSizePixel  = 0,
		Parent           = F,
	})
	corner(badgeBg, 5)
	local badgeStroke = stroke(badgeBg, C.Stroke, 1, 0.45)

	local badge = Instance.new("TextButton")
	badge.Size                   = UDim2.new(1, 0, 1, 0)
	badge.BackgroundTransparency = 1
	badge.BorderSizePixel        = 0
	badge.Font                   = Enum.Font.GothamMedium
	badge.TextSize               = 11
	badge.Text                   = beautifyKey(currentKey)
	badge.TextColor3             = currentKey and C.Accent or C.TextDark
	badge.ZIndex                 = 2
	badge.Parent                 = badgeBg
	if currentKey then self:_regAccent(badge, "TextColor3") end

	local function setBadgeIdle()
		badge.Text = beautifyKey(currentKey)
		ftw(badge,       { TextColor3       = currentKey and C.Accent or C.TextDark }):Play()
		ftw(badgeBg,     { BackgroundColor3 = C.ElemBg }):Play()
		ftw(badgeStroke, { Color = C.Stroke, Transparency = 0.45 }):Play()
	end

	local function setBadgeListening()
		badge.Text = "..."
		ftw(badge,       { TextColor3       = Color3.fromRGB(255, 200, 80) }):Play()
		ftw(badgeBg,     { BackgroundColor3 = Color3.fromRGB(28, 26, 14) }):Play()
		ftw(badgeStroke, { Color = Color3.fromRGB(255, 200, 80), Transparency = 0.1 }):Play()
	end

	if key then
		self._ConfigData[key] = currentKey
		self._ConfigCallbacks[key] = function(v, fromLoad)
			if fromLoad then currentKey = v; setBadgeIdle() end
			if not fromLoad and onChange then onChange(v) end
		end
	end

	local listenConn = nil

	local function stopListening()
		listening = false
		if listenConn then listenConn:Disconnect(); listenConn = nil end
		setBadgeIdle()
	end

	local function startListening()
		if listening then stopListening(); return end
		listening = true
		setBadgeListening()
		listenConn = UIS.InputBegan:Connect(function(i, proc)
			if proc then return end
			if i.KeyCode == Enum.KeyCode.Escape then stopListening(); return end
			if i.UserInputType ~= Enum.UserInputType.Keyboard then return end
			currentKey = tostring(i.KeyCode):gsub("Enum.KeyCode.", "")
			stopListening()
			if key then self._ConfigData[key] = currentKey end
			if onChange then onChange(currentKey) end
		end)
	end

	badge.MouseButton1Click:Connect(startListening)
	badge.TouchTap:Connect(startListening)
	badge.MouseEnter:Connect(function() if not listening then ftw(badgeStroke, { Transparency = 0.1  }):Play() end end)
	badge.MouseLeave:Connect(function() if not listening then ftw(badgeStroke, { Transparency = 0.45 }):Play() end end)

	local pressConn = UIS.InputBegan:Connect(function(i, proc)
		if proc or listening or not currentKey then return end
		if i.UserInputType ~= Enum.UserInputType.Keyboard then return end
		local k = tostring(i.KeyCode):gsub("Enum.KeyCode.", "")
		if k == currentKey then if onChange then onChange(currentKey) end end
	end)

	F.Destroying:Connect(function()
		if listenConn then listenConn:Disconnect() end
		pressConn:Disconnect()
	end)

	local API = {}
	function API:GetValue()  return currentKey end
	function API:SetValue(k) currentKey = k; setBadgeIdle() end
	return F, API
end

