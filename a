	discHit.BackgroundTransparency = 1
	discHit.Text                = ""
	discHit.ZIndex              = 57
	discHit.Parent              = discContainer

	local function makeSliderRow(yPos, labelText)
		local holder = Instance.new("Frame")
		holder.Size             = UDim2.new(1, 0, 0, 22)
		holder.Position         = UDim2.new(0, 0, 0, yPos)
		holder.BackgroundTransparency = 1
		holder.ZIndex           = 51
		holder.Parent           = inner

		local lbl = Instance.new("TextLabel")
		lbl.Size             = UDim2.new(0, 38, 1, 0)
		lbl.BackgroundTransparency = 1
		lbl.Text             = labelText
		lbl.TextColor3       = TEXT_MUTED
		lbl.TextSize         = 11
		lbl.Font             = Enum.Font.GothamBold
		lbl.TextXAlignment   = Enum.TextXAlignment.Left
		lbl.ZIndex           = 52
		lbl.Parent           = holder

		local track = Instance.new("Frame")
		track.Size             = UDim2.new(1, -42, 0, 8)
		track.Position         = UDim2.new(0, 42, 0.5, -4)
		track.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
		track.BackgroundTransparency = 0.88
		track.BorderSizePixel  = 0
		track.ZIndex           = 52
		track.Parent           = holder
		corner(track, 4)

		local grad  = Instance.new("UIGradient")
		grad.Parent = track

		local knob = Instance.new("Frame")
		knob.AnchorPoint    = Vector2.new(0.5, 0.5)
		knob.Size           = UDim2.new(0, 14, 0, 14)
		knob.Position       = UDim2.new(0, 0, 0.5, 0)
		knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
		knob.BorderSizePixel = 0
		knob.ZIndex         = 54
		knob.Parent         = track
		corner(knob, 7)

		local ks = Instance.new("UIStroke")
		ks.Color       = Color3.fromRGB(0, 0, 0)
		ks.Transparency = 0.55
		ks.Thickness   = 1.5
		ks.Parent      = knob

		local hit = Instance.new("TextButton")
		hit.Size                = UDim2.new(1, 16, 1, 16)
		hit.Position            = UDim2.new(0, -8, 0.5, -8)
		hit.BackgroundTransparency = 1
		hit.Text                = ""
		hit.ZIndex              = 55
		hit.Parent              = track

		return { track = track, grad = grad, knob = knob, hit = hit }
	end

	local VAL_Y = DISC_SIZE + 12
	local ALP_Y = VAL_Y + 30
	local valS  = makeSliderRow(VAL_Y, "Val")
	local alpS  = makeSliderRow(ALP_Y, "Alpha")

	local HEX_Y = ALP_Y + 34
	local inputBox = Instance.new("TextBox")
	inputBox.Size             = UDim2.new(1, 0, 0, 26)
	inputBox.Position         = UDim2.new(0, 0, 0, HEX_Y)
	inputBox.BackgroundColor3 = Color3.fromRGB(23, 22, 34)
	inputBox.BorderSizePixel  = 0
	inputBox.Text             = ""
	inputBox.PlaceholderText  = "hex or r, g, b"
	inputBox.PlaceholderColor3 = TEXT_MUTED
	inputBox.TextColor3       = TEXT_MAIN
	inputBox.TextSize         = 11
	inputBox.Font             = Enum.Font.Gotham
	inputBox.TextXAlignment   = Enum.TextXAlignment.Center
	inputBox.ClearTextOnFocus = false
	inputBox.ZIndex           = 52
	inputBox.Parent           = inner
	corner(inputBox, 6)

	local function refresh()
		local col = Color3.fromHSV(h, s, v)
		currentColor = col
		swatch.BackgroundColor3 = col

		local ang = (h * math.pi * 2) - (math.pi * 0.5)
		discKnob.Position = UDim2.new(0, DISC_R + math.cos(ang)*s*DISC_R, 0, DISC_R + math.sin(ang)*s*DISC_R)

		valOverlay.BackgroundTransparency = v
		valS.knob.Position = UDim2.new(v, 0, 0.5, 0)
		valS.grad.Color = ColorSequence.new({
			ColorSequenceKeypoint.new(0, Color3.fromRGB(0,0,0)),
			ColorSequenceKeypoint.new(1, Color3.fromHSV(h, math.max(s,0.6), 1)),
		})

		alpS.knob.Position = UDim2.new(1 - alpha, 0, 0.5, 0)
		alpS.grad.Color = ColorSequence.new({
			ColorSequenceKeypoint.new(0, Color3.fromRGB(17,16,26)),
			ColorSequenceKeypoint.new(1, col),
		})

		if configKey then saveConfig(configRegistry) end
		if onChange then onChange(col) end
	end

	local dragTarget = nil
	local dragPointer = nil

	local function discFromPoint(px, py)
		local ap  = discContainer.AbsolutePosition
		local sz  = discContainer.AbsoluteSize
		local cx, cy = ap.X + sz.X/2, ap.Y + sz.Y/2
		local dx, dy = px - cx, py - cy
		local ang = math.atan2(dy, dx) + (math.pi * 0.5)
		if ang < 0 then ang += math.pi * 2 end
		if ang > math.pi * 2 then ang -= math.pi * 2 end
		h = ang / (math.pi * 2)
		s = math.clamp(math.sqrt(dx*dx+dy*dy) / (sz.X/2), 0, 1)
		refresh()
	end

	local function linearPct(trackFrame, px)
		return math.clamp((px - trackFrame.AbsolutePosition.X) / trackFrame.AbsoluteSize.X, 0, 1)
	end

	discHit.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.Touch then
			dragTarget = "disc"; dragPointer = input; discFromPoint(input.Position.X, input.Position.Y)
		end
	end)
	valS.hit.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.Touch then
			dragTarget = "val"; dragPointer = input; v = linearPct(valS.track, input.Position.X); refresh()
		end
	end)
	alpS.hit.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.Touch then
			dragTarget = "alpha"; dragPointer = input; alpha = 1 - linearPct(alpS.track, input.Position.X); refresh()
		end
	end)

	onPointerMove(function(x, y, input)
		if not dragTarget then return end
		if dragPointer.UserInputType == Enum.UserInputType.Touch and input ~= dragPointer then return end
		if dragTarget == "disc"  then discFromPoint(x, y)
		elseif dragTarget == "val" then v = linearPct(valS.track, x); refresh()
		elseif dragTarget == "alpha" then alpha = 1 - linearPct(alpS.track, x); refresh()
		end
	end)
	onPointerEnd(function(input)
		if dragPointer and dragPointer.UserInputType == Enum.UserInputType.Touch and input ~= dragPointer then return end
		dragTarget = nil
		dragPointer = nil
	end)

	inputBox.FocusLost:Connect(function()
		local raw = inputBox.Text:gsub("%s", "")
		if raw == "" then return end
		local parsed
		local hex = raw:gsub("#", "")
		if #hex == 6 then
			local r = tonumber(hex:sub(1,2), 16)
			local g = tonumber(hex:sub(3,4), 16)
			local b = tonumber(hex:sub(5,6), 16)
			if r and g and b then parsed = Color3.fromRGB(r, g, b) end
		end
		if not parsed then
			local r, g, b = raw:match("^(%d+),(%d+),(%d+)$")
			if r and g and b then
				r, g, b = tonumber(r), tonumber(g), tonumber(b)
				if r <= 255 and g <= 255 and b <= 255 then parsed = Color3.fromRGB(r, g, b) end
			end
		end
		if parsed then h, s, v = parsed:ToHSV(); refresh() end
		inputBox.Text = ""
	end)

	local function positionPopup()
		local ap = swatch.AbsolutePosition
		local fp = MainFrame.AbsolutePosition
		local belowY = ap.Y - fp.Y + 42
		if belowY + POPUP_H > MainFrame.AbsoluteSize.Y then belowY = ap.Y - fp.Y - POPUP_H - 8 end
		local px = math.clamp(ap.X - fp.X - POPUP_W + 34, 8, math.max(8, MainFrame.AbsoluteSize.X - POPUP_W - 8))
		local py = math.clamp(belowY, 8, math.max(8, MainFrame.AbsoluteSize.Y - POPUP_H - 8))
		popup.Position = UDim2.fromOffset(px, py)
	end

	swatchBtn.MouseButton1Click:Connect(function()
		open = not open
		positionPopup()
		popup.Visible = open
		tween(parent, { BackgroundColor3 = open and Color3.fromRGB(18,17,26) or BG_ROW }, TI_FAST)
	end)

	onInputBegan(function(input)
		if not open then return end
		if isPointerDownEnd(input) then
			local point = Vector2.new(input.Position.X, input.Position.Y)
			task.defer(function()
				if not popup.Visible or inputBox:IsFocused() or dragTarget then return end
				local mp = point
				local ap, as = popup.AbsolutePosition, popup.AbsoluteSize
				local onSwatch = mp.X >= swatch.AbsolutePosition.X
					and mp.X <= swatch.AbsolutePosition.X + swatch.AbsoluteSize.X
					and mp.Y >= swatch.AbsolutePosition.Y
					and mp.Y <= swatch.AbsolutePosition.Y + swatch.AbsoluteSize.Y
				if not (mp.X >= ap.X and mp.X <= ap.X+as.X and mp.Y >= ap.Y and mp.Y <= ap.Y+as.Y) and not onSwatch then
					open = false
					popup.Visible = false
					tween(parent, { BackgroundColor3 = BG_ROW }, TI_FAST)
				end
			end)
		end
	end)

	refresh()
	return function() return currentColor end, function(fn) onChange = fn end
end

local function buildMultiSelect(parent, options, defaults, configKey)
	local selected = {}
	local saved = savedConfig[configKey]
	if saved and saved.type == "table" then
		for _, val in ipairs(saved.value) do selected[val] = true end
	elseif defaults then
		for _, val in ipairs(defaults) do selected[val] = true end
	end

	local open = false
	local ITEM_H = IS_MOBILE and 44 or 30
	local contentH = #options * ITEM_H + 8
	local openH = math.min(contentH, IS_MOBILE and 220 or 280)
	local trackConn
	local onChange = nil

	local function getLabel()
		local parts = {}
		for _, opt in ipairs(options) do if selected[opt] then table.insert(parts, opt) end end
		if #parts == 0 then return "None" end
		if #parts > 2 then return parts[1] .. ", +" .. (#parts - 1) end
		return table.concat(parts, ", ")
	end

	local frame = Instance.new("Frame")
	frame.Size             = UDim2.new(0, W_WIDE, 0, 34)
	frame.Position         = IS_MOBILE and UDim2.new(1, -W_WIDE, 1, -42) or UDim2.new(1, -W_WIDE, 0.5, -17)
